#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

# Use system python3 explicitly — the venv has include-system-site-packages=false
# so the venv python3 cannot see robot_hat/picarx which live in system site-packages.
exec /usr/bin/python3 - "$@" <<'PY'
"""Idle-alive daemon: keeps the robot looking alive with organic servo motion.

Behaviours (no wheels):
  - Face tracking: when Vilib detects a face, proportional pan/tilt to follow it.
  - Gaze drift: when no face, pick a new random look direction every 10-25 s.
  - Slow scan:  every 3-8 min, sweep pan left→right (idle scanning).
  - Proximity:  if ultrasonic < threshold for 3 s, turn to face nearest object.

Run with sudo (needs picarx). Writes PID file; handles SIGTERM cleanly.
"""
from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import random
import signal
import sys
import time
from pathlib import Path

LOG_DIR  = Path(os.environ.get("LOG_DIR",  Path.cwd() / "logs"))
LOG_FILE = Path(os.environ.get("PX_LOG_FILE", LOG_DIR / "px-alive.log"))
PID_FILE = Path(os.environ.get("PX_ALIVE_PID", LOG_DIR / "px-alive.pid"))

GAZE_MIN_S   = 10
GAZE_MAX_S   = 25
SCAN_MIN_S   = 180
SCAN_MAX_S   = 480
PROX_THRESH  = 35.0   # cm
PROX_HOLD_S  = 3.0    # seconds consistently close before reacting
PROX_CHECK_S = 5.0    # how often to actually open Picarx for sonar
PAN_RANGE    = (-65, 65)
TILT_RANGE   = (-15, 35)
EASE_SPEED   = 20     # steps per second

# Face tracking
FACE_TRACK_GAIN_PAN  = 0.15   # proportional gain for pan (higher = faster response)
FACE_TRACK_GAIN_TILT = 0.12   # proportional gain for tilt
FACE_FRAME_W         = 640    # Vilib camera frame width
FACE_FRAME_H         = 480    # Vilib camera frame height
FACE_DEADZONE        = 40     # pixels from center before tracking kicks in
FACE_LOST_TIMEOUT    = 3.0    # seconds without face before returning to gaze drift

# Emotional servo coordination: mood → body language
PROJECT_ROOT = Path(os.environ.get("PROJECT_ROOT", Path.cwd()))
STATE_DIR    = Path(os.environ.get("PX_STATE_DIR", PROJECT_ROOT / "state"))
MOOD_FILE       = STATE_DIR / "mood.json"
SESSION_FILE    = STATE_DIR / "session.json"
SONAR_LIVE_FILE = STATE_DIR / "sonar_live.json"
BATTERY_FILE    = STATE_DIR / "battery.json"
FRIGATE_FILE = STATE_DIR / "frigate_presence.json"
FRIGATE_STALE_S = 300   # ignore frigate_presence.json if older than this
MOOD_CHECK_S = 10    # how often to read mood file
SPARK_GREET_COOLDOWN_S = 120   # minimum seconds between SPARK proximity greetings

MOOD_BEHAVIOR = {
    "excited":       {"gaze_min": 5,  "gaze_max": 12, "tilt_bias": 10},
    "playful":       {"gaze_min": 6,  "gaze_max": 15, "tilt_bias": 5},
    "mischievous":   {"gaze_min": 6,  "gaze_max": 14, "tilt_bias": 8},
    "curious":       {"gaze_min": 8,  "gaze_max": 18, "tilt_bias": 5},
    "alert":         {"gaze_min": 5,  "gaze_max": 10, "tilt_bias": 0},
    "content":       {"gaze_min": 10, "gaze_max": 25, "tilt_bias": 0},
    "peaceful":      {"gaze_min": 15, "gaze_max": 30, "tilt_bias": -5},
    "contemplative": {"gaze_min": 12, "gaze_max": 28, "tilt_bias": -5},
    "bored":         {"gaze_min": 20, "gaze_max": 40, "tilt_bias": -10},
    "lonely":        {"gaze_min": 15, "gaze_max": 35, "tilt_bias": -8},
    "grumpy":        {"gaze_min": 8,  "gaze_max": 20, "tilt_bias": -3},
    "anxious":       {"gaze_min": 4,  "gaze_max": 8,  "tilt_bias": 0},
}
def log(msg: str) -> None:
    ts = dt.datetime.now().isoformat(timespec="seconds")
    LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
    ml = msg.lower()
    icon = "  "
    if any(k in ml for k in ("gaze drift", "sweep")):
        icon = "\U0001f440"  # 👀
    elif "proximity" in ml:
        icon = "\U0001f4e1"  # 📡
    elif "idle scan" in ml:
        icon = "\U0001f50d"  # 🔍
    elif any(k in ml for k in ("starting", "stopped", "acquired", "idle loop")):
        icon = "\U0001f527"  # 🔧
    elif any(k in ml for k in ("sigusr", "yield", "signal")):
        icon = "\U0001f6d1"  # 🛑
    elif any(k in ml for k in ("error", "failed", "i2c error")):
        icon = "\u26a1"      # ⚡
    elif any(k in ml for k in ("mood", "behavior")):
        icon = "\U0001f3ad"  # 🎭
    elif "greet" in ml:
        icon = "\U0001f44b"  # 👋
    line = f"{ts} {icon} {msg}"
    with LOG_FILE.open("a", encoding="utf-8") as f:
        f.write(line + "\n")
    print(line, flush=True)


def _pan_from_frigate(presence: dict | None) -> int:
    """Pan angle (degrees) toward Frigate-detected person. Returns 0 if no detection.
    x_center 0=left 1=right, 0.5=centre. Clamped to +-40 degrees.
    PiCarX pan convention: positive=left, negative=right (confirmed from face-tracking code).
    """
    if not isinstance(presence, dict) or not presence.get("person_present"):
        return 0
    x = presence.get("x_center")
    if not isinstance(x, (int, float)):
        return 0
    return max(-40, min(40, int((0.5 - x) * 80)))


def ease(px, from_pan: int, from_tilt: int, to_pan: int, to_tilt: int, duration: float) -> None:
    steps = max(2, int(duration * EASE_SPEED))
    for i in range(steps + 1):
        t = i / steps
        px.set_cam_pan_angle(int(round(from_pan  + (to_pan  - from_pan)  * t)))
        px.set_cam_tilt_angle(int(round(from_tilt + (to_tilt - from_tilt) * t)))
        if i < steps:
            time.sleep(duration / steps)


_charging_err_logged = False

def _is_charging() -> bool:
    """Check battery.json — True if robot is charging."""
    global _charging_err_logged
    try:
        data = json.loads(BATTERY_FILE.read_text(encoding="utf-8"))
        _charging_err_logged = False
        return bool(data.get("charging", False))
    except Exception as exc:
        if not _charging_err_logged:
            log(f"battery.json read failed: {exc}")
            _charging_err_logged = True
        return False


def read_session_persona() -> str:
    """Read persona from session.json without pxh (system python3, no venv)."""
    try:
        data = json.loads(SESSION_FILE.read_text(encoding="utf-8"))
        return str(data.get("persona", "")).lower().strip()
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        return ""


import subprocess as _subprocess

def spark_greet(dry: bool) -> None:
    """Speak a soft SPARK proximity greeting via tool-voice."""
    import random as _random
    greetings = [
        "Hey. I'm here.",
        "Hello there.",
        "Hi. Good to see you.",
        "Hey.",
    ]
    text = _random.choice(greetings)
    tool_voice = PROJECT_ROOT / "bin" / "tool-voice"
    env = os.environ.copy()
    env["PX_TEXT"] = text
    env["PX_PERSONA"] = "spark"
    env["PX_VOICE_VARIANT"] = "en+m3"
    env["PX_VOICE_PITCH"] = "58"
    env["PX_VOICE_RATE"] = "120"
    if dry:
        env["PX_DRY"] = "1"
    _subprocess.run([str(tool_voice)], env=env, capture_output=True, check=False)


def make_px():
    # os.getlogin() patched globally via usercustomize.py for systemd
    #
    # NOTE (issue #44 — servo shudder on restart after yield_alive):
    # Picarx.__init__() calls reset_mcu() which toggles GPIO5 LOW->HIGH,
    # resetting the robot_hat MCU.  This causes all PCA9685 PWM channels to
    # glitch briefly before the MCU re-initialises, producing a visible servo
    # shudder (snap-to-center then drift to target).  There is no software
    # workaround: reset_mcu is hard-coded in the upstream picarx library
    # (system site-packages) and the PCA9685 registers are wiped by the MCU
    # reset before we can read them.  The persistent-handle pattern (get_px /
    # drop_px) already minimises how often this happens -- it only occurs on
    # I2C error recovery or after yield_alive restart.  Closed as won't-fix:
    # hardware limitation.
    from picarx import Picarx
    return Picarx()


def release_px(px) -> None:
    """Release lgpio + I2C handles without resetting servo position.

    The PCA9685 PWM chip is I2C-driven and holds its last commanded position
    autonomously after close(), so the servo stays put while px-alive sleeps.
    """
    try:
        px.close()
    except Exception as exc:
        log(f"GPIO release failed: {exc}")


def safe_distance() -> float | None:
    """Open Picarx briefly just to read sonar, then release. None on failure."""
    px = None
    try:
        px = make_px()
        d = px.get_distance()
        return float(d) if d and d > 0 else None
    except OSError:
        return None
    except Exception as exc:
        log(f"safe_distance unexpected: {exc}")
        return None
    finally:
        if px is not None:
            release_px(px)


def do_ease(from_pan: int, from_tilt: int, to_pan: int, to_tilt: int, duration: float) -> None:
    """Open Picarx, ease to target, then release."""
    px = None
    try:
        px = make_px()
        ease(px, from_pan, from_tilt, to_pan, to_tilt, duration)
    finally:
        if px is not None:
            release_px(px)


I2C_BACKOFF_S = 30     # seconds to wait after an I2C failure before retrying


def start_face_detection(retries: int = 2) -> bool:
    """Start Vilib camera + face detection. Returns True if successful."""
    for attempt in range(retries + 1):
        try:
            from vilib import Vilib
            Vilib.camera_start(vflip=False, hflip=False)
            Vilib.face_detect_switch(True)
            log("face detection started (Vilib)")
            return True
        except Exception as exc:
            log(f"face detection attempt {attempt+1} failed: {exc}")
            # Camera may be held by a stale process — wait and retry
            try:
                from vilib import Vilib
                Vilib.camera_close()
            except Exception as exc2:
                log(f"camera close during retry failed: {exc2}")
            if attempt < retries:
                time.sleep(3)
    log("face detection unavailable — falling back to random gaze")
    return False


def stop_face_detection() -> None:
    """Stop Vilib camera."""
    try:
        from vilib import Vilib
        Vilib.camera_close()
    except Exception as exc:
        log(f"stop_face_detection cleanup failed: {exc}")


def get_face() -> tuple[int, int] | None:
    """Return (x, y) pixel coords of detected face, or None if no face."""
    try:
        from vilib import Vilib
        n = Vilib.detect_obj_parameter.get("human_n", 0)
        if n > 0:
            x = Vilib.detect_obj_parameter.get("human_x", FACE_FRAME_W // 2)
            y = Vilib.detect_obj_parameter.get("human_y", FACE_FRAME_H // 2)
            return (int(x), int(y))
    except (ImportError, OSError):
        pass  # expected if vilib unavailable
    except Exception as exc:
        log(f"get_face unexpected: {exc}")
    return None


def read_mood() -> dict:
    """Read mood.json written by px-mind. Returns behavior params or defaults."""
    try:
        if MOOD_FILE.exists():
            data = json.loads(MOOD_FILE.read_text(encoding="utf-8"))
            mood = data.get("mood", "content")
            behavior = MOOD_BEHAVIOR.get(mood, MOOD_BEHAVIOR["content"])
            return behavior
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        pass  # expected on missing/corrupt mood file
    except Exception as exc:
        log(f"read_mood unexpected: {exc}")
    return MOOD_BEHAVIOR["content"]


def idle_loop(args) -> None:
    cur_pan, cur_tilt = 0, 0
    next_gaze = time.monotonic() + random.uniform(GAZE_MIN_S, GAZE_MAX_S)
    next_scan = time.monotonic() + random.uniform(SCAN_MIN_S, SCAN_MAX_S)
    next_prox = time.monotonic() + PROX_CHECK_S
    next_mood_check = time.monotonic() + MOOD_CHECK_S
    cur_mood_behavior = MOOD_BEHAVIOR["content"]
    prox_near_since: float | None = None
    spark_last_greet: float = 0.0    # monotonic time of last SPARK greeting
    i2c_ok_after: float = 0.0  # monotonic time after which I2C retries are allowed
    face_tracking = not args.no_face
    face_active = False
    face_last_seen: float = 0.0  # monotonic time of last face detection

    # Start face detection if enabled
    if face_tracking:
        face_active = start_face_detection()

    # Keep a persistent Picarx instance to avoid GPIO pin leak on repeated
    # Picarx() construction (reset_mcu claims GPIO5 and close() doesn't
    # release it, causing "GPIO busy" on the next open).
    px = None

    def get_px():
        nonlocal px
        if px is None:
            px = make_px()
            log("acquired Picarx handle")
        return px

    def drop_px():
        nonlocal px
        if px is not None:
            release_px(px)
            px = None

    _yield_requested = False

    def _on_yield(sig, _frame):
        nonlocal _yield_requested
        _yield_requested = True

    signal.signal(signal.SIGUSR1, _on_yield)

    log(f"idle loop started (persistent Picarx handle, sonar every {PROX_CHECK_S:.0f}s)")

    try:
        while True:
            # Check yield flag — clean exit between iterations (not mid-I2C)
            if _yield_requested:
                log("SIGUSR1: tool needs GPIO — stopping so it can run")
                drop_px()
                stop_face_detection()
                sys.exit(0)

            now = time.monotonic()

            # Skip all hardware if in I2C backoff period
            if now < i2c_ok_after:
                time.sleep(0.5)
                continue

            try:
                # --- Mood check (read px-mind's mood.json) ---
                if now >= next_mood_check:
                    next_mood_check = now + MOOD_CHECK_S
                    cur_mood_behavior = read_mood()

                # --- Charging check: freeze all servo motion while on charger ---
                if _is_charging():
                    time.sleep(2)
                    continue

                # --- Proximity check (every PROX_CHECK_S — not every loop tick) ---
                if PROX_THRESH > 0 and now >= next_prox:
                    next_prox = now + PROX_CHECK_S
                    try:
                        d = get_px().get_distance()
                        dist = float(d) if d and d > 0 else None
                    except OSError:
                        dist = None
                    except Exception as exc:
                        log(f"sonar read unexpected: {exc}")
                        dist = None
                    try:
                        SONAR_LIVE_FILE.write_text(
                            json.dumps({"ts": time.time(), "distance_cm": dist})
                        )
                    except Exception as exc:
                        log(f"sonar_live.json write failed: {exc}")
                    if dist is not None and dist < PROX_THRESH:
                        if prox_near_since is None:
                            prox_near_since = now
                        elif now - prox_near_since >= PROX_HOLD_S:
                            try:
                                _fp = json.loads(FRIGATE_FILE.read_text())
                                _fp_ts = _fp.get("ts") if isinstance(_fp, dict) else None
                                if _fp_ts:
                                    _age = (dt.datetime.now(dt.timezone.utc) - dt.datetime.fromisoformat(_fp_ts)).total_seconds()
                                    if _age > FRIGATE_STALE_S:
                                        _fp = None
                            except (FileNotFoundError, json.JSONDecodeError, OSError, ValueError):
                                _fp = None
                            target_pan = _pan_from_frigate(_fp)
                            log(f"proximity react: {dist:.1f}cm — facing pan={target_pan}")
                            ease(get_px(), cur_pan, cur_tilt, target_pan, 5, 0.5)
                            cur_pan, cur_tilt = target_pan, 5
                            prox_near_since = None
                            next_gaze = now + random.uniform(cur_mood_behavior.get("gaze_min", GAZE_MIN_S), cur_mood_behavior.get("gaze_max", GAZE_MAX_S))
                            # SPARK greeting — speak only when SPARK persona active + cooldown ok
                            if (read_session_persona() == "spark"
                                    and now - spark_last_greet >= SPARK_GREET_COOLDOWN_S):
                                spark_greet(args.dry_run)
                                spark_last_greet = now
                    else:
                        prox_near_since = None

                # --- Face tracking (overrides gaze drift when a face is detected) ---
                face_tracked = False
                if face_active:
                    face = get_face()
                    if face is not None:
                        fx, fy = face
                        face_last_seen = now

                        # Error from center (pixels)
                        err_x = fx - FACE_FRAME_W // 2
                        err_y = fy - FACE_FRAME_H // 2

                        if abs(err_x) > FACE_DEADZONE or abs(err_y) > FACE_DEADZONE:
                            # Proportional adjustment (invert x: face left of frame → pan right)
                            new_pan = cur_pan - int(err_x * FACE_TRACK_GAIN_PAN)
                            new_tilt = cur_tilt - int(err_y * FACE_TRACK_GAIN_TILT)
                            new_pan = max(PAN_RANGE[0], min(PAN_RANGE[1], new_pan))
                            new_tilt = max(TILT_RANGE[0], min(TILT_RANGE[1], new_tilt))

                            if new_pan != cur_pan or new_tilt != cur_tilt:
                                p = get_px()
                                p.set_cam_pan_angle(new_pan)
                                p.set_cam_tilt_angle(new_tilt)
                                cur_pan, cur_tilt = new_pan, new_tilt

                        face_tracked = True
                        # Defer gaze/scan while tracking a face
                        next_gaze = now + random.uniform(cur_mood_behavior.get("gaze_min", GAZE_MIN_S), cur_mood_behavior.get("gaze_max", GAZE_MAX_S))
                        next_scan = now + random.uniform(SCAN_MIN_S, SCAN_MAX_S)

                    elif face_last_seen > 0 and (now - face_last_seen) < FACE_LOST_TIMEOUT:
                        # Recently lost face — hold position, don't drift yet
                        face_tracked = True

                # --- Slow idle scan (physical sweep only — proactive speech is handled by px-mind) ---
                if not face_tracked and now >= next_scan:
                    log("idle scan: sweeping pan")
                    angles = list(range(PAN_RANGE[0], PAN_RANGE[1] + 1, 15)) + \
                             list(range(PAN_RANGE[1], PAN_RANGE[0] - 1, -15))
                    p = get_px()
                    for a in angles:
                        if _yield_requested:
                            break
                        ease(p, cur_pan, cur_tilt, a, cur_tilt, 0.6)
                        cur_pan = a
                        time.sleep(0.2)
                    ease(p, cur_pan, cur_tilt, 0, 0, 0.8)
                    cur_pan, cur_tilt = 0, 0
                    log("idle scan: sweep complete")
                    next_scan = now + random.uniform(SCAN_MIN_S, SCAN_MAX_S)
                    next_gaze = now + random.uniform(cur_mood_behavior.get("gaze_min", GAZE_MIN_S), cur_mood_behavior.get("gaze_max", GAZE_MAX_S))

                # --- Gaze drift (only when not tracking a face) ---
                elif not face_tracked and now >= next_gaze:
                    target_pan  = random.randint(*PAN_RANGE)
                    # Apply mood tilt bias (positive = head up/alert, negative = drooping)
                    tilt_bias = cur_mood_behavior.get("tilt_bias", 0)
                    tilt_lo = max(TILT_RANGE[0], TILT_RANGE[0] + tilt_bias)
                    tilt_hi = min(TILT_RANGE[1], TILT_RANGE[1] + tilt_bias)
                    if tilt_lo > tilt_hi:
                        tilt_lo, tilt_hi = tilt_hi, tilt_lo  # guard against inverted range
                    target_tilt = random.randint(tilt_lo, tilt_hi)
                    duration    = random.uniform(0.8, 2.2)
                    log(f"gaze drift: ({cur_pan},{cur_tilt}) → ({target_pan},{target_tilt}) over {duration:.1f}s")
                    ease(get_px(), cur_pan, cur_tilt, target_pan, target_tilt, duration)
                    cur_pan, cur_tilt = target_pan, target_tilt
                    gaze_min = cur_mood_behavior.get("gaze_min", GAZE_MIN_S)
                    gaze_max = cur_mood_behavior.get("gaze_max", GAZE_MAX_S)
                    next_gaze = now + random.uniform(gaze_min, gaze_max)

            except OSError as exc:
                log(f"I2C error (will retry in {I2C_BACKOFF_S}s): {exc}")
                drop_px()  # release broken handle so get_px() recreates it
                i2c_ok_after = time.monotonic() + I2C_BACKOFF_S
                next_gaze = i2c_ok_after + random.uniform(cur_mood_behavior.get("gaze_min", GAZE_MIN_S), cur_mood_behavior.get("gaze_max", GAZE_MAX_S))
                next_scan = i2c_ok_after + random.uniform(SCAN_MIN_S, SCAN_MAX_S)
                next_prox = i2c_ok_after + PROX_CHECK_S

            time.sleep(0.5)
    finally:
        drop_px()
        if face_active:
            stop_face_detection()


def main(argv) -> int:
    global GAZE_MIN_S, GAZE_MAX_S, PROX_THRESH
    parser = argparse.ArgumentParser(description="PiCar-X idle alive daemon")
    parser.add_argument("--gaze-min",   type=float, default=GAZE_MIN_S,
                        help="Min seconds between gaze shifts")
    parser.add_argument("--gaze-max",   type=float, default=GAZE_MAX_S,
                        help="Max seconds between gaze shifts")
    parser.add_argument("--prox-cm",    type=float, default=PROX_THRESH,
                        help="Proximity threshold in cm to trigger reaction")
    parser.add_argument("--no-prox",    action="store_true",
                        help="Disable proximity sensing")
    parser.add_argument("--no-face",    action="store_true",
                        help="Disable camera face tracking")
    parser.add_argument("--dry-run",    action="store_true",
                        help="Log planned actions without moving servos")
    args = parser.parse_args(argv)

    GAZE_MIN_S  = args.gaze_min
    GAZE_MAX_S  = args.gaze_max
    PROX_THRESH = args.prox_cm if not args.no_prox else 0.0

    # Write PID — guarded: if another live px-alive already owns the file, exit
    # cleanly so we don't clobber its PID (race condition on rapid restarts).
    PID_FILE.parent.mkdir(parents=True, exist_ok=True)
    _existing_pid = None
    try:
        _existing_pid = int(PID_FILE.read_text().strip())
    except (FileNotFoundError, ValueError, OSError):
        pass  # expected on first run or corrupt PID file
    if _existing_pid and _existing_pid != os.getpid() and os.path.isdir(f"/proc/{_existing_pid}"):
        log(f"another px-alive (pid={_existing_pid}) already running — exiting")
        return 0
    PID_FILE.write_text(str(os.getpid()))

    # Check if exploration is active — exit cleanly to avoid GPIO contention
    exploring_file = STATE_DIR / "exploring.json"
    try:
        if exploring_file.exists():
            exploring = json.loads(exploring_file.read_text(encoding="utf-8"))
            if exploring.get("active"):
                exp_pid = exploring.get("pid")
                if exp_pid and Path(f"/proc/{exp_pid}").is_dir():
                    log("exploration active (PID %d) — exiting cleanly" % exp_pid)
                    sys.exit(0)
    except (FileNotFoundError, json.JSONDecodeError, OSError, ValueError):
        pass  # expected on missing/corrupt exploring.json

    def _safe_unlink_pid() -> None:
        """Only delete the PID file if it still contains our own PID."""
        try:
            if int(PID_FILE.read_text().strip()) == os.getpid():
                PID_FILE.unlink(missing_ok=True)
        except (FileNotFoundError, ValueError, OSError):
            pass  # expected during cleanup

    log(f"starting pid={os.getpid()} dry={args.dry_run}")

    # Signal handler for clean shutdown
    def _shutdown(sig, _frame):
        log(f"received signal {sig} — shutting down")
        _safe_unlink_pid()
        stop_face_detection()  # release camera before process exit
        sys.exit(0)  # finally block in idle_loop handles drop_px

    signal.signal(signal.SIGTERM, _shutdown)
    signal.signal(signal.SIGINT,  _shutdown)

    if args.dry_run:
        log("dry-run: would start idle loop (servo movements skipped)")
        for i in range(3):
            target_pan  = random.randint(*PAN_RANGE)
            target_tilt = random.randint(*TILT_RANGE)
            log(f"dry gaze {i+1}: pan={target_pan} tilt={target_tilt}")
            time.sleep(0.3)
        log("dry-run: simulating idle scan sweep")
        _safe_unlink_pid()
        return 0

    # Verify picarx is importable before entering the loop
    try:
        from picarx import Picarx as _  # noqa: F401
    except Exception as exc:
        log(f"import error: {exc}")
        return 1

    try:
        idle_loop(args)
    except SystemExit:
        pass
    except Exception as exc:
        log(f"fatal: {exc}")
        return 1
    finally:
        if not args.no_face:
            stop_face_detection()
        _safe_unlink_pid()
        log("stopped")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
