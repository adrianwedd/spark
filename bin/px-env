#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

export PROJECT_ROOT
export LOG_DIR="${LOG_DIR:-$PROJECT_ROOT/logs}"

normalize_path_list() {
    local path_list=":$1:"
    local addition=":$2:"
    [[ "$path_list" == *"$addition"* ]]
}

append_path() {
    local current="${1:-}"
    local addition="$2"
    if normalize_path_list "$current" "$addition"; then
        printf "%s" "$current"
    else
        if [[ -z "$current" ]]; then
            printf "%s" "$addition"
        else
            printf "%s:%s" "$addition" "$current"
        fi
    fi
}

PYTHONPATH="$(append_path "${PYTHONPATH:-}" "$PROJECT_ROOT/src")"
PYTHONPATH="$(append_path "$PYTHONPATH" "/home/pi/picar-x")"
export PYTHONPATH

if [[ -d "$PROJECT_ROOT/.venv" && -z "${VIRTUAL_ENV:-}" ]]; then
    # shellcheck disable=SC1091
    source "$PROJECT_ROOT/.venv/bin/activate"
fi

# Acquire the single secondary-hardware lease and pause px-alive in-process.
# The lease stays open in the calling shell and its child until shell exit.
resume_alive() {
    if [[ "${PX_GPIO_LEASE_ACTIVE:-0}" != "1" ]]; then
        return
    fi
    local pid_file="$LOG_DIR/px-alive.pid"
    if [[ -f "$pid_file" ]]; then
        local pid
        pid=$(<"$pid_file")
        if [[ -d "/proc/$pid" ]]; then
            kill -USR2 "$pid" 2>/dev/null || sudo -n kill -USR2 "$pid" 2>/dev/null || true
        fi
    fi
    if [[ -n "${PX_GPIO_LOCK_FD:-}" ]]; then
        flock -u "$PX_GPIO_LOCK_FD" 2>/dev/null || true
        eval "exec ${PX_GPIO_LOCK_FD}>&-"
        unset PX_GPIO_LOCK_FD
    fi
    PX_GPIO_LEASE_ACTIVE=0
    export PX_GPIO_LEASE_ACTIVE
}

yield_alive() {
    local arg
    for arg in "$@"; do
        if [[ "$arg" == "--dry-run" ]]; then
            return
        fi
    done
    if [[ "${PX_DRY:-0}" == "1" || "${PX_GPIO_LEASE_ACTIVE:-0}" == "1" ]]; then
        return
    fi
    local lock_file="$LOG_DIR/gpio-owner.lock"
    mkdir -p "$LOG_DIR"
    exec {PX_GPIO_LOCK_FD}>"$lock_file"
    if ! flock -w "${PX_GPIO_LOCK_TIMEOUT:-20}" "$PX_GPIO_LOCK_FD"; then
        echo "GPIO lease timeout: another hardware tool is still running" >&2
        return 1
    fi
    export PX_GPIO_LOCK_FD
    PX_GPIO_LEASE_ACTIVE=1
    export PX_GPIO_LEASE_ACTIVE
    trap resume_alive EXIT

    local pid_file="$LOG_DIR/px-alive.pid"
    local paused_file="$LOG_DIR/px-alive.paused"
    if [[ -f "$pid_file" ]]; then
        local pid
        pid=$(<"$pid_file")
        if [[ -d "/proc/$pid" ]]; then
            if ! kill -USR1 "$pid" 2>/dev/null && ! sudo -n kill -USR1 "$pid" 2>/dev/null; then
                echo "Unable to pause px-alive PID $pid" >&2
                resume_alive
                return 1
            fi
            local i
            for i in $(seq 50); do
                if [[ -f "$paused_file" ]] && [[ "$(<"$paused_file")" == "$pid" ]]; then
                    return
                fi
                if [[ ! -d "/proc/$pid" ]]; then
                    return
                fi
                sleep 0.2
            done
            echo "Timed out waiting for px-alive PID $pid to pause" >&2
            resume_alive
            return 1
        fi
    fi
}

mkdir -p "$LOG_DIR"

# Default audio output: HifiBerry DAC via robot_hat ALSA plug device.
# Override with e.g. PX_VOICE_DEVICE=plughw:1,0 for direct HW access.
export PX_VOICE_DEVICE="${PX_VOICE_DEVICE:-robothat}"

# PulseAudio socket lives at /run/user/1000/pulse — systemd services run as
# User=pi but don't inherit XDG_RUNTIME_DIR, so aplay -D pulse can't find it.
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/1000}"
