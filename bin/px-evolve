#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

# Load .env for GH token, API keys, etc.
if [ -f "$PROJECT_ROOT/.env" ]; then
    # shellcheck disable=SC1091
    set -a; source "$PROJECT_ROOT/.env"; set +a
fi

# Uses venv python — no GPIO needed.
exec python - "$@" <<'PY'
"""SPARK self-evolution daemon: polls evolve queue, creates PRs via Claude Opus.

For each pending entry in state/evolve_queue.jsonl:
1. Creates a git worktree on a new branch
2. Runs Claude Opus with a scoped prompt and file whitelist
3. Validates changes (max files, test pass)
4. Creates a GitHub PR
5. Cleans up worktree

Run with: bin/px-evolve [--dry-run] [--once]
"""
from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import re
import signal
import subprocess
import sys
import tempfile
import threading
import time
from pathlib import Path


PROJECT_ROOT = Path(os.environ.get("PROJECT_ROOT", Path(__file__).parent.parent))
LOG_DIR = Path(os.environ.get("LOG_DIR", PROJECT_ROOT / "logs"))
STATE_DIR = Path(os.environ.get("PX_STATE_DIR", PROJECT_ROOT / "state"))

EVOLVE_TIMEOUT = int(os.environ.get("PX_EVOLVE_TIMEOUT", "1800"))
EVOLVE_MAX_FILES = int(os.environ.get("PX_EVOLVE_MAX_FILES", "3"))

# Per-phase model overrides — defaults follow the plan/implement/test/qa pattern
PLAN_MODEL      = os.environ.get("PX_EVOLVE_PLAN_MODEL",      "claude-opus-4-6")
IMPLEMENT_MODEL = os.environ.get("PX_EVOLVE_IMPLEMENT_MODEL", "claude-sonnet-4-6")
TEST_MODEL      = os.environ.get("PX_EVOLVE_TEST_MODEL",      "claude-haiku-4-5-20251001")
QA_MODEL        = os.environ.get("PX_EVOLVE_QA_MODEL",        "claude-sonnet-4-6")
POLL_INTERVAL = 60

QUEUE_FILE = STATE_DIR / "evolve_queue.jsonl"
EVOLVE_LOG = STATE_DIR / "evolve_log.jsonl"

try:
    from filelock import FileLock as _FileLock
    _QUEUE_LOCK = _FileLock(str(QUEUE_FILE) + ".lock", timeout=5)
except ImportError:
    import sys as _sys
    print(
        "CRITICAL: filelock not installed — evolve queue has NO concurrency protection",
        file=_sys.stderr,
    )
    _FileLock = None  # type: ignore[assignment,misc]
    _QUEUE_LOCK = None


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

def log(msg: str) -> None:
    ts = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    line = f"[{ts}] px-evolve: {msg}"
    print(line, flush=True)
    try:
        LOG_DIR.mkdir(parents=True, exist_ok=True)
        with open(LOG_DIR / "px-evolve.log", "a") as f:
            f.write(line + "\n")
    except OSError:
        pass


# ---------------------------------------------------------------------------
# Atomic file helpers
# ---------------------------------------------------------------------------

def atomic_write(path: Path, content: str) -> None:
    """Write content atomically via mkstemp + fsync + os.replace."""
    fd, tmp = tempfile.mkstemp(dir=str(path.parent), suffix=".tmp")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(content)
            f.flush()
            os.fsync(f.fileno())
        os.replace(tmp, str(path))
    except BaseException:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


def load_queue() -> list[dict]:
    """Load all entries from the queue file."""
    import contextlib
    ctx = _QUEUE_LOCK if _QUEUE_LOCK is not None else contextlib.nullcontext()
    with ctx:
        if not QUEUE_FILE.exists():
            return []
        entries = []
        for line in QUEUE_FILE.read_text().strip().splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                entries.append(json.loads(line))
            except json.JSONDecodeError:
                log(f"skipping malformed queue line: {line[:80]}")
        return entries


def save_queue(entries: list[dict]) -> None:
    """Atomically write all queue entries back."""
    import contextlib
    content = "\n".join(json.dumps(e) for e in entries) + "\n" if entries else ""
    ctx = _QUEUE_LOCK if _QUEUE_LOCK is not None else contextlib.nullcontext()
    with ctx:
        atomic_write(QUEUE_FILE, content)


def append_evolve_log(record: dict) -> None:
    """Append a completion record to the evolve log."""
    import contextlib
    EVOLVE_LOG.parent.mkdir(parents=True, exist_ok=True)
    _lock = _FileLock(str(EVOLVE_LOG) + ".lock", timeout=5) if _FileLock is not None else None
    ctx = _lock if _lock is not None else contextlib.nullcontext()
    with ctx:
        with open(EVOLVE_LOG, "a") as f:
            f.write(json.dumps(record) + "\n")


# ---------------------------------------------------------------------------
# Core: process a single pending entry
# ---------------------------------------------------------------------------

def _whitelist_lines() -> tuple[str, str]:
    """Return (wl_lines, bl_lines) strings for prompt injection."""
    try:
        from pxh.claude_session import WHITELIST_PATTERNS, BLACKLIST_FILES, BLACKLIST_PATTERNS
        wl = "\n".join(f"- {p}" for p in WHITELIST_PATTERNS)
        bl = "\n".join(f"- {f}" for f in sorted(BLACKLIST_FILES))
        bl += "\n" + "\n".join(f"- {p}*" for p in BLACKLIST_PATTERNS)
    except ImportError:
        wl = "- src/pxh/spark_config.py\n- bin/tool-*\n- tests/"
        bl = "- src/pxh/api.py\n- bin/px-evolve\n- .env"
    return wl, bl


def _extract_json(text: str) -> dict | None:
    """Extract the last valid JSON object from Claude output text.

    Uses json.JSONDecoder.raw_decode so nested braces, braces inside
    string values, and multiple objects are all handled correctly.
    """
    decoder = json.JSONDecoder()
    idx = 0
    results: list[dict] = []
    while idx < len(text):
        idx = text.find("{", idx)
        if idx == -1:
            break
        try:
            obj, end = decoder.raw_decode(text, idx)
            if isinstance(obj, dict):
                results.append(obj)
            idx = end
        except json.JSONDecodeError:
            idx += 1
    return results[-1] if results else None


def build_plan_prompt(intent: str, introspection: dict) -> str:
    wl_lines, _ = _whitelist_lines()
    return f"""You are SPARK, planning a targeted change to your own code.

## Intent
{intent}

## Current state
{json.dumps(introspection, indent=2)}

## MANDATORY WORKFLOW:
Step 1: Read src/pxh/spark_config.py (and any other relevant whitelisted file) using the Read tool.
Step 2: Output ONLY this JSON — no other text before or after it:
{{"approach": "one sentence describing the implementation", "files": ["path/to/file"], "key_changes": ["change 1", "change 2"]}}

## File whitelist (ONLY these may be modified later)
{wl_lines}

Do NOT make any edits. Your only job right now is to plan.
"""


def build_implement_prompt(intent: str, plan: dict) -> str:
    wl_lines, bl_lines = _whitelist_lines()
    return f"""You are SPARK implementing a planned code change.

## Intent
{intent}

## Plan
{json.dumps(plan, indent=2)}

## MANDATORY WORKFLOW:
Step 1: Read each file listed in the plan using the Read tool.
Step 2: Implement every key change using Edit or Write tools.
Step 3: Stop. Do NOT summarize or narrate what you did.

## CRITICAL RULES:
- You MUST call Edit or Write to modify files — text descriptions do NOTHING.
- Do NOT use Bash. Do NOT run git commands.
- Max {EVOLVE_MAX_FILES} files changed.

## File whitelist (ONLY these may be modified)
{wl_lines}

## File blacklist (NEVER touch)
{bl_lines}

CRITICAL: Editing any file outside the whitelist will REJECT the entire evolution.
"""


def build_test_prompt(intent: str, diff: str, changed_files: list) -> str:
    diff_excerpt = diff[:3000] + ("…[truncated]" if len(diff) > 3000 else "")
    return f"""You are SPARK's test writer. A code change was just made — check if tests need updating.

## Intent
{intent}

## Changed files
{changed_files}

## Diff
{diff_excerpt}

## MANDATORY WORKFLOW:
Step 1: Read the changed files and their corresponding test files.
Step 2: If any new function or behaviour clearly has no test coverage, add a minimal test.
        Use existing patterns from tests/test_spark_config.py or tests/test_mind_utils.py.
Step 3: If coverage is already adequate, make NO changes.
Step 4: Stop. Do NOT summarize.

Only write NEW tests — do not modify or delete existing ones.
Only add tests in the tests/ directory.
"""


def build_qa_prompt(intent: str, diff: str) -> str:
    diff_excerpt = diff[:5000] + ("…[truncated]" if len(diff) > 5000 else "")
    return f"""You are SPARK's QA reviewer. Review this diff and decide if it should be merged.

## Intent
{intent}

## Diff
{diff_excerpt}

## Check for:
- Does the change implement the intent correctly?
- Any obvious bugs, off-by-one errors, or broken invariants?
- Style consistent with surrounding code?
- Any safety concerns (never touch .env, systemd, api.py, px-evolve)?

Output ONLY this JSON — no other text:
{{"status": "approved", "reason": "brief reason"}}
OR
{{"status": "rejected", "reason": "specific problem"}}

Be permissive — minor style issues are NOT grounds for rejection.
Only reject if the change is wrong, dangerous, or clearly broken.
"""


def process_entry(entry: dict, *, dry: bool = False) -> str:
    """Process a single pending queue entry. Returns final status string."""
    entry_id = entry["id"]
    intent = entry.get("intent", "")
    introspection = entry.get("introspection", {})

    safe_id = re.sub(r"[^a-zA-Z0-9_-]", "-", entry_id)[:64]
    branch = f"spark/evolve-{safe_id}"
    workdir = f"/tmp/spark-evolve-{safe_id}"

    log(f"[{entry_id}] starting: {intent[:80]}")

    # 1. Create git worktree
    try:
        subprocess.run(
            ["git", "worktree", "add", workdir, "-b", branch],
            cwd=str(PROJECT_ROOT), check=True,
            capture_output=True, text=True, timeout=30,
        )
    except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as exc:
        log(f"[{entry_id}] worktree creation failed: {exc}")
        return "failed:worktree"

    try:
        return _run_in_worktree(entry_id, intent, introspection, branch, workdir, dry=dry)
    finally:
        # 8. Cleanup worktree
        _cleanup_worktree(workdir, entry_id)


def _run_in_worktree(
    entry_id: str, intent: str, introspection: dict,
    branch: str, workdir: str, *, dry: bool,
) -> str:
    """4-phase evolution: plan (Opus) → implement (Sonnet) → test (Haiku) → QA (Sonnet)."""
    if dry:
        log(f"[{entry_id}] DRY RUN — skipping Claude execution")
        return "failed:no_changes"

    try:
        from pxh.claude_session import run_claude_session, SessionBudgetExhausted, file_in_whitelist
    except ImportError:
        log(f"[{entry_id}] claude_session not importable, using direct subprocess")
        return _run_claude_direct(entry_id, intent, build_implement_prompt(intent, {}), workdir)

    # ── Phase 1: Plan (Opus, budget-checked, read-only) ──────────────────────
    log(f"[{entry_id}] phase 1/4: planning with {PLAN_MODEL}")
    try:
        plan_result = run_claude_session(
            session_type="evolve",
            prompt=build_plan_prompt(intent, introspection),
            timeout=120,
            allowed_tools="Read,Glob,Grep",
            skip_permissions=True,
            cwd=workdir,
            model_override=PLAN_MODEL,
        )
    except SessionBudgetExhausted as exc:
        log(f"[{entry_id}] budget exhausted: {exc}")
        return "failed:budget"
    except subprocess.TimeoutExpired:
        log(f"[{entry_id}] phase 1 timed out")
        return "failed:timeout"

    if plan_result.returncode != 0:
        log(f"[{entry_id}] phase 1 exit={plan_result.returncode}, stderr: {plan_result.stderr[:300]}")
        return "failed:plan_error"

    plan = _extract_json(plan_result.stdout) or {}
    log(f"[{entry_id}] plan: {json.dumps(plan)[:300]}")

    # ── Phase 2: Implement (Sonnet, no budget check) ──────────────────────────
    log(f"[{entry_id}] phase 2/4: implementing with {IMPLEMENT_MODEL}")
    impl_timeout = max(300, EVOLVE_TIMEOUT - 300)
    try:
        impl_result = run_claude_session(
            session_type="evolve",
            prompt=build_implement_prompt(intent, plan),
            timeout=impl_timeout,
            allowed_tools="Read,Write,Edit,Glob,Grep",
            skip_permissions=True,
            cwd=workdir,
            model_override=IMPLEMENT_MODEL,
            skip_budget_check=True,
        )
    except subprocess.TimeoutExpired:
        log(f"[{entry_id}] phase 2 timed out after {impl_timeout}s")
        return "failed:timeout"

    if impl_result.returncode != 0:
        log(f"[{entry_id}] phase 2 exit={impl_result.returncode}, stderr: {impl_result.stderr[:300]}")
        return "failed:impl_error"

    # ── Check phase 2 produced changes ───────────────────────────────────────
    status_result = subprocess.run(
        ["git", "status", "--porcelain"],
        cwd=workdir, capture_output=True, text=True, timeout=10,
    )
    if not status_result.stdout.strip():
        log(f"[{entry_id}] implement phase made no changes — skipping")
        return "failed:no_changes"

    raw_diff = subprocess.run(
        ["git", "diff"], cwd=workdir, capture_output=True, text=True, timeout=10,
    ).stdout
    changed_so_far = [
        line[3:].strip()
        for line in status_result.stdout.strip().splitlines()
        if line.strip()
    ]

    # ── Phase 3: Test (Haiku) ─────────────────────────────────────────────────
    log(f"[{entry_id}] phase 3/4: writing tests with {TEST_MODEL}")
    try:
        run_claude_session(
            session_type="evolve",
            prompt=build_test_prompt(intent, raw_diff, changed_so_far),
            timeout=120,
            allowed_tools="Read,Write,Edit,Glob,Grep",
            skip_permissions=True,
            cwd=workdir,
            model_override=TEST_MODEL,
            skip_budget_check=True,
        )
    except subprocess.TimeoutExpired:
        log(f"[{entry_id}] phase 3 timed out — continuing without new tests")

    full_diff = subprocess.run(
        ["git", "diff"], cwd=workdir, capture_output=True, text=True, timeout=10,
    ).stdout

    # ── Phase 4: QA (Sonnet, diff review) ────────────────────────────────────
    log(f"[{entry_id}] phase 4/4: QA review with {QA_MODEL}")
    try:
        qa_result = run_claude_session(
            session_type="evolve",
            prompt=build_qa_prompt(intent, full_diff),
            timeout=90,
            allowed_tools="",
            skip_permissions=True,
            cwd=workdir,
            model_override=QA_MODEL,
            skip_budget_check=True,
        )
        qa = _extract_json(qa_result.stdout) or {}
        if qa.get("status") == "rejected":
            log(f"[{entry_id}] QA rejected: {qa.get('reason', '?')}")
            return "failed:qa_rejected"
        log(f"[{entry_id}] QA approved: {qa.get('reason', 'ok')}")
    except subprocess.TimeoutExpired:
        log(f"[{entry_id}] phase 4 timed out — proceeding without QA")

    # ── Pre-commit validation ─────────────────────────────────────────────────
    status_result = subprocess.run(
        ["git", "status", "--porcelain"],
        cwd=workdir, capture_output=True, text=True, timeout=10,
    )
    status_out = status_result.stdout.strip()

    if not status_out:
        log(f"[{entry_id}] no changes after all phases — skipping")
        return "failed:no_changes"

    conflict_markers = {"UU ", "AA ", "DD "}
    if any(line[:3] in conflict_markers for line in status_out.splitlines()):
        log(f"[{entry_id}] merge conflict detected in worktree — marking failed")
        return "failed:merge_conflict"

    # Stage and commit
    subprocess.run(
        ["git", "add", "-A"],
        cwd=workdir, capture_output=True, text=True, timeout=10,
    )

    commit_msg = f"[SPARK] {intent[:60]}"
    commit_result = subprocess.run(
        ["git", "commit", "-m", commit_msg],
        cwd=workdir, capture_output=True, text=True, timeout=10,
    )
    if commit_result.returncode != 0:
        log(f"[{entry_id}] git commit failed: {commit_result.stderr[:300]}")
        return "failed:git_commit"

    # 4. Check for changes against master (not HEAD — we just committed)
    diff_result = subprocess.run(
        ["git", "diff", "--name-only", "master...HEAD"],
        cwd=workdir, capture_output=True, text=True,
    )
    changed_files = [f for f in diff_result.stdout.strip().splitlines() if f]

    if not changed_files:
        log(f"[{entry_id}] no changes produced")
        return "failed:no_changes"

    log(f"[{entry_id}] changed files ({len(changed_files)}): {changed_files}")

    # 5. Whitelist enforcement — hard gate (Claude may ignore prompt constraints)
    for f in changed_files:
        if not file_in_whitelist(f):
            log(f"[{entry_id}] whitelist violation: {f}")
            return "failed:whitelist_violation"
        # bin/tool-* is whitelisted for NEW tools only; reject if file already exists on master.
        # Reject on non-zero returncode too (fail-safe: git error → block rather than allow).
        if f.startswith("bin/tool-"):
            ls = subprocess.run(
                ["git", "ls-tree", "master", "--", f],
                cwd=workdir, capture_output=True, text=True,
            )
            if ls.returncode != 0 or ls.stdout.strip():
                log(f"[{entry_id}] whitelist violation: existing tool modified (or ls-tree error): {f}")
                return "failed:whitelist_violation"

    # 6. Enforce max files
    if len(changed_files) > EVOLVE_MAX_FILES:
        log(f"[{entry_id}] too many files: {len(changed_files)} > {EVOLVE_MAX_FILES}")
        return "failed:too_many_files"

    # 7. Run tests (skip live hardware tests)
    try:
        test_result = subprocess.run(
            [sys.executable, "-m", "pytest", "tests/", "-x", "-q",
             "--ignore=tests/test_tools_live.py"],
            cwd=workdir, capture_output=True, text=True, timeout=300,
        )
        if test_result.returncode != 0:
            log(f"[{entry_id}] tests failed:\n{test_result.stdout[-500:]}\n{test_result.stderr[-500:]}")
            return "failed:tests"
        log(f"[{entry_id}] tests passed")
    except subprocess.TimeoutExpired:
        log(f"[{entry_id}] test suite timed out")
        return "failed:tests"

    # 8. Create PR
    intent_summary = intent[:60].replace('"', "'")
    body = (
        f"## Summary\n"
        f"SPARK self-evolution: {intent}\n\n"
        f"## Changed files\n"
        + "\n".join(f"- `{f}`" for f in changed_files)
        + "\n\n---\n*Proposed autonomously by SPARK via px-evolve.*"
    )

    try:
        subprocess.run(
            ["git", "push", "-u", "origin", branch],
            cwd=workdir, check=True, capture_output=True, text=True, timeout=60,
        )
    except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as exc:
        log(f"[{entry_id}] git push failed: {exc}")
        return "failed:pr_create"

    try:
        # Try with label first, fall back without if label doesn't exist
        pr_cmd = ["gh", "pr", "create",
                   "--title", f"[SPARK] {intent_summary}",
                   "--body", body]
        pr_result = subprocess.run(
            pr_cmd + ["--label", "spark-evolve"],
            cwd=workdir, capture_output=True, text=True, timeout=60,
        )
        if pr_result.returncode != 0:
            # Retry without label (label may not exist)
            log(f"[{entry_id}] PR with label failed (stderr: {pr_result.stderr.strip()[:200]}), retrying without label")
            pr_result = subprocess.run(
                pr_cmd, cwd=workdir,
                capture_output=True, text=True, timeout=60,
            )
        if pr_result.returncode != 0:
            log(f"[{entry_id}] PR creation failed: {pr_result.stderr.strip()[:300]}")
            return "failed:pr_create"
        pr_url = pr_result.stdout.strip()
        log(f"[{entry_id}] PR created: {pr_url}")
    except subprocess.TimeoutExpired as exc:
        log(f"[{entry_id}] PR creation timed out: {exc}")
        return "failed:pr_create"

    return f"pr_created|{pr_url}|{','.join(changed_files)}"


def _run_claude_direct(entry_id: str, intent: str, prompt: str, workdir: str) -> str:
    """Disabled: running without the session manager skips whitelist, diff, tests, and PR gate."""
    log(f"[{entry_id}] REFUSING direct Claude execution — pxh.claude_session unavailable; "
        "whitelist enforcement, test gate, and PR creation would all be bypassed. "
        "Fix the pxh package installation to restore evolution.")
    return "failed:no_session_manager"


def _cleanup_worktree(workdir: str, entry_id: str) -> None:
    """Remove git worktree, best effort."""
    try:
        subprocess.run(
            ["git", "worktree", "remove", workdir, "--force"],
            cwd=str(PROJECT_ROOT), capture_output=True, text=True, timeout=30,
        )
        log(f"[{entry_id}] worktree cleaned up")
    except (subprocess.CalledProcessError, subprocess.TimeoutExpired, OSError) as exc:
        log(f"[{entry_id}] worktree cleanup failed (non-fatal): {exc}")


# ---------------------------------------------------------------------------
# Queue targeted update (preserves entries appended after our last load_queue)
# ---------------------------------------------------------------------------

def _update_entry_in_queue(entry_id: str, **fields) -> None:
    """Reload queue from disk under lock, update matching entry by id, write back.

    Using load_queue/save_queue here would lose entries appended by tool-evolve
    between our original load and this save, because save_queue overwrites the
    whole file. Instead we reload fresh, update in-place, and write directly.
    """
    import contextlib
    ctx = _QUEUE_LOCK if _QUEUE_LOCK is not None else contextlib.nullcontext()
    with ctx:
        if not QUEUE_FILE.exists():
            return
        entries = []
        for line in QUEUE_FILE.read_text().strip().splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                entries.append(json.loads(line))
            except json.JSONDecodeError:
                pass
        for e in entries:
            if e["id"] == entry_id:
                e.update(fields)
                break
        content = "\n".join(json.dumps(e) for e in entries) + "\n" if entries else ""
        atomic_write(QUEUE_FILE, content)


# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------

def run_once(*, dry: bool) -> int:
    """Process all pending entries. Returns count processed."""
    entries = load_queue()
    if not entries:
        return 0

    processed = 0
    for entry in entries:
        if entry.get("status") != "pending":
            continue
        if entry.get("dry"):
            _update_entry_in_queue(entry["id"], status="skipped:dry")
            continue

        raw_status = process_entry(entry, dry=dry)
        ts_now = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

        # Parse enriched status: "pr_created|url|files" or plain "failed:reason"
        pr_url = None
        files_changed = []
        if raw_status.startswith("pr_created|"):
            parts = raw_status.split("|", 2)
            status = "pr_created"
            pr_url = parts[1] if len(parts) > 1 else None
            files_changed = parts[2].split(",") if len(parts) > 2 and parts[2] else []
        else:
            status = raw_status

        processed += 1

        # Targeted update: reload queue from disk, update this entry by id.
        # save_queue(entries) would overwrite entries appended by tool-evolve
        # during the ~30min Claude subprocess (issue #M2).
        _update_entry_in_queue(entry["id"], status=status, ts_completed=ts_now)

        # Append to evolve log with numeric ts for rate limiting
        log_entry = {
            "ts": time.time(),
            "id": entry["id"],
            "intent": entry.get("intent", ""),
            "status": status,
            "ts_completed": ts_now,
        }
        if pr_url:
            log_entry["pr_url"] = pr_url
        if files_changed:
            log_entry["files_changed"] = files_changed
        append_evolve_log(log_entry)

        log(f"[{entry['id']}] completed: {status}")

    return processed


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="SPARK self-evolution daemon")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--once", action="store_true", help="Process queue once and exit")
    parser.add_argument("--poll-interval", type=int, default=POLL_INTERVAL)
    args = parser.parse_args(argv)

    dry = args.dry_run or os.environ.get("PX_EVOLVE_DRY", "0") != "0"

    # Single-instance guard (PID file).
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    pid_file = STATE_DIR / "px-evolve.pid"
    my_pid = os.getpid()
    try:
        if pid_file.exists():
            old_pid = int(pid_file.read_text().strip())
            if old_pid != my_pid and Path(f"/proc/{old_pid}").exists():
                try:
                    cmdline = Path(f"/proc/{old_pid}/cmdline").read_bytes().decode(errors="replace")
                except OSError:
                    cmdline = ""
                if "px-evolve" in cmdline:
                    log(f"another px-evolve instance is running (pid={old_pid})")
                    return 1
                else:
                    log(f"pid {old_pid} alive but not px-evolve (recycled PID) — taking over")
                    pid_file.unlink(missing_ok=True)
            else:
                log(f"stale pid file removed (pid={old_pid})")
                pid_file.unlink(missing_ok=True)
    except (ValueError, OSError) as exc:
        log(f"pid file check failed, removing: {exc}")
        pid_file.unlink(missing_ok=True)
    pid_file.write_text(str(my_pid))

    def _safe_unlink_pid():
        """Delete PID file only if it still contains our PID."""
        try:
            if pid_file.exists() and int(pid_file.read_text().strip()) == my_pid:
                pid_file.unlink(missing_ok=True)
        except (ValueError, OSError):
            pass

    log(f"starting pid={my_pid} dry={dry} once={args.once}")

    if args.once:
        count = run_once(dry=dry)
        log(f"processed {count} entries")
        _safe_unlink_pid()
        return 0

    # SIGTERM handler
    _shutdown = threading.Event()

    def _on_signal(s, f):
        _shutdown.set()

    signal.signal(signal.SIGTERM, _on_signal)
    signal.signal(signal.SIGINT, _on_signal)

    try:
        while not _shutdown.is_set():
            try:
                count = run_once(dry=dry)
                if count:
                    log(f"poll: processed {count} entries")
            except Exception as exc:
                log(f"poll: CRASHED: {exc}")

            _shutdown.wait(timeout=args.poll_interval)
    finally:
        _safe_unlink_pid()
        log("shutting down")

    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
PY
