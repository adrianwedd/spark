#!/usr/bin/env bash
# Legacy cron compatibility shim.
#
# Feed data is runtime state served by /api/v1/public/feed. Committing it from
# cron polluted branch history and hid push failures, so this helper must never
# write to Git. It remains executable until installed crontabs are removed.
set -euo pipefail

printf '%s\n' \
  '{"status":"disabled","reason":"feed is served by the live API; remove the px-feed-snapshot cron entry"}'
