#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

python3 - "$@" <<'PY'
from __future__ import annotations

import argparse
import json
import os
import signal
import subprocess
import sys
import tempfile
import time
from pathlib import Path

from pxh.logging import log_event

STOP_REQUESTED = False
LOG_DIR = Path(os.environ.get("LOG_DIR", Path(os.environ.get("PROJECT_ROOT", ".")) / "logs"))
PID_FILE = LOG_DIR / "px-frigate-stream.pid"
PROJECT_ROOT = Path(os.environ.get("PROJECT_ROOT", "."))
GO2RTC_BIN = PROJECT_ROOT / "bin" / "go2rtc"


def handle_sigint(signum, frame):
    global STOP_REQUESTED
    STOP_REQUESTED = True


def build_go2rtc_config(args) -> dict:
    """go2rtc config that runs rpicam-vid as a local RTSP source.

    Frigate (on pi5-hailo) pulls from rtsp://192.168.0.236:{port}/{stream}.
    The exec: source starts rpicam-vid on demand when a consumer connects.
    """
    rpicam_cmd = (
        f"rpicam-vid --codec h264 --profile baseline --inline"
        f" --timeout 0 --framerate {args.fps}"
        f" --width {args.width} --height {args.height}"
        f" --output -"
    )
    return {
        "api": {"listen": f":{args.api_port}"},
        "rtsp": {"listen": f":{args.port}"},
        "streams": {args.stream: [f"exec:{rpicam_cmd}"]},
    }


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Serve PiCar-X camera as RTSP stream via local go2rtc"
    )
    parser.add_argument("--port", type=int, default=8554, help="RTSP listen port")
    parser.add_argument("--api-port", type=int, default=18554, help="go2rtc API port")
    parser.add_argument("--stream", default="picar-x", help="Stream name")
    parser.add_argument("--fps", type=int, default=15)
    parser.add_argument("--width", type=int, default=1280)
    parser.add_argument("--height", type=int, default=720)
    parser.add_argument("--duration", type=float, default=0, help="Stop after N seconds (0 = forever)")
    parser.add_argument("--host", default="picar.local", help="Hostname for the served RTSP URL")
    parser.add_argument("--dry-run", action="store_true", help="Print config without executing")

    args = parser.parse_args()

    serve_url = f"rtsp://{args.host}:{args.port}/{args.stream}"
    config = build_go2rtc_config(args)

    camera_cmd = [
        "rpicam-vid", "--codec", "h264", "--profile", "baseline", "--inline",
        "--timeout", "0", "--framerate", str(args.fps),
        "--width", str(args.width), "--height", str(args.height), "--output", "-",
    ]
    ffmpeg_cmd = [
        "ffmpeg", "-use_wallclock_as_timestamps", "1", "-i", "pipe:0",
        "-c:v", "copy", "-f", "rtsp", "-rtsp_transport", "tcp", "-muxdelay", "0.1",
        f"rtsp://127.0.0.1:{args.port}/{args.stream}",
    ]

    if args.dry_run or os.environ.get("PX_DRY", "0") == "1":
        payload = {
            "status": "dry-run",
            "serve_url": serve_url,
            "go2rtc_bin": str(GO2RTC_BIN),
            "go2rtc_config": config,
            "commands": {"camera": camera_cmd, "ffmpeg": ffmpeg_cmd},
        }
        log_event("frigate-stream", payload)
        print(json.dumps(payload, indent=2))
        return 0

    if not GO2RTC_BIN.exists():
        print(f"go2rtc binary not found: {GO2RTC_BIN}", file=sys.stderr)
        print("Download arm64 binary from https://github.com/AlexxIT/go2rtc/releases", file=sys.stderr)
        return 1

    signal.signal(signal.SIGINT, handle_sigint)
    signal.signal(signal.SIGTERM, handle_sigint)

    # Write PID file so tool-photograph/tool-describe-scene know camera is busy
    PID_FILE.parent.mkdir(parents=True, exist_ok=True)
    PID_FILE.write_text(str(os.getpid()))

    config_file = tempfile.NamedTemporaryFile(
        suffix=".json", delete=False, mode="w"
    )
    config_path = config_file.name
    json.dump(config, config_file)
    config_file.close()

    go2rtc_proc = subprocess.Popen(
        [str(GO2RTC_BIN), "-config", config_path],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )

    keepalive_proc = None

    def start_keepalive(port: int, stream: str) -> subprocess.Popen:
        """Pull the stream into /dev/null to keep go2rtc's exec: source alive.

        go2rtc's exec: source is lazy — it only runs rpicam-vid while at least
        one consumer is connected. Without a keepalive, every Frigate reconnect
        causes a ~2s camera reinit gap. The keepalive ensures rpicam-vid stays
        running continuously; Frigate's reconnects become seamless.
        """
        return subprocess.Popen(
            [
                "ffmpeg", "-loglevel", "quiet",
                "-rtsp_transport", "tcp",
                "-i", f"rtsp://127.0.0.1:{port}/{stream}",
                "-f", "null", "-",
            ],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

    try:
        time.sleep(1.0)  # let go2rtc bind the port
        if go2rtc_proc.poll() is not None:
            err = go2rtc_proc.stderr.read().decode(errors="replace")
            print(f"go2rtc exited early: {err}", file=sys.stderr)
            return 1

        # Kick off the keepalive consumer — this triggers go2rtc to start rpicam-vid
        keepalive_proc = start_keepalive(args.port, args.stream)

        start_ts = time.time()
        payload = {
            "status": "streaming",
            "serve_url": serve_url,
            "go2rtc_config": config,
        }
        log_event("frigate-stream", payload)
        print(json.dumps(payload))

        duration = args.duration
        while True:
            if STOP_REQUESTED:
                break
            if duration > 0 and (time.time() - start_ts) >= duration:
                break
            if go2rtc_proc.poll() is not None:
                log_event("frigate-stream", {"status": "go2rtc_exited_unexpectedly"})
                break
            # Restart keepalive if it died (e.g. go2rtc hiccup)
            if keepalive_proc.poll() is not None:
                keepalive_proc = start_keepalive(args.port, args.stream)
            time.sleep(0.5)

    finally:
        for proc in (keepalive_proc, go2rtc_proc):
            if proc is not None and proc.poll() is None:
                proc.terminate()
        for proc in (keepalive_proc, go2rtc_proc):
            if proc is None:
                continue
            try:
                proc.wait(timeout=5)
            except subprocess.TimeoutExpired:
                proc.kill()
        try:
            Path(config_path).unlink(missing_ok=True)
        except Exception:
            pass
        try:
            PID_FILE.unlink(missing_ok=True)
        except Exception:
            pass
        log_event(
            "frigate-stream",
            {"status": "stopped", "serve_url": serve_url,
             "duration": time.time() - start_ts},
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
PY
