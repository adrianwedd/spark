#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

# Uses venv python — needs requests/urllib + pxh, does NOT need picarx GPIO.
# GPIO-dependent actions (sonar, look, perform) are delegated to bin/tool-* subprocesses.
exec python - "$@" <<'PY'
"""Cognitive loop daemon: gives the robot an inner life.

Three layers:
  Layer 1 — Awareness (every ~30s): read sensors + state, detect transitions.
  Layer 2 — Reflection (on transition or every ~2 min): LLM produces a thought.
  Layer 3 — Expression (when reflection decides to act): speak, look.

Awareness is enriched with weather (every 10 min), long-term memory,
topic seeding for variety, and repetition detection to stay dynamic.

Run with: bin/px-mind [--dry-run]
Requires Ollama running on M1.local (or PX_OLLAMA_HOST).
"""
