# ── Mood momentum: valence (-1..1) × arousal (-1..1) ───────────────
MOOD_COORDS: dict[str, tuple[float, float]] = {
    "excited":       ( 0.8,  0.9),
    "playful":       ( 0.6,  0.7),
    "mischievous":   ( 0.4,  0.8),
    "curious":       ( 0.5,  0.5),
    "alert":         ( 0.2,  0.8),
    "content":       ( 0.4,  0.0),
    "peaceful":      ( 0.3, -0.3),
    "contemplative": ( 0.0, -0.2),
    "bored":        (-0.3, -0.5),
    "lonely":       (-0.6,  0.1),
    "grumpy":       (-0.5,  0.4),
    "anxious":      (-0.3,  0.7),
}
MOOD_ALPHA = 0.3  # weight of new mood (0.7 = inertia from previous)

