            f"{YELLOW}7{RESET}{DIM}firehose{RESET}  "
            f"{YELLOW}8{RESET}{DIM}claude-log{RESET}  "
            f"{YELLOW}9{RESET}{DIM}motd{RESET}",
        f"  {DIM}api{RESET}  "
            f"{_link(f'{API}/public/status', 'status')}  "
