# ── Main ─────────────────────────────────────────────────────────────────────

def main() -> None:
    sections = [
        section_banner(),
        section_system(),
        section_services(),
        section_connectivity(),
        section_tmux(),
        section_spark(),
        section_last_voice(),
        section_social(),
        section_errors(),
        section_quickref(),
    ]

    for section in sections:
        for line in section:
            print(line)


if __name__ == "__main__":
    main()
