#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

# Uses venv python — no GPIO needed.
exec python - "$@" <<'PY'
"""Social posting daemon: watches thoughts and posts qualifying ones.

Monitors state/thoughts.jsonl for high-salience or spoken-action thoughts,
deduplicates against recent posts, and queues them for social media.

Run with: bin/px-post [--dry-run]
"""
from __future__ import annotations

import argparse
import datetime as dt
import difflib
import json
import os
import random
import shutil
import signal
import subprocess
import sys
import tempfile
import textwrap
import threading
import time
import urllib.parse
import urllib.request
import urllib.error
from pathlib import Path

_SYS_RNG = random.SystemRandom()

PROJECT_ROOT = Path(os.environ.get("PROJECT_ROOT", Path(__file__).parent.parent))
LOG_DIR = Path(os.environ.get("LOG_DIR", PROJECT_ROOT / "logs"))
STATE_DIR = Path(os.environ.get("PX_STATE_DIR", PROJECT_ROOT / "state"))

MIN_SALIENCE_FEED = float(os.environ.get("PX_POST_MIN_SALIENCE", "0.55"))
MIN_SALIENCE_SOCIAL = float(os.environ.get("PX_POST_MIN_SALIENCE_SOCIAL", "0.7"))
SPOKEN_ACTIONS = {"comment", "greet", "weather_comment"}
SIMILARITY_THRESHOLD = 0.75
REQUIRED_FIELDS = {"thought", "salience", "action"}

# Hashtags: one from each pool per post, rotated randomly
_HASHTAGS_WRITING = ["#writing", "#poetry", "#thoughts", "#microfiction", "#prose"]
_HASHTAGS_ROBOT   = ["#AI", "#robotics", "#consciousness", "#robot", "#innerlife"]


def pick_hashtags(thought: str = "", mood: str = "") -> str:
    """Pick two hashtags — one writing, one robot — rotated per post."""
    w = _SYS_RNG.choice(_HASHTAGS_WRITING)
    r = _SYS_RNG.choice(_HASHTAGS_ROBOT)
    return f"{w} {r}"


# Full 13-mood palette — mirrors colors.css --mood-* vars exactly
MOOD_COLORS = {
    'peaceful':      '#4a9d8f',
    'content':       '#6b8e5e',
    'contemplative': '#7b6fa0',
    'bored':         '#8a8a8a',
    'lonely':        '#5b7ba5',
    'curious':       '#c48a3f',
    'mischievous':   '#8da000',
    'grumpy':        '#c44040',
    'anxious':       '#d4883a',
    'alert':         '#00b8d4',
    'playful':       '#c74dbd',
    'excited':       '#d44a6b',
    'active':        '#d46b4a',
}

# Card design tokens — mirror site/css/base.css --dark-* vars
_CARD_BG      = '#1a181c'
_CARD_TEXT    = '#e2ddd8'
_CARD_COPPER  = '#c48b6e'
_CARD_MUTED   = '#968e96'
_CARD_BORDER  = '#3d3844'

THOUGHT_IMAGE_DIR = STATE_DIR / "thought-images"


def generate_thought_card(thought_text: str, mood: str, ts: str) -> 'Path | None':
    """Generate a branded 1080x1080 square thought card. Returns path or None on failure."""
    try:
        from PIL import Image, ImageDraw, ImageFont
    except ImportError:
        log("generate_thought_card: Pillow not installed — skipping image generation")
        return None

    try:
        THOUGHT_IMAGE_DIR.mkdir(parents=True, exist_ok=True)

        safe_ts = _re.sub(r'[^a-zA-Z0-9_\-]', '_', ts) if ts else "unknown"
        out_path = THOUGHT_IMAGE_DIR / f"{safe_ts}.png"

        if out_path.exists():
            return out_path

        W, H = 1080, 1080

        # ── Dark background (single fill — faster than row-by-row gradient) ──
        img = Image.new('RGB', (W, H), _CARD_BG)
        draw = ImageDraw.Draw(img)

        # Mood colour for this card
        mood_str = (mood or 'content').lower()
        mc = MOOD_COLORS.get(mood_str, _CARD_COPPER)

        # Mood-coloured top stripe (6 px) — gives each card a unique identity
        draw.rectangle([0, 0, W, 6], fill=mc)

        # Fonts with fallbacks
        def _font(path, size):
            try:
                return ImageFont.truetype(path, size)
            except OSError:
                return ImageFont.load_default()

        font_mood = _font('/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf', 18)
        font_url  = _font('/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf', 16)

        # Adaptive font size based on text length
        n = len(thought_text)
        if n < 60:
            font_sz, wrap_w = 48, 18
        elif n < 100:
            font_sz, wrap_w = 42, 22
        elif n < 160:
            font_sz, wrap_w = 36, 28
        elif n < 250:
            font_sz, wrap_w = 32, 30
        else:
            font_sz, wrap_w = 28, 34

        font_quote = _font('/usr/share/fonts/opentype/urw-base35/NimbusMonoPS-Italic.otf', font_sz)
        deco_sz = int(font_sz * 1.8)
        font_deco       = _font('/usr/share/fonts/truetype/dejavu/DejaVuSerif-Bold.ttf', deco_sz)
        font_deco_close = _font('/usr/share/fonts/truetype/dejavu/DejaVuSerif-Bold.ttf', int(deco_sz * 0.6))

        ix, iw = 100, W - 100

        # Wrap and measure text block
        wrapped = textwrap.fill(thought_text, width=wrap_w)
        lines = wrapped.split('\n')
        max_lines = 18
        if len(lines) > max_lines:
            lines = lines[:max_lines]
            lines[-1] = lines[-1][:wrap_w - 3] + '...'
        line_h = int(font_sz * 1.4)

        # Total block height: open quote + text lines + close quote
        open_h  = int(deco_sz * 0.55)
        text_h  = len(lines) * line_h
        close_h = int(deco_sz * 0.35)
        total   = open_h + text_h + close_h

        # Golden ratio vertical placement (0.38 from top)
        badge_zone = 100
        usable_top, usable_bottom = 60, H - 60 - badge_zone
        usable  = usable_bottom - usable_top
        block_y = usable_top + int((usable - total) * 0.38)

        # Opening quote mark — copper accent
        draw.text((ix - 15, block_y), chr(8220), fill=_CARD_COPPER, font=font_deco)

        # Thought text — off-white on dark
        text_y = block_y + open_h
        for line in lines:
            draw.text((ix + 10, text_y), line, fill=_CARD_TEXT, font=font_quote)
            text_y += line_h

        # Closing quote mark — copper, smaller, after last word
        try:
            lb = draw.textbbox((0, 0), lines[-1], font=font_quote)
            last_w = lb[2] - lb[0]
        except AttributeError:
            last_w = len(lines[-1]) * int(font_sz * 0.6)
        cx = min(ix + 10 + last_w + 8, iw - int(deco_sz * 0.4))
        cy = text_y - line_h + int(font_sz * 0.4)
        draw.text((cx, cy), chr(8221), fill=_CARD_COPPER, font=font_deco_close)

        # ── Bottom bar ───────────────────────────────────────────────────────
        bar_y   = H - 90
        sep_y   = bar_y - 16

        # Thin separator line
        draw.line([(ix, sep_y), (iw, sep_y)], fill=_CARD_BORDER, width=1)

        # Left: mood dot + mood name in mood colour, uppercase monospace
        dot_r = 6
        dot_cx, dot_cy = ix + dot_r, bar_y + 12
        draw.ellipse([dot_cx - dot_r, dot_cy - dot_r, dot_cx + dot_r, dot_cy + dot_r], fill=mc)
        draw.text((ix + dot_r * 2 + 8, bar_y + 2), mood_str.upper(), fill=mc, font=font_mood)

        # Right: spark.wedd.au in copper
        url = 'spark.wedd.au'
        try:
            ub  = draw.textbbox((0, 0), url, font=font_url)
            utw = ub[2] - ub[0]
        except AttributeError:
            utw = len(url) * 9
        draw.text((iw - utw, bar_y + 4), url, fill=_CARD_COPPER, font=font_url)

        img.save(str(out_path), 'PNG', optimize=True)
        log(f"thought card generated: {out_path.name}")
        return out_path

    except Exception as exc:
        log(f"generate_thought_card failed: {exc}")
        return None


def log(msg: str, **extra) -> None:
    """Emit a structured log line."""
    import datetime as dt
    entry = {
        "ts": dt.datetime.now(dt.timezone.utc).isoformat(),
        "src": "px-post",
        "msg": msg,
        **extra,
    }
    try:
        LOG_DIR.mkdir(parents=True, exist_ok=True)
        log_file = LOG_DIR / "tool-post.log"
        with open(log_file, "a") as f:
            f.write(json.dumps(entry) + "\n")
        # Simple rotation: keep last half when file exceeds 5MB
        try:
            if log_file.stat().st_size > 5_000_000:
                lines = log_file.read_text(encoding="utf-8").splitlines()
                half = len(lines) // 2
                half_content = "\n".join(lines[half:]) + "\n"
                fd, tmp = tempfile.mkstemp(dir=str(log_file.parent), suffix=".tmp")
                with os.fdopen(fd, "w", encoding="utf-8") as f:
                    f.write(half_content)
                    f.flush()
                    os.fsync(f.fileno())
                os.replace(tmp, str(log_file))
        except Exception:
            pass
    except OSError:
        pass


def log_event(name: str, payload: dict) -> None:
    """Append a structured log entry under logs/tool-<name>.log."""
    log_path = LOG_DIR / f"tool-{name}.log"
    try:
        LOG_DIR.mkdir(parents=True, exist_ok=True)
        record = {"ts": dt.datetime.now(dt.timezone.utc).isoformat(), **payload}
        with log_path.open("a", encoding="utf-8") as f:
            f.write(json.dumps(record) + "\n")
    except OSError:
        pass


# Private content that must never be published — medical, custody, household details
import re as _re

# Private content that must never be published — medical, custody, household details.
# Uses word-boundary regex to avoid false positives (e.g. "comedies" matching "meds").
_PRIVATE_PATTERNS_RE = _re.compile(r'\b(?:' + '|'.join([
    r"meds", r"medication", r"medicated", r"prescription",
    r"custody", r"mum'?s place", r"dad'?s place", r"mum'?s house", r"dad'?s house",
    r"thirsty", r"hydration", r"water intake",
    r"sleep quality", r"sleep score",
    r"on a call", r"mic active",
]) + r')\b', _re.IGNORECASE)


def _contains_private_content(text: str) -> bool:
    """Return True if text contains private/medical content that shouldn't be published."""
    return bool(_PRIVATE_PATTERNS_RE.search(text))


def qualifies(entry: dict) -> bool:
    """Return True if this thought qualifies for the feed (lower threshold)."""
    if not REQUIRED_FIELDS.issubset(entry.keys()):
        return False
    if _contains_private_content(entry.get("thought", "")):
        return False
    if entry.get("salience", 0) >= MIN_SALIENCE_FEED:
        return True
    if entry.get("action") in SPOKEN_ACTIONS:
        return True
    return False


def qualifies_social(entry: dict) -> bool:
    """Return True if this thought qualifies for Bluesky (higher threshold)."""
    if not REQUIRED_FIELDS.issubset(entry.keys()):
        return False
    if _contains_private_content(entry.get("thought", "")):
        return False
    if entry.get("salience", 0) >= MIN_SALIENCE_SOCIAL:
        return True
    if entry.get("action") in SPOKEN_ACTIONS:
        return True
    return False


def is_duplicate(thought: str, recent_posts: list[str]) -> bool:
    """Return True if thought is too similar to a recent post."""
    for prev in recent_posts:
        ratio = difflib.SequenceMatcher(None, thought, prev).ratio()
        if ratio >= SIMILARITY_THRESHOLD:
            return True
    return False


def run_qa_gate(thought: str) -> str | None:
    """Return 'pass', 'rejected', 'ambiguous', or None (error/timeout).

    Calls claude CLI with a binary YES/NO prompt. Response is stripped,
    lowercased, and prefix-matched.

    A circuit breaker opens after 3 consecutive failures, skipping QA calls
    for 5 minutes (returns None immediately). Resets on any success.
    """
    if os.environ.get("PX_POST_QA", "1") == "0":
        return "pass"  # QA disabled for testing

    # Circuit breaker check
    now = time.monotonic()
    if _qa_breaker["failures"] >= _qa_breaker["threshold"]:
        if now < _qa_breaker["open_until"]:
            log("qa gate circuit breaker open — skipping")
            return None
        else:
            # Cooldown elapsed — reset and retry
            log(f"qa breaker: cooldown elapsed, retrying (was {_qa_breaker['failures']} consecutive failures)")
            _qa_breaker["failures"] = 0

    claude_bin = (os.environ.get("PX_CLAUDE_BIN")
                  or shutil.which("claude")
                  or "/home/pi/.local/bin/claude")

    prompt = ('Is this thought from a small robot interesting enough to share '
              'publicly on social media?\n'
              'Answer only YES or NO. Nothing else.\n\n'
              f'The thought: "{thought}"')

    # Strip Claude Code env vars to allow nested invocation
    env = {k: v for k, v in os.environ.items()
           if not k.startswith("CLAUDE_CODE")
           and k not in ("CLAUDECODE", "DISABLE_CLAUDE_CODE_PROTECTIONS")}

    try:
        result = subprocess.run(
            [claude_bin, "-p", prompt,
             "--no-session-persistence",
             "--output-format", "text",
             "--allowedTools", ""],
            capture_output=True, text=True, timeout=15, env=env,
        )
        if result.returncode != 0:
            log(f"qa gate error: claude exit {result.returncode}: {result.stderr[:200]}")
            _qa_breaker["failures"] += 1
            if _qa_breaker["failures"] >= _qa_breaker["threshold"]:
                _qa_breaker["open_until"] = time.monotonic() + _qa_breaker["cooldown"]
                log(f"qa gate circuit breaker opened ({_qa_breaker['failures']} failures)")
            return None
        resp = result.stdout.strip().lower()
        if resp.startswith("yes"):
            _qa_breaker["failures"] = 0
            return "pass"
        elif resp.startswith("no"):
            _qa_breaker["failures"] = 0
            return "rejected"
        else:
            log(f"qa gate ambiguous response: {result.stdout.strip()[:100]}")
            _qa_breaker["failures"] = 0
            return "ambiguous"
    except subprocess.TimeoutExpired:
        log("qa gate timeout (15s)")
        _qa_breaker["failures"] += 1
        if _qa_breaker["failures"] >= _qa_breaker["threshold"]:
            _qa_breaker["open_until"] = time.monotonic() + _qa_breaker["cooldown"]
            log(f"qa gate circuit breaker opened ({_qa_breaker['failures']} failures)")
        return None
    except Exception as exc:
        log(f"qa gate error: {exc}")
        _qa_breaker["failures"] += 1
        if _qa_breaker["failures"] >= _qa_breaker["threshold"]:
            _qa_breaker["open_until"] = time.monotonic() + _qa_breaker["cooldown"]
            log(f"qa gate circuit breaker opened ({_qa_breaker['failures']} failures)")
        return None


CURSOR_FILE = STATE_DIR / "px-post-cursor.json"


def _load_cursor() -> dict:
    try:
        return json.loads(CURSOR_FILE.read_text())
    except (FileNotFoundError, json.JSONDecodeError) as exc:
        log(f"cursor reset (fresh start): {exc}")
        return {"offset": 0, "inode": 0}


def _save_cursor(offset: int, inode: int) -> None:
    data = {"file": "thoughts-spark.jsonl", "offset": offset, "inode": inode,
            "last_poll_ts": dt.datetime.now(dt.timezone.utc).isoformat()}
    try:
        # Atomic write
        fd, tmp = tempfile.mkstemp(dir=str(STATE_DIR), suffix=".tmp")
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            json.dump(data, f, indent=2)
            f.flush()
            os.fsync(f.fileno())
        os.replace(tmp, str(CURSOR_FILE))
    except Exception as exc:
        log(f"cursor write failed: {exc}")


def poll_new_thoughts(thoughts_file: Path) -> list[dict]:
    """Read new complete lines from thoughts file since last cursor position."""
    cursor = _load_cursor()
    try:
        st = thoughts_file.stat()
    except FileNotFoundError:
        return []

    # Inode change -> file replaced, reset
    if st.st_ino != cursor.get("inode", 0):
        log("cursor: inode changed — resetting to 0")
        cursor["offset"] = 0
    # File shrunk -> trimmed, reset
    elif st.st_size < cursor.get("offset", 0):
        log("cursor: file shrunk — resetting to 0")
        cursor["offset"] = 0

    with thoughts_file.open("rb") as f:
        f.seek(cursor["offset"])
        raw = f.read()

    # Only process complete lines (ending in \n)
    last_nl = raw.rfind(b"\n")
    if last_nl == -1:
        return []  # no complete lines
    processable = raw[:last_nl + 1]
    new_offset = cursor["offset"] + len(processable)

    entries = []
    for line in processable.decode("utf-8", errors="replace").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            log(f"corrupt line skipped: {line[:100]}")
            continue
        if not REQUIRED_FIELDS.issubset(entry.keys()):
            log(f"malformed entry skipped: {list(entry.keys())}")
            continue
        entries.append(entry)

    _save_cursor(new_offset, st.st_ino)
    return entries


FEED_FILE = STATE_DIR / "feed.json"
FEED_LIMIT = 100


def truncate_at_word(text: str, max_len: int) -> str:
    """Truncate text at the last word boundary before max_len, append ellipsis."""
    if len(text) <= max_len:
        return text
    # Find last space before max_len - 1 (leaving room for …)
    cut_point = text[:max_len - 1].rfind(" ")
    if cut_point <= 0:
        cut_point = max_len - 1  # no spaces, hard cut
    return text[:cut_point] + "\u2026"


def write_feed(thought: dict) -> bool:
    """Append thought to feed.json. Returns True on success."""
    try:
        existing = json.loads(FEED_FILE.read_text()) if FEED_FILE.exists() else {"posts": []}
    except (json.JSONDecodeError, OSError):
        existing = {"posts": []}

    post = {
        "ts": thought.get("ts", ""),
        "thought": thought["thought"],
        "mood": thought.get("mood", ""),
        "salience": thought.get("salience", 0),
        "posted_ts": dt.datetime.now(dt.timezone.utc).isoformat(),
    }
    existing["posts"].append(post)
    existing["posts"] = existing["posts"][-FEED_LIMIT:]
    existing["updated"] = dt.datetime.now(dt.timezone.utc).isoformat()

    try:
        fd, tmp = tempfile.mkstemp(dir=str(STATE_DIR), suffix=".tmp")
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            json.dump(existing, f, indent=2)
            f.flush()
            os.fsync(f.fileno())
        os.replace(tmp, str(FEED_FILE))
        return True
    except Exception as exc:
        log(f"feed.json write failed: {exc}")
        try:
            os.unlink(tmp)
        except Exception:
            pass
        return False


class BlueskyClient:
    def __init__(self):
        self.handle = os.environ.get("PX_BSKY_HANDLE", "")
        log(f"bluesky: init handle={self.handle!r} password={'***' if os.environ.get('PX_BSKY_APP_PASSWORD') else '(empty)'}")
        self.password = os.environ.get("PX_BSKY_APP_PASSWORD", "")
        self.access_token = None
        self.refresh_token = None
        self.did = None
        self.auth_failures = 0
        self.disabled = False
        self._logged_missing = False

    def available(self) -> bool:
        if not self.handle or not self.password:
            if not self._logged_missing:
                log("bluesky: credentials not configured — skipping")
                self._logged_missing = True
            return False
        return not self.disabled

    def _auth(self) -> bool:
        """Authenticate via createSession. Returns True on success."""
        url = "https://bsky.social/xrpc/com.atproto.server.createSession"
        data = json.dumps({"identifier": self.handle, "password": self.password}).encode()
        req = urllib.request.Request(url, data=data,
                                     headers={"Content-Type": "application/json"})
        try:
            with urllib.request.urlopen(req, timeout=10) as resp:
                body = json.loads(resp.read())
                self.access_token = body["accessJwt"]
                self.refresh_token = body.get("refreshJwt")
                self.did = body["did"]
                self.auth_failures = 0
                return True
        except urllib.error.HTTPError as e:
            self.auth_failures += 1
            if e.code == 400:
                log("bluesky: auth failed (400) — check PX_BSKY_HANDLE and PX_BSKY_APP_PASSWORD")
            else:
                log(f"bluesky: auth failed ({e.code})")
            if self.auth_failures >= 3:
                self.disabled = True
                log("bluesky: disabled after 3 consecutive auth failures")
            return False
        except Exception as exc:
            self.auth_failures += 1
            log(f"bluesky: auth error: {exc}")
            if self.auth_failures >= 3:
                self.disabled = True
                log("bluesky: disabled after 3 consecutive auth failures")
            return False

    def _upload_image(self, image_path: 'Path') -> 'dict | None':
        """Upload image blob to Bluesky. Returns blob dict or None. Re-auths on failure."""
        try:
            with open(image_path, 'rb') as f:
                img_data = f.read()
            for attempt in range(2):  # try once, re-auth, try again
                req = urllib.request.Request(
                    'https://bsky.social/xrpc/com.atproto.repo.uploadBlob',
                    data=img_data,
                    headers={
                        'Content-Type': 'image/png',
                        'Authorization': f'Bearer {self.access_token}',
                    },
                )
                try:
                    resp = json.loads(urllib.request.urlopen(req, timeout=15).read())
                    return resp.get('blob')
                except urllib.error.HTTPError as e:
                    if attempt == 0 and e.code in (400, 401):
                        log(f"bluesky: image upload {e.code} — re-authenticating")
                        if self._auth():
                            continue  # retry with fresh token
                    log(f"bluesky: image upload failed: HTTP {e.code}")
                    return None
        except Exception as exc:
            log(f"bluesky: image upload failed: {exc}")
            return None

    def post(self, text: str, dry: bool = False, image_path: 'Path | None' = None) -> str:
        """Post text to Bluesky. Returns 'ok', 'error:reason', or 'skipped'."""
        if not self.available():
            return "skipped"
        if dry:
            log(f"bluesky [DRY]: {text[:80]}" + (f" [img={image_path}]" if image_path else ""))
            return "ok"
        if not self.access_token and not self._auth():
            return "error:auth_failed"

        post_text = text  # caller pre-truncates to leave room for suffix
        rec = {
            "$type": "app.bsky.feed.post",
            "text": post_text,
            "createdAt": dt.datetime.now(dt.timezone.utc).isoformat(),
        }
        # Add rich text facets (clickable links + hashtags)
        facets = []
        text_bytes = post_text.encode("utf-8")
        search_start = 0
        for token in post_text.split():
            if token.startswith("https://") or token.startswith("http://"):
                url_bytes = token.encode("utf-8")
                start = text_bytes.find(url_bytes, search_start)
                if start >= 0:
                    facets.append({
                        "index": {"byteStart": start, "byteEnd": start + len(url_bytes)},
                        "features": [{"$type": "app.bsky.richtext.facet#link", "uri": token}],
                    })
                    search_start = start + len(url_bytes)
            elif token.startswith("#") and len(token) > 1:
                tag_bytes = token.encode("utf-8")
                start = text_bytes.find(tag_bytes, search_start)
                if start >= 0:
                    facets.append({
                        "index": {"byteStart": start, "byteEnd": start + len(tag_bytes)},
                        "features": [{"$type": "app.bsky.richtext.facet#tag", "tag": token[1:]}],
                    })
                    search_start = start + len(tag_bytes)
        if facets:
            rec["facets"] = facets
        record = {
            "repo": self.did,
            "collection": "app.bsky.feed.post",
            "record": rec,
        }
        # Attach image if provided
        if image_path and Path(image_path).exists():
            blob = self._upload_image(image_path)
            if blob:
                record["record"]["embed"] = {
                    "$type": "app.bsky.embed.images",
                    "images": [{"alt": post_text[:100], "image": blob}],
                }
        url = "https://bsky.social/xrpc/com.atproto.repo.createRecord"
        data = json.dumps(record).encode()
        req = urllib.request.Request(url, data=data, headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {self.access_token}",
        })
        try:
            with urllib.request.urlopen(req, timeout=10) as resp:
                log(f"bluesky: posted ({len(post_text)} chars)")
                return "ok"
        except urllib.error.HTTPError as e:
            if e.code in (400, 401):
                log(f"bluesky: {e.code} — re-authenticating")
                if self._auth():
                    # Retry once with new token
                    req.remove_header("Authorization")
                    req.add_header("Authorization", f"Bearer {self.access_token}")
                    try:
                        with urllib.request.urlopen(req, timeout=10) as resp:
                            return "ok"
                    except Exception as exc2:
                        return f"error:retry_failed:{exc2}"
                return "error:reauth_failed"
            elif e.code == 429:
                retry_after = e.headers.get("Retry-After", "unknown")
                log(f"bluesky: rate limited (429), Retry-After: {retry_after}")
                return "error:rate_limited"
            return f"error:http_{e.code}"
        except Exception as exc:
            return f"error:{exc}"


QUEUE_FILE = STATE_DIR / "post_queue.jsonl"
QUEUE_LIMIT = 200

_qa_breaker = {"failures": 0, "open_until": 0.0, "threshold": 3, "cooldown": 300}


def _generate_post_id() -> str:
    return f"post-{dt.datetime.now().strftime('%Y%m%d-%H%M%S')}-{_SYS_RNG.randint(0, 999):03d}"


def queue_thought(entry: dict) -> None:
    """Append a qualifying thought to the post queue. Skips if already queued (dedup)."""
    # Check for duplicates in existing queue
    existing = _load_queue()
    new_thought = entry["thought"][:100]
    for existing_entry in existing:
        if existing_entry.get("thought", "")[:100] == new_thought:
            return  # already queued
    queue_entry = {
        "id": _generate_post_id(),
        "ts": entry.get("ts", ""),
        "thought": entry["thought"],
        "mood": entry.get("mood", ""),
        "action": entry.get("action", ""),
        "salience": entry.get("salience", 0),
        "queued_ts": dt.datetime.now(dt.timezone.utc).isoformat(),
        "qa_result": None,
        "posted": {"feed": None, "bluesky": None},
    }
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    try:
        with QUEUE_FILE.open("a", encoding="utf-8") as f:
            f.write(json.dumps(queue_entry) + "\n")
    except OSError as exc:
        log(f"queue_thought failed: {exc}")


def _load_queue() -> list[dict]:
    """Read all queue entries. Skip corrupt lines."""
    if not QUEUE_FILE.exists():
        return []
    entries = []
    for line in QUEUE_FILE.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            entries.append(json.loads(line))
        except json.JSONDecodeError:
            log(f"queue: corrupt line skipped: {line[:100]}")
    return entries


def _save_queue(entries: list[dict]) -> None:
    """Rewrite queue atomically. Trim to QUEUE_LIMIT."""
    entries = entries[-QUEUE_LIMIT:]
    fd, tmp = tempfile.mkstemp(dir=str(STATE_DIR), suffix=".tmp")
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            for e in entries:
                f.write(json.dumps(e) + "\n")
            f.flush()
            os.fsync(f.fileno())
        os.replace(tmp, str(QUEUE_FILE))
    except Exception as exc:
        log(f"queue save failed: {exc}")
        try:
            os.unlink(tmp)
        except Exception:
            pass


def _is_in_feed(thought_text: str, feed_posts: list[dict]) -> bool:
    """Check if a thought already appears in feed.json (repost guard)."""
    for post in feed_posts:
        ratio = difflib.SequenceMatcher(None, thought_text, post.get("thought", "")).ratio()
        if ratio >= SIMILARITY_THRESHOLD:
            return True
    return False


def flush_queue(bluesky: 'BlueskyClient', dry: bool) -> dict:
    """Two-pass flush: batch all feed writes, then one social post. Never blocks feed on social rate limits."""
    entries = _load_queue()
    if not entries:
        return {"processed": 0, "posted": False, "rejected": False}

    # Load feed for repost guard
    feed_posts = []
    try:
        feed = json.loads(FEED_FILE.read_text()) if FEED_FILE.exists() else {}
        feed_posts = feed.get("posts", [])
    except (json.JSONDecodeError, OSError):
        pass

    processed = 0
    was_posted = False
    was_rejected = False

    # ── Pass 1: Batch all feed writes (local, no rate limit) ──
    for entry in entries:
        posted = entry.get("posted", {})
        if posted.get("feed") is not None and not (isinstance(posted.get("feed"), str) and posted["feed"].startswith("error:")):
            continue  # feed already done

        # Privacy gate
        if _contains_private_content(entry.get("thought", "")):
            entry["posted"] = {k: v or "skipped" for k, v in posted.items()}
            log(f"flush: private content blocked: {entry.get('thought', '')[:50]}")
            processed += 1
            continue

        # Repost guard
        if _is_in_feed(entry.get("thought", ""), feed_posts):
            entry["qa_result"] = entry.get("qa_result") or "pass"
            entry["posted"]["feed"] = "ok"
            processed += 1
            continue

        # QA gate (if enabled and not already done)
        if entry.get("qa_result") is None:
            qa = run_qa_gate(entry["thought"])
            if qa is None:
                continue  # timeout — skip, try next cycle
            entry["qa_result"] = qa

        if entry["qa_result"] == "rejected":
            entry["posted"] = {k: v or "skipped" for k, v in posted.items()}
            processed += 1
            was_rejected = True
            continue
        # "ambiguous" (e.g. "Maybe") defaults to pass — QA is a safety net, not a quality bar
        if entry["qa_result"] == "ambiguous":
            entry["qa_result"] = "pass"

        # Write to feed
        if write_feed(entry):
            entry["posted"]["feed"] = "ok"
            was_posted = True
            processed += 1
        else:
            entry["posted"]["feed"] = "error:write_failed"

    # ── Pass 2: One social post (rate-limited) ──
    # Reload feed for cross-check (feed was just updated in pass 1)
    try:
        feed_data = json.loads(FEED_FILE.read_text()) if FEED_FILE.exists() else {"posts": []}
        feed_texts = {p["thought"][:80] for p in feed_data.get("posts", [])}
    except (json.JSONDecodeError, OSError):
        feed_texts = set()

    for entry in entries:
        posted = entry.get("posted", {})
        # Need Bluesky posting?
        bsky_pending = posted.get("bluesky") is None or (isinstance(posted.get("bluesky"), str) and posted["bluesky"].startswith("error:"))
        if not bsky_pending:
            continue

        # Privacy gate
        if _contains_private_content(entry.get("thought", "")):
            entry["posted"]["bluesky"] = entry["posted"].get("bluesky") or "skipped"
            continue

        text = entry["thought"]

        # Feed cross-check: must be in feed to post socially
        if text[:80] not in feed_texts:
            entry["posted"]["bluesky"] = entry["posted"].get("bluesky") or "skipped"
            continue

        # Build social text
        thought_ts = entry.get("ts", "")
        permalink = f"https://spark.wedd.au/thought/?ts={urllib.parse.quote(thought_ts)}" if thought_ts else ""
        hashtags = pick_hashtags(text, entry.get("mood", ""))
        social_suffix = ""
        if permalink:
            social_suffix += "\n\n" + permalink
        if hashtags:
            social_suffix += "\n\n" + hashtags
        bsky_thought = truncate_at_word(text, 300 - len(social_suffix.encode("utf-8")))

        # Generate thought card image
        image_path = generate_thought_card(text, entry.get("mood", ""), entry.get("ts", ""))

        if qualifies_social(entry):
            entry["posted"]["bluesky"] = bluesky.post(bsky_thought + social_suffix, dry=dry, image_path=image_path)
            processed += 1
            was_posted = True
            break  # rate limit: max 1 social post per flush cycle
        else:
            entry["posted"]["bluesky"] = "skipped"

    _save_queue(entries)
    return {"processed": processed, "posted": was_posted, "rejected": was_rejected}


STATUS_FILE = STATE_DIR / "px-post-status.json"


def write_health_status(queue_depth: int, total_posted: int, total_rejected: int,
                        bluesky_ok: bool, last_post_ts: str | None) -> None:
    """Write health status atomically."""
    data = {
        "ts": dt.datetime.now(dt.timezone.utc).isoformat(),
        "status": "running",
        "queue_depth": queue_depth,
        "total_posted": total_posted,
        "total_rejected": total_rejected,
        "bluesky_ok": bluesky_ok,
        "last_post_ts": last_post_ts,
    }
    try:
        fd, tmp = tempfile.mkstemp(dir=str(STATE_DIR), suffix=".tmp")
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            json.dump(data, f, indent=2)
            f.flush()
            os.fsync(f.fileno())
        os.replace(tmp, str(STATUS_FILE))
    except Exception as exc:
        log(f"health status write failed: {exc}")


def run_backfill(dry: bool) -> int:
    """Process entire thoughts file, write feed.json only. Returns count posted."""
    thoughts_file = STATE_DIR / "thoughts-spark.jsonl"
    if not thoughts_file.exists():
        log("backfill: no thoughts file found")
        return 0

    # Load existing feed for dedup
    feed_posts = []
    try:
        feed = json.loads(FEED_FILE.read_text()) if FEED_FILE.exists() else {}
        feed_posts = feed.get("posts", [])
    except (json.JSONDecodeError, OSError):
        pass

    posted = 0
    for line in thoughts_file.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        if not qualifies(entry):
            continue
        # Dedup against existing feed
        if is_duplicate(entry["thought"], [p.get("thought", "") for p in feed_posts]):
            continue
        # QA gate (unless disabled). "ambiguous" defaults to pass (safety net, not quality bar)
        qa = run_qa_gate(entry["thought"])
        if qa == "ambiguous":
            qa = "pass"
        if qa not in ("pass", None):
            continue
        if qa is None and os.environ.get("PX_POST_QA", "1") != "0":
            continue  # QA error, skip in backfill
        # Write to feed only (no social posting)
        if write_feed(entry):
            posted += 1
            # Update feed_posts for subsequent dedup
            feed_posts.append({"thought": entry["thought"]})

    log(f"backfill complete: {posted} thoughts posted to feed")
    return posted


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="SPARK social posting daemon")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--backfill", action="store_true")
    parser.add_argument("--poll-interval", type=int, default=60)
    parser.add_argument("--flush-interval", type=int, default=300)
    args = parser.parse_args(argv)

    dry = args.dry_run or os.environ.get("PX_POST_DRY", "0") != "0"

    # Single-instance guard (PID file — survives crashes unlike flock).
    # TOCTOU note: read-check-write is non-atomic, but systemd serialises restarts
    # (RestartSec=30), making simultaneous starts practically impossible.
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    pid_file = STATE_DIR / "px-post.pid"
    my_pid = os.getpid()
    try:
        if pid_file.exists():
            old_pid = int(pid_file.read_text().strip())
            if old_pid != my_pid and Path(f"/proc/{old_pid}").exists():
                try:
                    cmdline = Path(f"/proc/{old_pid}/cmdline").read_bytes().decode(errors="replace")
                except OSError:
                    cmdline = ""
                if "px-post" in cmdline:
                    log(f"another px-post instance is running (pid={old_pid})")
                    return 1
                else:
                    log(f"pid {old_pid} alive but not px-post (recycled PID) — taking over")
                    pid_file.unlink(missing_ok=True)
            else:
                log(f"stale pid file removed (pid={old_pid})")
                pid_file.unlink(missing_ok=True)
    except (ValueError, OSError) as exc:
        log(f"pid file check failed, removing: {exc}")
        pid_file.unlink(missing_ok=True)
    pid_file.write_text(str(my_pid))

    def _safe_unlink_pid():
        """Delete PID file only if it still contains our PID."""
        try:
            if pid_file.exists() and int(pid_file.read_text().strip()) == my_pid:
                pid_file.unlink(missing_ok=True)
        except (ValueError, OSError):
            pass

    log(f"starting pid={my_pid} dry={dry}")

    if args.backfill:
        count = run_backfill(dry)
        log(f"backfill done: {count} posts")
        _safe_unlink_pid()
        return 0

    # SIGTERM handler
    _shutdown = threading.Event()
    def _on_signal(s, f):
        _shutdown.set()
    signal.signal(signal.SIGTERM, _on_signal)
    signal.signal(signal.SIGINT, _on_signal)

    bluesky = BlueskyClient()
    thoughts_file = STATE_DIR / "thoughts-spark.jsonl"
    total_posted = 0
    total_rejected = 0
    last_post_ts = None
    last_flush = 0

    poll_count = 0
    try:
        while not _shutdown.is_set():
            poll_count += 1
            # Poll for new thoughts
            try:
                new_thoughts = poll_new_thoughts(thoughts_file)
            except Exception as exc:
                log(f"poll: CRASHED: {exc}")
                new_thoughts = []

            # Load feed for dedup
            feed_posts = []
            try:
                feed = json.loads(FEED_FILE.read_text()) if FEED_FILE.exists() else {}
                feed_posts = [p.get("thought", "") for p in feed.get("posts", [])]
            except (json.JSONDecodeError, OSError):
                pass

            queued_count = 0
            for entry in new_thoughts:
                if qualifies(entry) and not is_duplicate(entry["thought"], feed_posts):
                    queue_thought(entry)
                    queued_count += 1
            if new_thoughts or queued_count:
                log(f"poll: {len(new_thoughts)} new thoughts, {queued_count} queued")

            # Flush cycle
            now = time.monotonic()
            secs_until_flush = max(0, args.flush_interval - (now - last_flush))
            if poll_count % 5 == 0:  # log heartbeat every 5 polls (~5 min)
                log(f"heartbeat: poll={poll_count} flush_in={secs_until_flush:.0f}s queue={len(_load_queue())} bsky={bluesky.available()}")
            if now - last_flush >= args.flush_interval:
                log(f"flush: starting (interval={args.flush_interval}s, bsky_ok={bluesky.available()}, queue={len(_load_queue())})")
                try:
                    result = flush_queue(bluesky, dry)
                except Exception as exc:
                    log(f"flush: CRASHED: {exc}")
                    result = {"posted": False, "rejected": False, "processed": 0}
                log(f"flush: done processed={result.get('processed',0)} posted={result.get('posted')} rejected={result.get('rejected')}")
                if result.get("posted"):
                    total_posted += 1
                    last_post_ts = dt.datetime.now(dt.timezone.utc).isoformat()
                if result.get("rejected"):
                    total_rejected += 1

                write_health_status(
                    queue_depth=len(_load_queue()),
                    total_posted=total_posted,
                    total_rejected=total_rejected,
                    bluesky_ok=bluesky.available(),
                    last_post_ts=last_post_ts,
                )
                last_flush = now

            _shutdown.wait(timeout=args.poll_interval)
    finally:
        _safe_unlink_pid()

    log("shutting down")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
