#!/usr/bin/env python3
"""px-statusline — compact one-line status for Claude Code statusbar.

Reads only fast sources (state files, /sys, vcgencmd).
No I2C/GPIO/sudo — must complete in <200ms.
"""
from __future__ import annotations
import json
import os
import subprocess
from pathlib import Path

PROJECT_ROOT = Path(os.environ.get("PROJECT_ROOT", Path(__file__).resolve().parent.parent))
STATE_DIR    = Path(os.environ.get("PX_STATE_DIR", PROJECT_ROOT / "state"))


def _read_json(path: Path) -> dict:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}


def cpu_temp() -> str:
    try:
        t = int(Path("/sys/class/thermal/thermal_zone0/temp").read_text()) / 1000
        warn = "🔥" if t >= 80 else ("♨️ " if t >= 70 else "")
        return f"{warn}{t:.0f}°C"
    except Exception:
        return "?°C"


def throttle() -> str:
    try:
        raw = subprocess.check_output(["vcgencmd", "get_throttled"], text=True, timeout=1).strip()
        val = int(raw.split("=")[1], 16)
        if val == 0:
            return ""
        flags = []
        if val & 0x1:   flags.append("under-V")
        if val & 0x4:   flags.append("throttled")
        if val & 0x2:   flags.append("freq-cap")
        return " ⚡" + ",".join(flags) if flags else ""
    except Exception:
        return ""


def mem() -> str:
    try:
        info = Path("/proc/meminfo").read_text()
        avail = next(int(l.split()[1]) for l in info.splitlines() if l.startswith("MemAvailable"))
        mb = avail // 1024
        warn = "⚠️ " if mb < 200 else ""
        return f"{warn}{mb}MB"
    except Exception:
        return "?MB"


def battery() -> str:
    d = _read_json(STATE_DIR / "battery.json")
    if not d:
        return "🔋?"
    v = d.get("volts") or 0
    pct = d.get("pct") or 0
    charging = d.get("charging", False)
    icon = "🔌" if charging else ("🔋" if pct > 30 else ("🪫" if pct > 10 else "❌"))
    return f"{icon}{v:.1f}V({pct}%)"


def mood() -> str:
    d = _read_json(STATE_DIR / "mood.json")
    if not d:
        return ""
    icons = {
        "curious": "🔍", "content": "😌", "alert": "👀", "playful": "😄",
        "contemplative": "🤔", "bored": "😐", "mischievous": "😏",
        "lonely": "😔", "excited": "✨", "grumpy": "😤",
        "peaceful": "🕊️", "anxious": "😰",
    }
    m = d.get("mood", "")
    return icons.get(m, "🧠") + m


def sonar() -> str:
    d = _read_json(STATE_DIR / "awareness.json")
    cm = d.get("sonar_cm")
    if cm is None:
        return ""
    if cm >= 999:
        return "📡—"
    warn = "🚨" if cm < 20 else ("⚠️ " if cm < 35 else "📡")
    return f"{warn}{cm:.0f}cm"


def session() -> str:
    d = _read_json(STATE_DIR / "session.json")
    persona = d.get("persona") or ""
    listening = d.get("listening", False)
    parts = []
    if persona:
        p_icons = {"gremlin": "👹", "vixen": "🦊", "spark": "⚡"}
        parts.append(p_icons.get(persona, "🎭") + persona)
    if listening:
        parts.append("🎤")
    return " ".join(parts)


def obi_mode() -> str:
    d = _read_json(STATE_DIR / "awareness.json")
    mode = d.get("obi_mode")
    if not mode:
        return ""
    icons = {
        "active": "🧒", "calm": "🧒", "absent": "💤",
        "at-school": "🏫", "at-mums": "🏠",
        "possibly-overloaded": "⚡", "unknown": "",
    }
    icon = icons.get(mode, "")
    return f"{icon}{mode}" if icon else ""


def weather() -> str:
    d = _read_json(STATE_DIR / "awareness.json")
    w = d.get("weather", {})
    if not w:
        return ""
    temp = w.get("temp_c")
    if temp is None:
        return ""
    return f"🌡️{temp}°C"


def social() -> str:
    d = _read_json(STATE_DIR / "px-post-status.json")
    if not d:
        return ""
    bsky = d.get("bluesky_ok", False)
    total = d.get("total_posted", 0)
    queue = d.get("queue_depth", 0)
    icon = "📫" if bsky else "📭"
    return f"{icon}{total}↑{queue}⏳"


def services() -> str:
    labels = ["alive", "mind", "wake", "api", "post"]
    svc_names = ["px-alive", "px-mind", "px-wake-listen", "px-api-server", "px-post"]
    try:
        # Single systemctl call for all services
        r = subprocess.run(
            ["systemctl", "is-active"] + svc_names,
            capture_output=True, text=True, timeout=2,
        )
        results = r.stdout.strip().splitlines()
    except Exception:
        results = []
    states = []
    for i, label in enumerate(labels):
        active = i < len(results) and results[i].strip() == "active"
        states.append(("●" if active else "○") + label)
    return " ".join(states)


def claude_budget() -> str:
    """Claude session budget: used/cap today."""
    try:
        from pxh.claude_session import _load_session_log, _today_entries, DAILY_CAP, SESSION_LOG
        entries = _load_session_log()
        today = _today_entries(entries)
        used = len(today)
        return f"🧠{used}/{DAILY_CAP}"
    except Exception:
        return ""


def main() -> None:
    parts = []

    # Session persona / listening
    s = session()
    if s:
        parts.append(s)

    # px-mind mood
    m = mood()
    if m:
        parts.append(m)

    # Obi
    o = obi_mode()
    if o:
        parts.append(o)

    # Sonar proximity
    sr = sonar()
    if sr:
        parts.append(sr)

    # Weather
    w = weather()
    if w:
        parts.append(w)

    # Hardware
    parts.append(cpu_temp() + throttle())
    parts.append(mem())
    parts.append(battery())

    # Claude budget
    cb = claude_budget()
    if cb:
        parts.append(cb)

    # Social
    sc = social()
    if sc:
        parts.append(sc)

    # Services
    parts.append(services())

    print(" │ ".join(parts))


if __name__ == "__main__":
    main()
