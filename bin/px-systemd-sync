#!/usr/bin/env python3
"""Check or reconcile the child-facing systemd deployment."""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import shutil
import subprocess
import tempfile
from pathlib import Path


PROJECT_ROOT = Path(os.environ.get("PROJECT_ROOT", Path(__file__).resolve().parents[1]))
DEFAULT_SOURCE = PROJECT_ROOT / "systemd"
DEFAULT_TARGET = Path("/etc/systemd/system")
DENIED_CHILD_UNITS = frozenset({"px-tts-glados.service"})


def _digest(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def _manifest(source: Path) -> dict[str, Path]:
    units = {}
    for pattern in ("*.service", "*.timer"):
        for path in sorted(source.glob(pattern)):
            if path.is_file():
                units[path.name] = path
    return units


def inspect(source: Path, target: Path) -> dict:
    units = _manifest(source)
    statuses = {}
    for name, source_path in units.items():
        installed_path = target / name
        if not installed_path.exists():
            status = "missing"
        elif _digest(source_path) == _digest(installed_path):
            status = "current"
        else:
            status = "drift"
        statuses[name] = status

    denied = sorted(name for name in DENIED_CHILD_UNITS if (target / name).exists())
    return {
        "status": "ok" if all(v == "current" for v in statuses.values()) and not denied else "drift",
        "profile": "child",
        "units": statuses,
        "denied_installed": denied,
    }


def _atomic_install(source: Path, target: Path) -> None:
    target.parent.mkdir(parents=True, exist_ok=True)
    fd, temporary = tempfile.mkstemp(prefix=f".{target.name}.", dir=target.parent)
    try:
        with os.fdopen(fd, "wb") as output:
            output.write(source.read_bytes())
            output.flush()
            os.fsync(output.fileno())
        os.chmod(temporary, 0o644)
        os.replace(temporary, target)
    finally:
        try:
            os.unlink(temporary)
        except FileNotFoundError:
            pass


def apply(source: Path, target: Path, *, systemctl: bool) -> dict:
    before = inspect(source, target)
    if systemctl:
        verification = subprocess.run(
            ["systemd-analyze", "verify", *map(str, _manifest(source).values())],
            check=False,
            capture_output=True,
            text=True,
        )
        if verification.returncode != 0:
            raise RuntimeError(f"systemd verification failed: {verification.stderr[-1000:]}")
    changed = []
    for name, source_path in _manifest(source).items():
        if before["units"][name] != "current":
            _atomic_install(source_path, target / name)
            changed.append(name)

    removed = []
    for name in before["denied_installed"]:
        if systemctl:
            disabled = subprocess.run(
                ["systemctl", "disable", "--now", name],
                check=False,
                capture_output=True,
                text=True,
            )
            if disabled.returncode != 0:
                raise RuntimeError(f"failed to disable {name}: {disabled.stderr.strip()}")
        (target / name).unlink(missing_ok=True)
        removed.append(name)

    if systemctl and (changed or removed):
        subprocess.run(["systemctl", "daemon-reload"], check=True)

    after = inspect(source, target)
    after.update({
        "changed": changed,
        "removed": removed,
        "restart_required": changed,
    })
    return after


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--apply", action="store_true", help="install checked-in child units")
    parser.add_argument("--source", type=Path, default=DEFAULT_SOURCE)
    parser.add_argument("--target", type=Path, default=DEFAULT_TARGET)
    parser.add_argument(
        "--no-systemctl",
        action="store_true",
        help=argparse.SUPPRESS,
    )
    args = parser.parse_args()

    source = args.source.resolve()
    target = args.target.resolve()
    if not source.is_dir():
        print(json.dumps({"status": "error", "error": f"source not found: {source}"}))
        return 2

    if args.apply:
        if target == DEFAULT_TARGET and os.geteuid() != 0:
            print(json.dumps({
                "status": "error",
                "error": "run with sudo to apply system units",
            }))
            return 2
        try:
            payload = apply(
                source,
                target,
                systemctl=target == DEFAULT_TARGET and not args.no_systemctl,
            )
        except (OSError, RuntimeError, subprocess.SubprocessError) as exc:
            print(json.dumps({"status": "error", "error": str(exc)}))
            return 2
    else:
        payload = inspect(source, target)

    print(json.dumps(payload, sort_keys=True))
    return 0 if payload["status"] == "ok" else 1


if __name__ == "__main__":
    raise SystemExit(main())
