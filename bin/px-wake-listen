#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

"$PROJECT_ROOT/.venv/bin/python3" - "$@" <<'PY'
"""Wake-word listener: detects wake phrase via Vosk, captures utterance, pipes to voice loop.

Flow:
  1. Grammar recognizer listens continuously for the wake word (low CPU).
  2. On detection: play ack chime, record utterance, transcribe.
  3. Run conversation loop (up to --convo-turns turns):
     a. Pipe utterance to run-voice-loop-claude --max-turns 1.
     b. Flush stale buffer, play soft follow-up chime, listen for reply.
     c. If reply detected within timeout → next turn; else → end conversation.
  4. Restart px-alive, return to step 1.
"""
import argparse
import datetime as dt
import json
import os
import audioop
import signal
import struct
import subprocess
import sys
import threading
import time
import wave
from pathlib import Path

LOG_DIR  = Path(os.environ.get("LOG_DIR",  Path.cwd() / "logs"))
LOG_FILE = Path(os.environ.get("PX_LOG_FILE", LOG_DIR / "px-wake-listen.log"))
PID_FILE = Path(os.environ.get("PX_WAKE_PID", LOG_DIR / "px-wake-listen.pid"))
PROJECT_ROOT = Path(os.environ.get("PROJECT_ROOT", Path.cwd()))

# Audio constants
MIC_RATE    = 44100  # hardware recording rate (USB mic supports 44100/48000 only)
VOSK_RATE   = 16000  # Vosk model input rate
CHUNK       = 2048   # frames per buffer at 44100 Hz (~46 ms)
CHANNELS    = 1
SILENCE_S        = 3.0    # silence after speech → end of utterance (patient — handles mid-sentence pauses)
MAX_RECORD_S     = 20.0   # hard cap on recording length
RMS_SILENCE      = 300    # RMS below this → silence
AMBIENT_WRITE_S  = 10     # write ambient sound level every N seconds
SPEECH_ONSET_RMS = 400    # RMS above this → speech started (follow-up detection)
FOLLOWUP_SILENCE_S  = 3.5  # silence threshold ending a follow-up utterance
FOLLOWUP_MAX_S      = 20.0  # hard cap for follow-up recording
FOLLOWUP_TIMEOUT_S  = 30.0  # seconds to wait for follow-up speech to begin (timeout → end session)
END_PHRASES = {"stop", "bye", "goodbye", "that's all", "done", "end", "no thanks"}

DEFAULT_MODEL = str(PROJECT_ROOT / "models" / "vosk-model-small-en-us-0.15")
DEFAULT_WAKE  = "hey robot"

# Persona config: prompt file, voice settings, and fallback chat tool
PERSONAS = {
    "vixen": {
        "prompt": str(PROJECT_ROOT / "docs" / "prompts" / "persona-vixen.md"),
        "chat_tool": str(PROJECT_ROOT / "bin" / "tool-chat-vixen"),
        "voice_env": {
            "PX_VOICE_VARIANT": "en+f4",
            "PX_VOICE_PITCH": "72",
            "PX_VOICE_RATE": "135",
        },
    },
    "gremlin": {
        "prompt": str(PROJECT_ROOT / "docs" / "prompts" / "persona-gremlin.md"),
        "chat_tool": str(PROJECT_ROOT / "bin" / "tool-chat"),
        "voice_env": {
            "PX_VOICE_VARIANT": "en+croak",
            "PX_VOICE_PITCH": "20",
            "PX_VOICE_RATE": "180",
        },
    },
}
# Legacy mapping used for utterance keyword routing
PERSONA_WAKE = {f"hey {name}": cfg["chat_tool"] for name, cfg in PERSONAS.items()}
DEFAULT_VOICE_CMD = str(PROJECT_ROOT / "bin" / "run-voice-loop-claude")
DEFAULT_STT_MODEL = str(PROJECT_ROOT / "models" / "sherpa-onnx-streaming-zipformer-en-2023-06-26")
DEFAULT_SENSEVOICE_MODEL = str(PROJECT_ROOT / "models" / "sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17")

def _find_whisper_model() -> str:
    """Auto-detect the faster-whisper-base.en snapshot directory."""
    base = PROJECT_ROOT / "models" / "whisper" / "models--Systran--faster-whisper-base.en" / "snapshots"
    if base.exists():
        snaps = sorted(base.iterdir())
        if snaps:
            return str(snaps[-1])
    return ""

DEFAULT_WHISPER_MODEL = _find_whisper_model()


def log(msg: str) -> None:
    ts = dt.datetime.now().isoformat(timespec="seconds")
    LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
    line = f"{ts} [wake] {msg}"
    with LOG_FILE.open("a", encoding="utf-8") as f:
        f.write(line + "\n")
    print(line, flush=True)


def rms(data: bytes) -> float:
    """Compute RMS amplitude of 16-bit PCM chunk."""
    count = len(data) // 2
    if count == 0:
        return 0.0
    shorts = struct.unpack(f"{count}h", data)
    return (sum(s * s for s in shorts) / count) ** 0.5


def find_input_device(pa, preferred_name: str = "") -> int:
    """Return PyAudio device index for the best available input.

    Search order:
      1. Direct match on preferred_name substring (e.g. 'USB')
      2. 'pulse' device (PulseAudio — routes USB mic when ALSA direct unavailable)
      3. First device with input channels
    """
    best = None
    pulse_idx = None
    for i in range(pa.get_device_count()):
        info = pa.get_device_info_by_index(i)
        if info["maxInputChannels"] < 1:
            continue
        name_lower = info["name"].lower()
        if preferred_name and preferred_name.lower() in name_lower:
            return i
        if name_lower == "pulse":
            pulse_idx = i
        if best is None:
            best = i
    result = pulse_idx if pulse_idx is not None else best
    if result is None:
        raise RuntimeError("No input audio device found")
    return result


def _play_tone_sequence(freqs_durs: list, device: str = "", amplitude: int = 22000) -> None:
    """Render and play a sequence of (freq_hz, duration_s) sine tones with 10ms fade and 40ms gap."""
    try:
        from robot_hat import enable_speaker
        enable_speaker()
    except Exception:
        pass
    try:
        import math, wave as wv, tempfile
        all_samples: list[int] = []
        fade_n = int(MIC_RATE * 0.010)  # 10ms linear fade to avoid clicks
        gap_n  = int(MIC_RATE * 0.040)  # 40ms silence between tones
        for freq, dur in freqs_durs:
            n = int(MIC_RATE * dur)
            for t in range(n):
                s = int(amplitude * math.sin(2 * math.pi * freq * t / MIC_RATE))
                if t < fade_n:
                    s = int(s * t / fade_n)
                elif t > n - fade_n:
                    s = int(s * (n - t) / fade_n)
                all_samples.append(s)
            all_samples.extend([0] * gap_n)
        with tempfile.NamedTemporaryFile(suffix=".wav", delete=False) as tf:
            with wv.open(tf.name, "wb") as wf:
                wf.setnchannels(1)
                wf.setsampwidth(2)
                wf.setframerate(MIC_RATE)
                wf.writeframes(struct.pack(f"{len(all_samples)}h", *all_samples))
            tmp = tf.name
        cmd = ["aplay", "-q"]
        if device:
            cmd += ["-D", device]
        cmd.append(tmp)
        subprocess.run(cmd, check=False, capture_output=True)
        os.unlink(tmp)
    except Exception as exc:
        log(f"tone error: {exc}")


def play_chime(device: str = "") -> None:
    """Single 440 Hz tone — wake word acknowledged, starting to record."""
    _play_tone_sequence([(440, 0.25)], device, amplitude=28000)


def play_chime_listening(device: str = "") -> None:
    """Two ascending tones (600→900 Hz) — 'I'm listening, your turn'."""
    _play_tone_sequence([(600, 0.10), (900, 0.13)], device, amplitude=18000)


def play_chime_processing(device: str = "") -> None:
    """Descending double-blip (800→500 Hz) — 'Got it, I'm thinking'."""
    _play_tone_sequence([(800, 0.07), (500, 0.07)], device, amplitude=15000)


def play_chime_timeout(device: str = "") -> None:
    """Three descending tones (700→500→300 Hz) — 'Stopping, session ended'."""
    _play_tone_sequence([(700, 0.09), (500, 0.09), (300, 0.14)], device, amplitude=13000)


def resample(data: bytes, state=None):
    """Downsample 44100 Hz 16-bit mono PCM to 16000 Hz. Returns (resampled_bytes, new_state)."""
    resampled, new_state = audioop.ratecv(data, 2, 1, MIC_RATE, VOSK_RATE, state)
    return resampled, new_state


def transcribe(model, audio_bytes: bytes) -> str:
    """Vosk transcription fallback for 44100 Hz PCM (resampled to 16kHz internally)."""
    import vosk
    rec = vosk.KaldiRecognizer(model, VOSK_RATE)
    chunk_size = MIC_RATE * 2  # 1 s of 44100 Hz 16-bit
    state = None
    for i in range(0, len(audio_bytes), chunk_size):
        chunk = audio_bytes[i:i + chunk_size]
        resampled, state = resample(chunk, state)
        rec.AcceptWaveform(resampled)
    result = json.loads(rec.FinalResult())
    return result.get("text", "").strip()


def load_stt_model(model_dir: str):
    """Load sherpa-onnx streaming Zipformer recognizer. Returns None if unavailable."""
    try:
        import sherpa_onnx
        import glob as _glob
        path = Path(model_dir)
        if not path.exists():
            return None

        def _pick(pattern, int8_pattern):
            """Return int8 variant if present, else full-precision."""
            hits = sorted(_glob.glob(str(path / int8_pattern)))
            if hits:
                return hits[0]
            hits = sorted(_glob.glob(str(path / pattern)))
            return hits[0] if hits else None

        encoder = _pick("encoder*.onnx", "encoder*.int8.onnx")
        decoder = _pick("decoder*.onnx", "decoder*.int8.onnx")
        joiner  = _pick("joiner*.onnx",  "joiner*.int8.onnx")
        tokens  = str(path / "tokens.txt")
        if not all([encoder, decoder, joiner]) or not Path(tokens).exists():
            return None

        kwargs = dict(
            tokens=tokens,
            encoder=encoder,
            decoder=decoder,
            joiner=joiner,
            num_threads=4,
            sample_rate=VOSK_RATE,
            feature_dim=80,
            decoding_method="greedy_search",
            provider="cpu",
        )
        return sherpa_onnx.OnlineRecognizer.from_transducer(**kwargs)
    except Exception as exc:
        try:
            import datetime as _dt
            print(f"{_dt.datetime.now().isoformat(timespec='seconds')} [wake] STT load error: {exc}", flush=True)
        except Exception:
            pass
        return None


def transcribe_sherpa(stt, audio_bytes: bytes) -> str:
    """Transcribe 44100 Hz PCM using sherpa-onnx Zipformer (resamples to 16kHz internally)."""
    import numpy as np
    resampled, _ = audioop.ratecv(audio_bytes, 2, 1, MIC_RATE, VOSK_RATE, None)
    samples = np.frombuffer(resampled, dtype=np.int16).astype(np.float32) / 32768.0
    # Append 0.5 s silence tail to flush final tokens through the decoder
    tail = np.zeros(int(VOSK_RATE * 0.5), dtype=np.float32)
    stream = stt.create_stream()
    stream.accept_waveform(VOSK_RATE, samples)
    stream.accept_waveform(VOSK_RATE, tail)
    stream.input_finished()
    while stt.is_ready(stream):
        stt.decode_stream(stream)
    return stt.get_result(stream).strip()


def load_whisper_model(model_dir: str):
    """Load faster-whisper model for utterance transcription. Returns None if unavailable.

    faster-whisper was trained on diverse global English data and handles
    Australian/British/Irish accents significantly better than the US-English
    Zipformer. Uses int8 quantisation for CPU efficiency (~5 s load, ~1-2 s RTF).
    """
    try:
        from faster_whisper import WhisperModel
        path = Path(model_dir)
        if not path.exists():
            return None
        model = WhisperModel(str(path), device="cpu", compute_type="int8")
        return model
    except Exception as exc:
        try:
            import datetime as _dt
            print(f"{_dt.datetime.now().isoformat(timespec='seconds')} [wake] Whisper load error: {exc}", flush=True)
        except Exception:
            pass
        return None


def transcribe_whisper(whisper, audio_bytes: bytes) -> str:
    """Transcribe 44100 Hz PCM using faster-whisper (resampled to 16kHz).

    Whisper handles Australian English well due to diverse multilingual training data.
    Key settings to prevent hallucination on short/noisy mic input:
    - temperature=0: greedy decoding, no sampling randomness
    - condition_on_previous_text=False: no hallucinated context carry-over
    - no_speech_threshold=0.6: suppress hallucinated output on silence
    - vad_filter=False: don't clip utterance-start (we already gate on RMS onset)
    """
    import numpy as np
    resampled, _ = audioop.ratecv(audio_bytes, 2, 1, MIC_RATE, VOSK_RATE, None)
    samples = np.frombuffer(resampled, dtype=np.int16).astype(np.float32) / 32768.0
    segments, _info = whisper.transcribe(
        samples,
        language="en",
        beam_size=5,
        temperature=0,
        condition_on_previous_text=False,
        no_speech_threshold=0.6,
        vad_filter=False,
    )
    text = " ".join(s.text.strip() for s in segments).strip()
    # Strip non-ASCII chars (curly quotes, em-dashes are OK; CJK blocks are hallucination)
    ascii_text = text.encode("ascii", "ignore").decode("ascii").strip()
    if text != ascii_text:
        # If stripping removed most of the content, it was hallucination
        if len(ascii_text) < len(text) * 0.5:
            log(f"whisper hallucination (non-ASCII dominant): {text!r}")
            return ""
        log(f"whisper stripped non-ASCII: {text!r} → {ascii_text!r}")
        text = ascii_text
    # Reject common Whisper phantom outputs on near-silence
    PHANTOM_PHRASES = {
        "thank you", "thank you.", "thanks for watching", "thanks for watching.",
        "you", "the", "bye", "bye.", "so", "i'm sorry",
        "subscribe", "like and subscribe",
    }
    if text.lower().strip(".!? ") in PHANTOM_PHRASES:
        log(f"whisper hallucination (phantom): {text!r}")
        return ""
    # Reject repetitive hallucinations ("Okay. Okay. Okay. ...")
    words = text.lower().split()
    if len(words) >= 6:
        unique_ratio = len(set(words)) / len(words)
        if unique_ratio < 0.3:
            log(f"whisper hallucination (repetitive): {text!r}")
            return ""
    return text


def load_sensevoice(model_dir: str):
    """Load SenseVoice-Small via sherpa-onnx OfflineRecognizer. Returns None if unavailable.

    SenseVoice is non-autoregressive — processes entire utterance in a single forward
    pass with no beam search. Significantly faster than autoregressive models (Whisper).
    """
    try:
        import sherpa_onnx
        path = Path(model_dir)
        if not path.exists():
            return None
        model = str(path / "model.int8.onnx")
        tokens = str(path / "tokens.txt")
        if not Path(model).exists() or not Path(tokens).exists():
            return None
        return sherpa_onnx.OfflineRecognizer.from_sense_voice(
            model=model,
            tokens=tokens,
            num_threads=4,
            sample_rate=VOSK_RATE,
            language="en",
            use_itn=False,
            provider="cpu",
        )
    except Exception as exc:
        try:
            import datetime as _dt
            print(f"{_dt.datetime.now().isoformat(timespec='seconds')} [wake] SenseVoice load error: {exc}", flush=True)
        except Exception:
            pass
        return None


import re as _sensevoice_re
_SENSEVOICE_TAG_RE = _sensevoice_re.compile(r"<\|[^|]+\|>")

def transcribe_sensevoice(sv, audio_bytes: bytes) -> str:
    """Transcribe 44100 Hz PCM using SenseVoice (non-autoregressive, single forward pass).

    Strips emotion/event tags (<|HAPPY|>, <|Speech|>, etc.) and applies
    the same anti-hallucination filters as Whisper.
    """
    import numpy as np
    resampled, _ = audioop.ratecv(audio_bytes, 2, 1, MIC_RATE, VOSK_RATE, None)
    samples = np.frombuffer(resampled, dtype=np.int16).astype(np.float32) / 32768.0

    stream = sv.create_stream()
    stream.accept_waveform(VOSK_RATE, samples)
    sv.decode_stream(stream)
    text = stream.result.text.strip()

    # Strip SenseVoice special tags: <|HAPPY|>, <|NEUTRAL|>, <|Speech|>, etc.
    text = _SENSEVOICE_TAG_RE.sub("", text).strip()

    # Non-ASCII dominant → hallucination (CJK leaking through)
    ascii_text = text.encode("ascii", "ignore").decode("ascii").strip()
    if text != ascii_text:
        if len(ascii_text) < len(text) * 0.5:
            log(f"sensevoice hallucination (non-ASCII dominant): {text!r}")
            return ""
        log(f"sensevoice stripped non-ASCII: {text!r} → {ascii_text!r}")
        text = ascii_text

    # Phantom phrase rejection
    PHANTOM_PHRASES = {
        "thank you", "thank you.", "thanks for watching", "thanks for watching.",
        "you", "the", "bye", "bye.", "so", "i'm sorry",
        "subscribe", "like and subscribe",
    }
    if text.lower().strip(".!? ") in PHANTOM_PHRASES:
        log(f"sensevoice hallucination (phantom): {text!r}")
        return ""

    # Repetitive text rejection
    words = text.lower().split()
    if len(words) >= 6:
        unique_ratio = len(set(words)) / len(words)
        if unique_ratio < 0.3:
            log(f"sensevoice hallucination (repetitive): {text!r}")
            return ""

    return text


def _alive_pid() -> int | None:
    """Return px-alive PID if running, else None."""
    try:
        pid = int(PID_FILE.parent.joinpath("px-alive.pid").read_text().strip())
    except Exception:
        return None
    # Use /proc to check existence — os.kill(pid, 0) raises PermissionError for
    # root-owned processes when running as pi, which we must not treat as "dead".
    return pid if Path(f"/proc/{pid}").exists() else None


def _stop_alive() -> int | None:
    """Send SIGTERM to px-alive so it releases GPIO. Returns PID if killed."""
    pid = _alive_pid()
    if pid:
        log(f"pausing px-alive (pid={pid}) for voice turn")
        try:
            # px-alive runs as root; use sudo kill so pi user can signal it
            subprocess.run(["sudo", "-n", "kill", str(pid)], check=False, capture_output=True)
            time.sleep(2.0)  # wait for Picarx.close() to release GPIO
        except Exception:
            pass
    return pid


def _restart_alive() -> None:
    """Restart px-alive in background."""
    alive_script = PROJECT_ROOT / "bin" / "px-alive"
    if alive_script.exists():
        log("restarting px-alive")
        subprocess.Popen(
            ["sudo", "-n", str(alive_script)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )



def flush_stream(stream, chunks: int = 15) -> None:
    """Discard buffered audio that built up while the robot was speaking."""
    for _ in range(chunks):
        try:
            stream.read(CHUNK, exception_on_overflow=False)
        except Exception:
            break


def record_utterance(stream, max_s: float, silence_s: float) -> bytes:
    """Record from stream until silence_s of quiet or max_s total. Returns raw PCM bytes."""
    captured = []
    silence_frames = 0
    silence_limit = int(silence_s * MIC_RATE / CHUNK)
    max_frames = int(max_s * MIC_RATE / CHUNK)
    for _ in range(max_frames):
        chunk = stream.read(CHUNK, exception_on_overflow=False)
        captured.append(chunk)
        if rms(chunk) < RMS_SILENCE:
            silence_frames += 1
            if silence_frames >= silence_limit:
                break
        else:
            silence_frames = 0
    return b"".join(captured)


def _do_transcribe(audio_bytes: bytes, model, stt=None, whisper=None, sensevoice=None) -> str:
    """Transcribe audio using the best available backend: sensevoice > whisper > sherpa > vosk."""
    if sensevoice is not None:
        return transcribe_sensevoice(sensevoice, audio_bytes)
    if whisper is not None:
        return transcribe_whisper(whisper, audio_bytes)
    if stt is not None:
        return transcribe_sherpa(stt, audio_bytes)
    return transcribe(model, audio_bytes)


def record_followup(stream, model, stt=None, whisper=None, sensevoice=None,
                    aplay_device: str = "") -> str:
    """Wait up to FOLLOWUP_TIMEOUT_S for speech onset, then record and transcribe.

    Plays a processing beep after recording ends (before STT) so the user knows
    their input was captured. Returns transcribed text, or '' if no speech detected.
    """
    timeout_chunks = int(FOLLOWUP_TIMEOUT_S * MIC_RATE / CHUNK)
    # Phase 1: wait for speech onset
    for _ in range(timeout_chunks):
        data = stream.read(CHUNK, exception_on_overflow=False)
        if rms(data) >= SPEECH_ONSET_RMS:
            # Speech started — record the full utterance
            onset = [data]
            rest = record_utterance(stream, FOLLOWUP_MAX_S, FOLLOWUP_SILENCE_S)
            audio = b"".join(onset) + rest
            play_chime_processing(aplay_device)
            return _do_transcribe(audio, model, stt, whisper, sensevoice)
    return ""  # timeout — no speech


def run_persona_conversation(persona_name: str, initial_text: str, dry: bool,
                             stream, model, aplay_device: str, max_turns: int,
                             voice_cmd: str, stt=None, whisper=None, sensevoice=None) -> None:
    """Run a multi-turn conversation using Claude voice loop with a persona prompt.

    Uses the full Claude tool-calling pipeline but with an alternate system
    prompt (persona personality) and voice settings (distinct espeak voice).
    Falls back to the raw chat tool if the persona prompt file is missing.
    """
    if not initial_text:
        log("empty transcript — skipping persona conversation")
        return

    cfg = PERSONAS.get(persona_name)
    if not cfg:
        log(f"unknown persona: {persona_name}")
        return

    if dry:
        log(f"dry_run: persona {persona_name} with {initial_text!r} ({max_turns} turns max)")
        return

    had_alive = _stop_alive()
    env = os.environ.copy()
    env["PX_DRY"] = "0"

    # Set persona voice so all tool_voice/tool_perform calls use the right voice
    for k, v in cfg["voice_env"].items():
        env[k] = v

    # Use Ollama chat tool directly for persona conversations
    log(f"persona {persona_name}: using Ollama chat tool")

    current_text = initial_text
    try:
        for turn in range(1, max_turns + 1):
            log(f"persona {persona_name} turn {turn}/{max_turns}: {current_text!r}")

            env["PX_TEXT"] = current_text
            result = subprocess.run(
                [cfg["chat_tool"]], capture_output=True, text=True, check=False, env=env,
            )
            log(f"persona chat tool rc={result.returncode}")

            if result.returncode != 0:
                log(f"persona error (rc={result.returncode})")
                break

            if turn >= max_turns:
                log("persona conversation: max turns reached")
                play_chime_timeout(aplay_device)
                break

            flush_stream(stream)
            play_chime_listening(aplay_device)
            log("persona conversation: listening for follow-up...")
            follow_text = record_followup(stream, model, stt, whisper, sensevoice,
                                          aplay_device=aplay_device)

            if not follow_text:
                log("persona conversation: silence — ending")
                play_chime_timeout(aplay_device)
                break

            log(f"persona conversation: follow-up: {follow_text!r}")

            if any(phrase in follow_text.lower() for phrase in END_PHRASES):
                log("persona conversation: end phrase — final turn")
                env["PX_TEXT"] = follow_text
                subprocess.run(
                    [cfg["chat_tool"]], capture_output=True, text=True, check=False, env=env,
                )
                play_chime_timeout(aplay_device)
                break

            current_text = follow_text

    finally:
        if had_alive:
            _restart_alive()


def run_conversation(initial_text: str, voice_cmd: str, dry: bool,
                     stream, model, aplay_device: str, max_turns: int, stt=None, whisper=None, sensevoice=None) -> None:
    """Run a multi-turn conversation. Blocks wake detection for its duration."""
    if not initial_text:
        log("empty transcript — skipping")
        return
    if dry:
        log(f"dry_run: conversation with {initial_text!r} ({max_turns} turns max)")
        return

    had_alive = _stop_alive()
    env = os.environ.copy()
    env["PX_DRY"] = "0"

    current_text = initial_text
    try:
        for turn in range(1, max_turns + 1):
            log(f"conversation turn {turn}/{max_turns}: {current_text!r}")
            result = subprocess.run(
                [voice_cmd, "--max-turns", "3"],
                input=current_text,
                text=True,
                capture_output=False,
                env=env,
                check=False,
            )
            log(f"voice loop rc={result.returncode}")

            if turn >= max_turns:
                log("conversation: max turns reached")
                play_chime_timeout(aplay_device)
                break

            # Flush stale audio buffered while robot was speaking
            flush_stream(stream)

            # Ascending chime: "your turn, I'm listening"
            play_chime_listening(aplay_device)

            # Listen for follow-up (patient: 30s onset wait, 3.5s in-speech silence)
            log("conversation: listening for follow-up...")
            follow_text = record_followup(stream, model, stt, whisper, sensevoice,
                                          aplay_device=aplay_device)

            if not follow_text:
                log("conversation: silence — ending")
                play_chime_timeout(aplay_device)
                break

            log(f"conversation: follow-up: {follow_text!r}")

            # Check for end-of-conversation phrases
            if any(phrase in follow_text.lower() for phrase in END_PHRASES):
                log("conversation: end phrase — one final turn")
                subprocess.run(
                    [voice_cmd, "--max-turns", "3"],
                    input=follow_text,
                    text=True,
                    capture_output=False,
                    env=env,
                    check=False,
                )
                play_chime_timeout(aplay_device)
                break

            current_text = follow_text

    finally:
        if had_alive:
            _restart_alive()


def listen_loop(pa, model, args, stt=None, whisper=None, sensevoice=None) -> None:
    """Main listen loop: wake-word detect → conversation → return to listening."""
    import vosk
    import pyaudio

    device_idx = find_input_device(pa, args.mic)
    log(f"using mic device idx={device_idx} ({pa.get_device_info_by_index(device_idx)['name']})")

    # Grammar recognizer for wake word (fast, low-CPU)
    wake_phrase = args.wake_word.lower().strip()
    grammar = json.dumps([wake_phrase, "[unk]"])
    wake_rec = vosk.KaldiRecognizer(model, VOSK_RATE, grammar)
    resample_state = None  # audioop.ratecv state for wake recognizer

    stream = pa.open(
        format=pyaudio.paInt16,
        channels=CHANNELS,
        rate=MIC_RATE,
        input=True,
        input_device_index=device_idx,
        frames_per_buffer=CHUNK,
    )
    stream.start_stream()
    persona_names = [k.split()[-1] for k in PERSONA_WAKE]
    log(f"listening for wake word: '{wake_phrase}' (say 'vixen' or 'gremlin' after wake to switch persona)")

    # Ambient sound tracking for px-mind
    STATE_DIR = Path(os.environ.get("PX_STATE_DIR", PROJECT_ROOT / "state"))
    AMBIENT_FILE = STATE_DIR / "ambient_sound.json"
    _ambient_rms_sum = 0
    _ambient_rms_count = 0
    _ambient_last_write = time.monotonic()

    try:
        while True:
            data = stream.read(CHUNK, exception_on_overflow=False)
            resampled_data, resample_state = resample(data, resample_state)

            # Track ambient sound level (rolling RMS)
            try:
                chunk_rms = audioop.rms(data, 2)
                _ambient_rms_sum += chunk_rms
                _ambient_rms_count += 1
                _now_mono = time.monotonic()
                if (_now_mono - _ambient_last_write) >= AMBIENT_WRITE_S and _ambient_rms_count > 0:
                    avg_rms = _ambient_rms_sum // _ambient_rms_count
                    level = "silent" if avg_rms < 200 else "quiet" if avg_rms < 500 else "moderate" if avg_rms < 1500 else "loud"
                    try:
                        from pxh.time import utc_timestamp as _utc_ts
                        STATE_DIR.mkdir(parents=True, exist_ok=True)
                        _tmp = AMBIENT_FILE.with_suffix(".tmp")
                        _tmp.write_text(json.dumps({
                            "ts": _utc_ts(), "rms": avg_rms, "level": level,
                        }), encoding="utf-8")
                        _tmp.rename(AMBIENT_FILE)
                    except Exception:
                        pass
                    _ambient_rms_sum = 0
                    _ambient_rms_count = 0
                    _ambient_last_write = _now_mono
            except Exception:
                pass

            if wake_rec.AcceptWaveform(resampled_data):
                result = json.loads(wake_rec.Result())
                text = result.get("text", "")
                if text and text != "[unk]":
                    log(f"vosk heard: {text!r}")

                if wake_phrase in text:
                    log(f"wake word detected: {text!r}")
                    # Chime in background while we start recording
                    threading.Thread(target=play_chime, args=(args.aplay_device,), daemon=True).start()

                    # --- Capture initial utterance ---
                    log("recording...")
                    audio_bytes = record_utterance(stream, MAX_RECORD_S, SILENCE_S)
                    chunks_n = len(audio_bytes) // (CHUNK * 2)
                    log(f"captured {chunks_n} chunks ({chunks_n * CHUNK / MIC_RATE:.1f}s)")
                    # Processing beep: "got it, I'm thinking" — fires before STT + LLM
                    play_chime_processing(args.aplay_device)
                    text_out = _do_transcribe(audio_bytes, model, stt, whisper, sensevoice)
                    log(f"utterance: {text_out!r}")

                    # Log transcript to session history for px-mind conversation digestion
                    if text_out:
                        try:
                            from pxh.state import update_session as _update_session
                            _update_session(history_entry={
                                "event": "wake_transcript",
                                "text": text_out[:500],
                            })
                        except Exception:
                            pass

                    # Check session for persistent persona (set via API)
                    from pxh.state import load_session as _load_session
                    session_persona = (_load_session().get("persona") or "").lower().strip()
                    
                    # Route: session persona > utterance keyword > default claude
                    routed_persona = None
                    utterance_lower = text_out.lower()
                    
                    if session_persona and session_persona in PERSONAS:
                        routed_persona = session_persona
                        log(f"persona from session: {session_persona}")
                        # Still strip persona name from utterance if present
                        import re as _re
                        for pn in PERSONAS:
                            if pn in utterance_lower:
                                utterance_lower = _re.sub(
                                    rf"\b(talk to |ask |hey |speak to |call )?{pn}\b[,:]?\s*",
                                    "", utterance_lower, count=1,
                                ).strip()
                        if utterance_lower:
                            text_out = utterance_lower
                    else:
                        # Fallback: check utterance for persona keyword
                        for persona_name in PERSONAS:
                            if persona_name in utterance_lower:
                                routed_persona = persona_name
                                # Strip the persona name from the utterance so it's clean input
                                import re as _re
                                clean_utterance = _re.sub(
                                    rf"\b(talk to |ask |hey |speak to |call )?{persona_name}\b[,:]?\s*",
                                    "", utterance_lower, count=1,
                                ).strip()
                                if not clean_utterance:
                                    clean_utterance = "hello"
                                log(f"persona routed: {persona_name} (utterance: {clean_utterance!r})")
                                text_out = clean_utterance
                                break

                    if routed_persona:
                        # --- Persona conversation (Claude voice loop + persona prompt) ---
                        run_persona_conversation(
                            routed_persona, text_out, args.dry_run,
                            stream, model, args.aplay_device, args.convo_turns,
                            args.voice_cmd, stt, whisper, sensevoice,
                        )
                    else:
                        # --- Standard Claude conversation ---
                        run_conversation(
                            text_out, args.voice_cmd, args.dry_run,
                            stream, model, args.aplay_device, args.convo_turns, stt, whisper, sensevoice,
                        )

                    # Reset wake recognizer after conversation ends
                    wake_rec = vosk.KaldiRecognizer(model, VOSK_RATE, grammar)
                    resample_state = None
                    log(f"listening for wake word: '{wake_phrase}'")

    finally:
        stream.stop_stream()
        stream.close()


def main(argv) -> int:
    parser = argparse.ArgumentParser(description="Wake-word listener daemon")
    parser.add_argument("--wake-word",     default=DEFAULT_WAKE,
                        help="Wake phrase to listen for (default: 'hey robot')")
    parser.add_argument("--model-dir",     default=DEFAULT_MODEL,
                        help="Path to Vosk model directory (wake word grammar)")
    parser.add_argument("--stt-model-dir", default=DEFAULT_STT_MODEL,
                        help="Path to sherpa-onnx Zipformer model directory for utterance STT (fallback)")
    parser.add_argument("--sensevoice-model", default=DEFAULT_SENSEVOICE_MODEL,
                        help="Path to SenseVoice-Small model dir (fastest STT, non-autoregressive)")
    parser.add_argument("--whisper-model", default=DEFAULT_WHISPER_MODEL,
                        help="Path to faster-whisper model snapshot dir (fallback STT, best AU accent support)")
    parser.add_argument("--mic",           default="USB",
                        help="Substring to match in mic device name (default: USB)")
    parser.add_argument("--aplay-device",  default="",
                        help="ALSA device for chime output (default: system default)")
    parser.add_argument("--voice-cmd",     default=DEFAULT_VOICE_CMD,
                        help="Voice loop command to pipe utterances to")
    parser.add_argument("--convo-turns",   type=int, default=5,
                        help="Max follow-up turns per conversation (default: 5)")
    parser.add_argument("--dry-run",       action="store_true",
                        help="Detect and transcribe but do not run voice loop")
    args = parser.parse_args(argv)

    # PID file
    PID_FILE.parent.mkdir(parents=True, exist_ok=True)
    PID_FILE.write_text(str(os.getpid()))
    persona_names = list(PERSONAS.keys())
    log(f"starting pid={os.getpid()} dry={args.dry_run}")
    log(f"personas available: {', '.join(persona_names)} (say name after wake word)")

    def _shutdown(sig, _frame):
        log(f"signal {sig} — stopping")
        try:
            PID_FILE.unlink(missing_ok=True)
        except Exception:
            pass
        sys.exit(0)

    signal.signal(signal.SIGTERM, _shutdown)
    signal.signal(signal.SIGINT,  _shutdown)

    # Validate model
    model_path = Path(args.model_dir)
    if not model_path.exists():
        log(f"Vosk model not found at {model_path}")
        log("Download: wget https://alphacephei.com/vosk/models/vosk-model-small-en-us-0.15.zip")
        log("Then: unzip -d models/ models/vosk-model-small-en-us.zip")
        return 1

    try:
        import vosk
        import pyaudio
    except ImportError as exc:
        log(f"missing dependency: {exc}")
        return 1

    vosk.SetLogLevel(-1)  # suppress Kaldi verbosity
    log(f"loading Vosk model {model_path} ...")
    model = vosk.Model(str(model_path))
    log("Vosk model loaded")

    # Load SenseVoice (fastest: non-autoregressive single-pass, ~228MB int8)
    sensevoice = None
    if args.sensevoice_model:
        log(f"loading SenseVoice model {args.sensevoice_model} ...")
        sensevoice = load_sensevoice(args.sensevoice_model)
        if sensevoice is not None:
            log("SenseVoice model loaded (int8, non-autoregressive — fastest STT)")
        else:
            log("SenseVoice model not available — will try Whisper")

    # Load faster-whisper as fallback (best AU accent support)
    whisper = None
    if sensevoice is None and args.whisper_model:
        log(f"loading Whisper model {args.whisper_model} ...")
        whisper = load_whisper_model(args.whisper_model)
        if whisper is not None:
            log("Whisper model loaded (faster-whisper base.en — AU accent support)")
        else:
            log("Whisper model load failed — will try sherpa-onnx")

    # Load sherpa-onnx Zipformer as last resort before Vosk
    stt = None
    if sensevoice is None and whisper is None:
        stt_path = Path(args.stt_model_dir)
        if stt_path.exists():
            log(f"loading STT model {stt_path} ...")
            stt = load_stt_model(args.stt_model_dir)
            if stt is not None:
                log("STT model loaded (sherpa-onnx Zipformer)")
            else:
                log("STT model load failed — falling back to Vosk for transcription")
        else:
            log(f"STT model dir not found ({stt_path}) — using Vosk fallback")

    backend = "sensevoice" if sensevoice else ("faster-whisper" if whisper else ("sherpa-onnx" if stt else "vosk"))
    log(f"STT backend: {backend}")

    # PyAudio init spams ALSA warnings to stderr — suppress at the fd level
    import ctypes
    try:
        _libc = ctypes.CDLL("libc.so.6")
        _devnull = os.open(os.devnull, os.O_WRONLY)
        _saved_stderr = os.dup(2)
        os.dup2(_devnull, 2)
        os.close(_devnull)
        pa = pyaudio.PyAudio()
        os.dup2(_saved_stderr, 2)
        os.close(_saved_stderr)
    except Exception:
        pa = pyaudio.PyAudio()
    try:
        listen_loop(pa, model, args, stt, whisper, sensevoice)
    except KeyboardInterrupt:
        pass
    except Exception as exc:
        log(f"fatal: {exc}")
        import traceback
        traceback.print_exc()
        return 1
    finally:
        pa.terminate()
        PID_FILE.unlink(missing_ok=True)
        log("stopped")

    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
