#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

"$PROJECT_ROOT/.venv/bin/python3" - "$@" <<'PY'
"""Wake-word listener: detects wake phrase via Vosk, captures utterance, pipes to voice loop.

Flow:
  1. Grammar recognizer listens continuously for the wake word (low CPU).
  2. On detection: play ack chime, record utterance, transcribe.
  3. Run conversation loop (up to --convo-turns turns):
     a. Pipe utterance to run-voice-loop-claude --max-turns 1.
     b. Flush stale buffer, play soft follow-up chime, listen for reply.
     c. If reply detected within timeout → next turn; else → end conversation.
  4. Restart px-alive, return to step 1.
"""
import argparse
import datetime as dt
import json
import os
import audioop
import signal
import struct
import subprocess
import sys
import threading
import time
import wave
from pathlib import Path

LOG_DIR  = Path(os.environ.get("LOG_DIR",  Path.cwd() / "logs"))
LOG_FILE = Path(os.environ.get("PX_LOG_FILE", LOG_DIR / "px-wake-listen.log"))
PID_FILE = Path(os.environ.get("PX_WAKE_PID", LOG_DIR / "px-wake-listen.pid"))
PROJECT_ROOT = Path(os.environ.get("PROJECT_ROOT", Path.cwd()))

# Audio constants
MIC_RATE    = 44100  # hardware recording rate (USB mic supports 44100/48000 only)
VOSK_RATE   = 16000  # Vosk model input rate
CHUNK       = 2048   # frames per buffer at 44100 Hz (~46 ms)
CHANNELS    = 1
SILENCE_S        = 1.5    # silence after speech → end of utterance
MAX_RECORD_S     = 8.0    # hard cap on recording length
RMS_SILENCE      = 300    # RMS below this → silence
SPEECH_ONSET_RMS = 400    # RMS above this → speech started (follow-up detection)
FOLLOWUP_SILENCE_S  = 2.0  # silence threshold ending a follow-up utterance
FOLLOWUP_MAX_S      = 8.0  # hard cap for follow-up recording
FOLLOWUP_TIMEOUT_S  = 4.0  # seconds to wait for follow-up speech to begin
END_PHRASES = {"stop", "bye", "goodbye", "that's all", "done", "end", "no thanks"}

DEFAULT_MODEL = str(PROJECT_ROOT / "models" / "vosk-model-small-en-us-0.15")
DEFAULT_WAKE  = "hey robot"

# Persona wake phrases → direct chat tool routing (bypasses full voice loop)
PERSONA_WAKE = {
    "hey siren":  "tool-chat-siren",
    "hey gremlin": "tool-chat",
}
DEFAULT_VOICE_CMD = str(PROJECT_ROOT / "bin" / "run-voice-loop-claude")
DEFAULT_STT_MODEL = str(PROJECT_ROOT / "models" / "sherpa-onnx-streaming-zipformer-en-2023-06-26")


def log(msg: str) -> None:
    ts = dt.datetime.now().isoformat(timespec="seconds")
    LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
    line = f"{ts} [wake] {msg}"
    with LOG_FILE.open("a", encoding="utf-8") as f:
        f.write(line + "\n")
    print(line, flush=True)


def rms(data: bytes) -> float:
    """Compute RMS amplitude of 16-bit PCM chunk."""
    count = len(data) // 2
    if count == 0:
        return 0.0
    shorts = struct.unpack(f"{count}h", data)
    return (sum(s * s for s in shorts) / count) ** 0.5


def find_input_device(pa, preferred_name: str = "") -> int:
    """Return PyAudio device index for the best available input.

    Search order:
      1. Direct match on preferred_name substring (e.g. 'USB')
      2. 'pulse' device (PulseAudio — routes USB mic when ALSA direct unavailable)
      3. First device with input channels
    """
    best = None
    pulse_idx = None
    for i in range(pa.get_device_count()):
        info = pa.get_device_info_by_index(i)
        if info["maxInputChannels"] < 1:
            continue
        name_lower = info["name"].lower()
        if preferred_name and preferred_name.lower() in name_lower:
            return i
        if name_lower == "pulse":
            pulse_idx = i
        if best is None:
            best = i
    result = pulse_idx if pulse_idx is not None else best
    if result is None:
        raise RuntimeError("No input audio device found")
    return result


def play_chime(device: str = "") -> None:
    """Play a short 440 Hz beep via aplay to signal wake detection."""
    try:
        from robot_hat import enable_speaker
        enable_speaker()
    except Exception:
        pass
    try:
        # Generate a short beep: 0.25 s 440 Hz sine, 16-bit 44100 Hz mono WAV
        import math, wave as wv, tempfile
        beep_f = 440
        dur    = 0.25
        n      = int(MIC_RATE * dur)
        samples = bytes(struct.pack(f"{n}h", *[
            int(28000 * math.sin(2 * math.pi * beep_f * t / MIC_RATE))
            for t in range(n)
        ]))
        with tempfile.NamedTemporaryFile(suffix=".wav", delete=False) as tf:
            with wv.open(tf.name, "wb") as wf:
                wf.setnchannels(1)
                wf.setsampwidth(2)
                wf.setframerate(MIC_RATE)
                wf.writeframes(samples)
            tmp = tf.name
        cmd = ["aplay", "-q"]
        if device:
            cmd += ["-D", device]
        cmd.append(tmp)
        subprocess.run(cmd, check=False, capture_output=True)
        os.unlink(tmp)
    except Exception as exc:
        log(f"chime error: {exc}")


def resample(data: bytes, state=None):
    """Downsample 44100 Hz 16-bit mono PCM to 16000 Hz. Returns (resampled_bytes, new_state)."""
    resampled, new_state = audioop.ratecv(data, 2, 1, MIC_RATE, VOSK_RATE, state)
    return resampled, new_state


def transcribe(model, audio_bytes: bytes) -> str:
    """Vosk transcription fallback for 44100 Hz PCM (resampled to 16kHz internally)."""
    import vosk
    rec = vosk.KaldiRecognizer(model, VOSK_RATE)
    chunk_size = MIC_RATE * 2  # 1 s of 44100 Hz 16-bit
    state = None
    for i in range(0, len(audio_bytes), chunk_size):
        chunk = audio_bytes[i:i + chunk_size]
        resampled, state = resample(chunk, state)
        rec.AcceptWaveform(resampled)
    result = json.loads(rec.FinalResult())
    return result.get("text", "").strip()


def load_stt_model(model_dir: str):
    """Load sherpa-onnx streaming Zipformer recognizer. Returns None if unavailable."""
    try:
        import sherpa_onnx
        import glob as _glob
        path = Path(model_dir)
        if not path.exists():
            return None

        def _pick(pattern, int8_pattern):
            """Return int8 variant if present, else full-precision."""
            hits = sorted(_glob.glob(str(path / int8_pattern)))
            if hits:
                return hits[0]
            hits = sorted(_glob.glob(str(path / pattern)))
            return hits[0] if hits else None

        encoder = _pick("encoder*.onnx", "encoder*.int8.onnx")
        decoder = _pick("decoder*.onnx", "decoder*.int8.onnx")
        joiner  = _pick("joiner*.onnx",  "joiner*.int8.onnx")
        tokens  = str(path / "tokens.txt")
        if not all([encoder, decoder, joiner]) or not Path(tokens).exists():
            return None

        kwargs = dict(
            tokens=tokens,
            encoder=encoder,
            decoder=decoder,
            joiner=joiner,
            num_threads=4,
            sample_rate=VOSK_RATE,
            feature_dim=80,
            decoding_method="greedy_search",
            provider="cpu",
        )
        return sherpa_onnx.OnlineRecognizer.from_transducer(**kwargs)
    except Exception as exc:
        try:
            import datetime as _dt
            print(f"{_dt.datetime.now().isoformat(timespec='seconds')} [wake] STT load error: {exc}", flush=True)
        except Exception:
            pass
        return None


def transcribe_sherpa(stt, audio_bytes: bytes) -> str:
    """Transcribe 44100 Hz PCM using sherpa-onnx Zipformer (resamples to 16kHz internally)."""
    import numpy as np
    resampled, _ = audioop.ratecv(audio_bytes, 2, 1, MIC_RATE, VOSK_RATE, None)
    samples = np.frombuffer(resampled, dtype=np.int16).astype(np.float32) / 32768.0
    # Append 0.5 s silence tail to flush final tokens through the decoder
    tail = np.zeros(int(VOSK_RATE * 0.5), dtype=np.float32)
    stream = stt.create_stream()
    stream.accept_waveform(VOSK_RATE, samples)
    stream.accept_waveform(VOSK_RATE, tail)
    stream.input_finished()
    while stt.is_ready(stream):
        stt.decode_stream(stream)
    return stt.get_result(stream).strip()


def _alive_pid() -> int | None:
    """Return px-alive PID if running, else None."""
    try:
        pid = int(PID_FILE.parent.joinpath("px-alive.pid").read_text().strip())
    except Exception:
        return None
    # Use /proc to check existence — os.kill(pid, 0) raises PermissionError for
    # root-owned processes when running as pi, which we must not treat as "dead".
    return pid if Path(f"/proc/{pid}").exists() else None


def _stop_alive() -> int | None:
    """Send SIGTERM to px-alive so it releases GPIO. Returns PID if killed."""
    pid = _alive_pid()
    if pid:
        log(f"pausing px-alive (pid={pid}) for voice turn")
        try:
            # px-alive runs as root; use sudo kill so pi user can signal it
            subprocess.run(["sudo", "-n", "kill", str(pid)], check=False, capture_output=True)
            time.sleep(2.0)  # wait for Picarx.close() to release GPIO
        except Exception:
            pass
    return pid


def _restart_alive() -> None:
    """Restart px-alive in background."""
    alive_script = PROJECT_ROOT / "bin" / "px-alive"
    if alive_script.exists():
        log("restarting px-alive")
        subprocess.Popen(
            ["sudo", "-n", str(alive_script)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )


def play_chime_followup(device: str = "") -> None:
    """Play a soft lower-pitch tone: signals 'still listening for follow-up'."""
    try:
        from robot_hat import enable_speaker
        enable_speaker()
    except Exception:
        pass
    try:
        import math, wave as wv, tempfile
        beep_f = 300
        dur    = 0.15
        n      = int(MIC_RATE * dur)
        samples = bytes(struct.pack(f"{n}h", *[
            int(16000 * math.sin(2 * math.pi * beep_f * t / MIC_RATE))
            for t in range(n)
        ]))
        with tempfile.NamedTemporaryFile(suffix=".wav", delete=False) as tf:
            with wv.open(tf.name, "wb") as wf:
                wf.setnchannels(1)
                wf.setsampwidth(2)
                wf.setframerate(MIC_RATE)
                wf.writeframes(samples)
            tmp = tf.name
        cmd = ["aplay", "-q"]
        if device:
            cmd += ["-D", device]
        cmd.append(tmp)
        subprocess.run(cmd, check=False, capture_output=True)
        os.unlink(tmp)
    except Exception as exc:
        log(f"follow-up chime error: {exc}")


def flush_stream(stream, chunks: int = 15) -> None:
    """Discard buffered audio that built up while the robot was speaking."""
    for _ in range(chunks):
        try:
            stream.read(CHUNK, exception_on_overflow=False)
        except Exception:
            break


def record_utterance(stream, max_s: float, silence_s: float) -> bytes:
    """Record from stream until silence_s of quiet or max_s total. Returns raw PCM bytes."""
    captured = []
    silence_frames = 0
    silence_limit = int(silence_s * MIC_RATE / CHUNK)
    max_frames = int(max_s * MIC_RATE / CHUNK)
    for _ in range(max_frames):
        chunk = stream.read(CHUNK, exception_on_overflow=False)
        captured.append(chunk)
        if rms(chunk) < RMS_SILENCE:
            silence_frames += 1
            if silence_frames >= silence_limit:
                break
        else:
            silence_frames = 0
    return b"".join(captured)


def record_followup(stream, model, stt=None) -> str:
    """Wait up to FOLLOWUP_TIMEOUT_S for speech onset, then record and transcribe.

    Uses sherpa-onnx (stt) if available, otherwise falls back to Vosk model.
    Returns transcribed text, or '' if no speech detected within timeout.
    """
    timeout_chunks = int(FOLLOWUP_TIMEOUT_S * MIC_RATE / CHUNK)
    # Phase 1: wait for speech onset
    for _ in range(timeout_chunks):
        data = stream.read(CHUNK, exception_on_overflow=False)
        if rms(data) >= SPEECH_ONSET_RMS:
            # Speech started — record the full utterance
            onset = [data]
            rest = record_utterance(stream, FOLLOWUP_MAX_S, FOLLOWUP_SILENCE_S)
            audio = b"".join(onset) + rest
            if stt is not None:
                return transcribe_sherpa(stt, audio)
            return transcribe(model, audio)
    return ""  # timeout — no speech


def run_persona_conversation(persona_tool: str, initial_text: str, dry: bool,
                             stream, model, aplay_device: str, max_turns: int, stt=None) -> None:
    """Run a multi-turn conversation with a persona chat tool (SIREN, GREMLIN).

    Simpler than run_conversation: calls the chat tool directly with PX_TEXT
    instead of piping through the full Claude voice loop.
    """
    if not initial_text:
        log("empty transcript — skipping persona conversation")
        return
    if dry:
        log(f"dry_run: persona {persona_tool} with {initial_text!r} ({max_turns} turns max)")
        return

    had_alive = _stop_alive()
    tool_path = str(PROJECT_ROOT / "bin" / persona_tool)
    env = os.environ.copy()
    env["PX_DRY"] = "0"

    current_text = initial_text
    try:
        for turn in range(1, max_turns + 1):
            log(f"persona {persona_tool} turn {turn}/{max_turns}: {current_text!r}")
            env["PX_TEXT"] = current_text
            result = subprocess.run(
                [tool_path], capture_output=True, text=True, check=False, env=env,
            )
            log(f"persona tool rc={result.returncode}")
            if result.returncode != 0:
                log(f"persona tool error: {result.stderr[:200]}")
                break

            if turn >= max_turns:
                log("persona conversation: max turns reached")
                break

            flush_stream(stream)
            play_chime_followup(aplay_device)
            log("persona conversation: listening for follow-up...")
            follow_text = record_followup(stream, model, stt)

            if not follow_text:
                log("persona conversation: silence — ending")
                break

            log(f"persona conversation: follow-up: {follow_text!r}")

            if any(phrase in follow_text.lower() for phrase in END_PHRASES):
                log("persona conversation: end phrase detected — final turn")
                env["PX_TEXT"] = follow_text
                subprocess.run(
                    [tool_path], capture_output=True, text=True, check=False, env=env,
                )
                break

            current_text = follow_text

    finally:
        if had_alive:
            _restart_alive()


def run_conversation(initial_text: str, voice_cmd: str, dry: bool,
                     stream, model, aplay_device: str, max_turns: int, stt=None) -> None:
    """Run a multi-turn conversation. Blocks wake detection for its duration."""
    if not initial_text:
        log("empty transcript — skipping")
        return
    if dry:
        log(f"dry_run: conversation with {initial_text!r} ({max_turns} turns max)")
        return

    had_alive = _stop_alive()
    env = os.environ.copy()
    env["PX_DRY"] = "0"

    current_text = initial_text
    try:
        for turn in range(1, max_turns + 1):
            log(f"conversation turn {turn}/{max_turns}: {current_text!r}")
            result = subprocess.run(
                [voice_cmd, "--max-turns", "3"],
                input=current_text,
                text=True,
                capture_output=False,
                env=env,
                check=False,
            )
            log(f"voice loop rc={result.returncode}")

            if turn >= max_turns:
                log("conversation: max turns reached")
                break

            # Flush stale audio buffered while robot was speaking
            flush_stream(stream)

            # Soft chime: "still listening"
            play_chime_followup(aplay_device)

            # Listen for follow-up
            log("conversation: listening for follow-up...")
            follow_text = record_followup(stream, model, stt)

            if not follow_text:
                log("conversation: silence — ending")
                break

            log(f"conversation: follow-up: {follow_text!r}")

            # Check for end-of-conversation phrases
            if any(phrase in follow_text.lower() for phrase in END_PHRASES):
                log("conversation: end phrase — one final turn")
                subprocess.run(
                    [voice_cmd, "--max-turns", "3"],
                    input=follow_text,
                    text=True,
                    capture_output=False,
                    env=env,
                    check=False,
                )
                break

            current_text = follow_text

    finally:
        if had_alive:
            _restart_alive()


def listen_loop(pa, model, args, stt=None) -> None:
    """Main listen loop: wake-word detect → conversation → return to listening."""
    import vosk
    import pyaudio

    device_idx = find_input_device(pa, args.mic)
    log(f"using mic device idx={device_idx} ({pa.get_device_info_by_index(device_idx)['name']})")

    # Grammar recognizer for wake word (fast, low-CPU)
    wake_phrase = args.wake_word.lower().strip()
    grammar = json.dumps([wake_phrase, "[unk]"])
    wake_rec = vosk.KaldiRecognizer(model, VOSK_RATE, grammar)
    resample_state = None  # audioop.ratecv state for wake recognizer

    stream = pa.open(
        format=pyaudio.paInt16,
        channels=CHANNELS,
        rate=MIC_RATE,
        input=True,
        input_device_index=device_idx,
        frames_per_buffer=CHUNK,
    )
    stream.start_stream()
    persona_names = [k.split()[-1] for k in PERSONA_WAKE]
    log(f"listening for wake word: '{wake_phrase}' (say 'siren' or 'gremlin' after wake to switch persona)")

    try:
        while True:
            data = stream.read(CHUNK, exception_on_overflow=False)
            resampled_data, resample_state = resample(data, resample_state)

            if wake_rec.AcceptWaveform(resampled_data):
                result = json.loads(wake_rec.Result())
                text = result.get("text", "")
                if text and text != "[unk]":
                    log(f"vosk heard: {text!r}")

                if wake_phrase in text:
                    log(f"wake word detected: {text!r}")
                    # Chime in background while we start recording
                    threading.Thread(target=play_chime, args=(args.aplay_device,), daemon=True).start()

                    # --- Capture initial utterance ---
                    log("recording...")
                    audio_bytes = record_utterance(stream, MAX_RECORD_S, SILENCE_S)
                    chunks_n = len(audio_bytes) // (CHUNK * 2)
                    log(f"captured {chunks_n} chunks ({chunks_n * CHUNK / MIC_RATE:.1f}s)")
                    if stt is not None:
                        text_out = transcribe_sherpa(stt, audio_bytes)
                    else:
                        text_out = transcribe(model, audio_bytes)
                    log(f"utterance: {text_out!r}")

                    # Route by keyword in utterance: "siren", "gremlin" → persona
                    # e.g. "talk to siren", "ask gremlin", "siren what's up"
                    routed_persona = None
                    utterance_lower = text_out.lower()
                    for keyword, persona_tool in PERSONA_WAKE.items():
                        # PERSONA_WAKE keys are "hey siren" etc — extract the name
                        persona_name = keyword.split()[-1]
                        if persona_name in utterance_lower:
                            routed_persona = persona_tool
                            # Strip the persona name from the utterance so it's clean input
                            import re as _re
                            clean_utterance = _re.sub(
                                rf"\b(talk to |ask |hey |speak to |call )?{persona_name}\b[,:]?\s*",
                                "", utterance_lower, count=1,
                            ).strip()
                            if not clean_utterance:
                                clean_utterance = "hello"
                            log(f"persona routed: {persona_name} → {persona_tool} (utterance: {clean_utterance!r})")
                            text_out = clean_utterance
                            break

                    if routed_persona:
                        # --- Persona conversation (direct chat tool) ---
                        run_persona_conversation(
                            routed_persona, text_out, args.dry_run,
                            stream, model, args.aplay_device, args.convo_turns, stt,
                        )
                    else:
                        # --- Standard Claude conversation ---
                        run_conversation(
                            text_out, args.voice_cmd, args.dry_run,
                            stream, model, args.aplay_device, args.convo_turns, stt,
                        )

                    # Reset wake recognizer after conversation ends
                    wake_rec = vosk.KaldiRecognizer(model, VOSK_RATE, grammar)
                    resample_state = None
                    log(f"listening for wake word: '{wake_phrase}'")

    finally:
        stream.stop_stream()
        stream.close()


def main(argv) -> int:
    parser = argparse.ArgumentParser(description="Wake-word listener daemon")
    parser.add_argument("--wake-word",     default=DEFAULT_WAKE,
                        help="Wake phrase to listen for (default: 'hey robot')")
    parser.add_argument("--model-dir",     default=DEFAULT_MODEL,
                        help="Path to Vosk model directory (wake word grammar)")
    parser.add_argument("--stt-model-dir", default=DEFAULT_STT_MODEL,
                        help="Path to sherpa-onnx Zipformer model directory for utterance STT")
    parser.add_argument("--mic",           default="USB",
                        help="Substring to match in mic device name (default: USB)")
    parser.add_argument("--aplay-device",  default="",
                        help="ALSA device for chime output (default: system default)")
    parser.add_argument("--voice-cmd",     default=DEFAULT_VOICE_CMD,
                        help="Voice loop command to pipe utterances to")
    parser.add_argument("--convo-turns",   type=int, default=5,
                        help="Max follow-up turns per conversation (default: 5)")
    parser.add_argument("--dry-run",       action="store_true",
                        help="Detect and transcribe but do not run voice loop")
    args = parser.parse_args(argv)

    # PID file
    PID_FILE.parent.mkdir(parents=True, exist_ok=True)
    PID_FILE.write_text(str(os.getpid()))
    persona_phrases = ", ".join(f"'{p}'" for p in PERSONA_WAKE)
    log(f"starting pid={os.getpid()} dry={args.dry_run}")
    log(f"wake phrases: '{args.wake_word}' (claude), {persona_phrases} (personas)")

    def _shutdown(sig, _frame):
        log(f"signal {sig} — stopping")
        try:
            PID_FILE.unlink(missing_ok=True)
        except Exception:
            pass
        sys.exit(0)

    signal.signal(signal.SIGTERM, _shutdown)
    signal.signal(signal.SIGINT,  _shutdown)

    # Validate model
    model_path = Path(args.model_dir)
    if not model_path.exists():
        log(f"Vosk model not found at {model_path}")
        log("Download: wget https://alphacephei.com/vosk/models/vosk-model-small-en-us-0.15.zip")
        log("Then: unzip -d models/ models/vosk-model-small-en-us.zip")
        return 1

    try:
        import vosk
        import pyaudio
    except ImportError as exc:
        log(f"missing dependency: {exc}")
        return 1

    vosk.SetLogLevel(-1)  # suppress Kaldi verbosity
    log(f"loading Vosk model {model_path} ...")
    model = vosk.Model(str(model_path))
    log("Vosk model loaded")

    # Load sherpa-onnx STT model for utterance transcription (better accuracy)
    stt = None
    stt_path = Path(args.stt_model_dir)
    if stt_path.exists():
        log(f"loading STT model {stt_path} ...")
        stt = load_stt_model(args.stt_model_dir)
        if stt is not None:
            log("STT model loaded (sherpa-onnx Zipformer)")
        else:
            log("STT model load failed — falling back to Vosk for transcription")
    else:
        log(f"STT model dir not found ({stt_path}) — using Vosk fallback")

    # PyAudio init spams ALSA warnings to stderr — suppress at the fd level
    import ctypes
    try:
        _libc = ctypes.CDLL("libc.so.6")
        _devnull = os.open(os.devnull, os.O_WRONLY)
        _saved_stderr = os.dup(2)
        os.dup2(_devnull, 2)
        os.close(_devnull)
        pa = pyaudio.PyAudio()
        os.dup2(_saved_stderr, 2)
        os.close(_saved_stderr)
    except Exception:
        pa = pyaudio.PyAudio()
    try:
        listen_loop(pa, model, args, stt)
    except KeyboardInterrupt:
        pass
    except Exception as exc:
        log(f"fatal: {exc}")
        import traceback
        traceback.print_exc()
        return 1
    finally:
        pa.terminate()
        PID_FILE.unlink(missing_ok=True)
        log("stopped")

    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
