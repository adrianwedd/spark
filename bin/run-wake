#!/usr/bin/env bash
# Launch the wake-word listener daemon.
# Usage: bin/run-wake [--wake-word "hey robot"] [--dry-run] [--help]
#
# Environment:
#   PX_WAKE_WORD      Wake phrase (default: "hey robot")
#   PX_WAKE_MODEL     Vosk grammar model dir (default: vosk-model-small-en-us-0.15)
#   PX_SENSEVOICE_MODEL  SenseVoice-Small dir (fastest STT, non-autoregressive)
#   PX_WHISPER_MODEL     faster-whisper snapshot dir (fallback STT, best AU accent)
#   PX_STT_MODEL         Sherpa-onnx Zipformer dir (fallback STT if whisper unavailable)
#   PX_VOICE_DEVICE   ALSA device for chime output
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

MODEL_DIR="${PX_WAKE_MODEL:-$PROJECT_ROOT/models/vosk-model-small-en-us-0.15}"
STT_DIR="${PX_STT_MODEL:-$PROJECT_ROOT/models/sherpa-onnx-streaming-zipformer-en-2023-06-26}"
WAKE_WORD="${PX_WAKE_WORD:-hey robot}"
APLAY_DEV="${PX_VOICE_DEVICE:-}"
# PX_WHISPER_MODEL is auto-detected inside px-wake-listen if not set

exec "$SCRIPT_DIR/px-wake-listen" \
    --model-dir "$MODEL_DIR" \
    --stt-model-dir "$STT_DIR" \
    --wake-word "$WAKE_WORD" \
    ${APLAY_DEV:+--aplay-device "$APLAY_DEV"} \
    ${PX_SENSEVOICE_MODEL:+--sensevoice-model "$PX_SENSEVOICE_MODEL"} \
    ${PX_WHISPER_MODEL:+--whisper-model "$PX_WHISPER_MODEL"} \
    "$@"
