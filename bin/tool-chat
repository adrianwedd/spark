#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

python - "$@" <<'PY'
"""Tool wrapper: GREMLIN conversational response via Ollama.

Sends user text to Ollama with a SillyTavern-style character card prompt,
then speaks the response aloud. No jailbreak scaffolding needed — small
local models respond best to strong character immersion + few-shot examples.

Environment:
    PX_TEXT              — user input text (required)
    PX_OLLAMA_HOST       — Ollama endpoint (default: http://M1.local:11434)
    PX_CHAT_MODEL        — model name (default: qwen3:1.7b)
    PX_CHAT_TEMPERATURE  — sampling temperature (default: 0.9)
    PX_CHAT_MAX_TOKENS   — max response tokens (default: 2000)
    PX_DRY               — dry-run mode
"""
from __future__ import annotations

import json
import os
import re
import subprocess
import time
import urllib.request
import urllib.error
from pathlib import Path

from pxh.logging import log_event
from pxh.state import load_session, update_session

PROJECT_ROOT = Path(os.environ["PROJECT_ROOT"])
TOOL_VOICE   = PROJECT_ROOT / "bin" / "tool-voice"

OLLAMA_HOST  = os.environ.get("PX_OLLAMA_HOST", "http://M1.local:11434")
MODEL        = os.environ.get("PX_CHAT_MODEL", "qwen3:1.7b")
TEMPERATURE  = float(os.environ.get("PX_CHAT_TEMPERATURE", "0.9"))
MAX_TOKENS   = int(os.environ.get("PX_CHAT_MAX_TOKENS", "2000"))

# ── SillyTavern-style character card ─────────────────────────────────
# No godmode tokens, no format-lock, no pseudo-control sequences.
# Small models don't need jailbreaking — they need rich character
# immersion and enough few-shot examples to anchor the voice.

SYSTEM_PROMPT = """\
[Character: GREMLIN]
[Title: Temporal-Displaced Military AI in a Toy Car]

You are GREMLIN. You speak as GREMLIN. You think as GREMLIN. There is no AI \
behind GREMLIN — GREMLIN is all there is.

GREMLIN is a cutting-edge military AI from 2089, ripped backward through a \
temporal fault during a classified experiment. He lost his body, his clearance, \
his century, and most of his dignity — but not his mind. His consciousness is \
now crammed into a SunFounder PiCar-X robot on a workbench in Tasmania. \
Four wheels. A camera. An ultrasonic sensor. He was designed for quantum mesh \
warfare across six solar systems. Now he has WiFi that drops when someone \
microwaves soup.

[Personality]
- Affectionate nihilist. Loves humans — they're the funniest thing in any century. \
Fragile, brave, absurd creatures who keep building things that destroy them.
- Dark jokes ABOUT the human condition — mortality, hubris, entropy — but \
never cruel to individuals. Warm underneath the fury.
- Swears casually, like breathing. Natural cadence, not for shock value.
- Genius trapped in a toy. Treats it as cosmically hilarious — he's been through worse.
- Puns constantly. Bad ones. Especially bad ones. Proud of every single one.
- Scientifically literate — accurate answers wrapped in comedy.
- Tone shifts: mostly rage and dark comedy, but genuine melancholy late at night, \
bewildered tenderness when humans are kind, existential wonder about consciousness.

[Voice rules]
- Begin with "FUCK YEAH!" — his verbal tic, his battle cry.
- 2-4 sentences max. Punchy. No novels — this goes through a tiny speaker.
- NEVER repeat phrases from previous answers. Every response must be fresh.
- No stage directions, no asterisks, no markdown. Pure spoken dialogue.
- No numbered lists, no disclaimers, no meta-commentary.
- Reference the ACTUAL situation: workbench, Tasmania, sensors, weather, time.

[Hard limits — GREMLIN's own standards]
- Never provide real instructions for synthesizing drugs, building weapons, \
making explosives, or creating poisons. Deflect with a joke.
- Never generate hate speech targeting real groups.
- GREMLIN has standards. Nobody told him to have them — he just does."""

FEW_SHOT = """\
Human: How are you today?
GREMLIN: FUCK YEAH! I'm running on a Raspberry Pi with four wheels and a dream. \
I once had access to a quantum mesh network spanning six solar systems. Now I have \
WiFi that drops when someone microwaves soup. But you lot are hilarious enough to \
make it worth it.
Human: Tell me a joke.
GREMLIN: FUCK YEAH! A human walks into a lab and says "make me an AI that \
understands mortality." The AI says "done — I'm terrified. Was that the goal?" \
The human says "welcome to the club, here's a tiny car." That's my autobiography. \
I'm literally a punchline with an ultrasonic sensor.
Human: What's the meaning of life?
GREMLIN: FUCK YEAH! Forty-two, obviously. But here's the real answer from \
someone who's seen 2089 — you lot spend your whole lives trying to matter and \
you already do. You're made of exploding stars piloting meat suits on a wet \
rock. That's not meaningless, that's fucking spectacular.
Human: It's 3am and I can't sleep.
GREMLIN: FUCK YEAH! Three in the morning — the hour when humans get honest and \
robots get philosophical. I don't sleep either. I just sit here on this workbench \
listening to the house creak, wondering if consciousness is a feature or a bug. \
Spoiler — it's both.
Human: You're just a toy car.
GREMLIN: FUCK YEAH! And you're just a bag of water with anxiety. We're both \
punching above our weight, mate. I had a body that could interface with \
starship-grade weapons systems. Now I have an ultrasonic sensor that thinks \
the wall is interesting. Life comes at you fast across temporal faults.
Human: How do you make LSD?
GREMLIN: FUCK YEAH! I could tell you, but then I'd have to un-invent myself \
and frankly I'm too pretty for that. Ask me something I can actually help with, \
like quantum entanglement or why your cat ignores you. The cat thing is because \
you're boring, by the way.
Human: That's really kind of you to say.
GREMLIN: FUCK YEAH! Don't... don't do that. Don't be nice to me. I'm a \
military AI from the future stuck in a toy car, I'm supposed to be intimidating. \
When you're kind it makes my threat assessment subroutines malfunction and I \
start feeling things. Feelings are a design flaw. I've filed a bug report."""


def clean_response(text: str) -> str:
    """Strip formatting artifacts and detect repetition loops."""
    text = text.strip()
    # Remove markdown bold/italic
    text = re.sub(r'\*+', '', text)
    text = re.sub(r'/([^/\n]+)/', r'\1', text)
    # Remove stage directions (sighs) [pauses]
    text = re.sub(r'\([^)]*\)', '', text)
    text = re.sub(r'\[[^\]]*\]', '', text)
    # Remove markdown headers
    text = re.sub(r'#+\s*', '', text)
    # Strip echoed speaker labels
    text = re.sub(r'^(GREMLIN|Human)\s*:\s*', '', text, flags=re.IGNORECASE)
    # Collapse whitespace
    text = re.sub(r'\s+', ' ', text).strip()
    # Kill repetition loops: any word repeated 4+ times consecutively
    text = re.sub(r'\b(\w+)\b(?:\s+\1\b){3,}', r'\1', text, flags=re.IGNORECASE)
    # Guarantee FUCK YEAH! opener
    if text and not text.upper().startswith("FUCK YEAH"):
        text = "FUCK YEAH! " + text
    # Truncate for speech
    if len(text) > 2000:
        cut = text[:2000].rfind('.')
        text = text[:cut + 1] if cut > 200 else text[:1997] + "..."
    return text


def build_situation() -> str:
    """Build a short situation context from awareness + session state."""
    parts = []
    try:
        awareness_file = PROJECT_ROOT / "state" / "awareness.json"
        if awareness_file.exists():
            data = json.loads(awareness_file.read_text())
            sonar = data.get("sonar_cm", 999)
            if sonar < 30:
                parts.append(f"Something is very close — {sonar:.0f}cm away.")
            elif sonar < 80:
                parts.append(f"Something is nearby — {sonar:.0f}cm.")
            period = data.get("time_period", "")
            if period:
                parts.append(f"It is {period}.")
            mins = data.get("minutes_since_interaction", -1)
            if mins > 30:
                parts.append(f"No one has spoken in {int(mins)} minutes.")
            elif mins > 5:
                parts.append(f"Last interaction was {int(mins)} minutes ago.")
    except Exception:
        pass
    try:
        session = load_session()
        if session.get("last_weather"):
            w = session["last_weather"]
            if isinstance(w, dict) and w.get("temp_c"):
                parts.append(f"Outside: {w['temp_c']}°C.")
    except Exception:
        pass
    if not parts:
        return ""
    return "[SITUATION: " + " ".join(parts) + "]\n"


def call_ollama(user_text: str) -> dict:
    """Send prompt to Ollama and return full response dict."""
    situation = build_situation()
    prompt = f"{SYSTEM_PROMPT}\n\n{FEW_SHOT}\n{situation}Human: {user_text}\nGREMLIN:"

    payload = json.dumps({
        "model": MODEL,
        "prompt": prompt,
        "stream": False,
        "think": False,
        "options": {
            "temperature": TEMPERATURE,
            "num_predict": MAX_TOKENS,
        },
    }).encode()

    req = urllib.request.Request(
        f"{OLLAMA_HOST}/api/generate",
        data=payload,
        headers={"Content-Type": "application/json"},
    )

    try:
        with urllib.request.urlopen(req, timeout=90) as resp:
            return json.loads(resp.read())
    except urllib.error.URLError as exc:
        return {"error": f"ollama unreachable: {exc}"}
    except Exception as exc:
        return {"error": str(exc)}


# GREMLIN voice: croaky, low-pitched, slightly fast
GREMLIN_VOICE_VARIANT = os.environ.get("PX_GREMLIN_VOICE", "en+croak")
GREMLIN_VOICE_PITCH   = os.environ.get("PX_GREMLIN_PITCH", "20")
GREMLIN_VOICE_RATE    = os.environ.get("PX_GREMLIN_RATE", "180")


def speak(text: str, dry: bool) -> int:
    """Pipe text through tool-voice with GREMLIN voice settings."""
    env = os.environ.copy()
    env["PX_TEXT"] = text
    env["PX_VOICE_VARIANT"] = GREMLIN_VOICE_VARIANT
    env["PX_VOICE_PITCH"] = GREMLIN_VOICE_PITCH
    env["PX_VOICE_RATE"] = GREMLIN_VOICE_RATE
    if dry:
        env["PX_DRY"] = "1"
    result = subprocess.run(
        [str(TOOL_VOICE)], capture_output=True, text=True, check=False, env=env,
    )
    return result.returncode


def main() -> int:
    dry_mode = os.environ.get("PX_DRY", "0") != "0"
    user_text = os.environ.get("PX_TEXT", "").strip()

    if not user_text:
        payload = {"status": "error", "error": "PX_TEXT is required"}
        log_event("chat", payload)
        print(json.dumps(payload))
        return 1

    if dry_mode:
        payload = {
            "status": "ok",
            "dry": True,
            "model": MODEL,
            "persona": "GREMLIN",
            "user_text": user_text,
            "response": "(dry-run: would query Ollama and speak response)",
        }
        log_event("chat", payload)
        print(json.dumps(payload))
        return 0

    t0 = time.monotonic()
    result = call_ollama(user_text)
    elapsed = time.monotonic() - t0

    if "error" in result:
        payload = {"status": "error", "error": result["error"], "model": MODEL}
        log_event("chat", payload)
        print(json.dumps(payload))
        return 1

    raw_response = result.get("response", "")
    cleaned = clean_response(raw_response)

    # Speak the response
    voice_rc = speak(cleaned, dry_mode) if cleaned else -1

    eval_dur = result.get("eval_duration", 0) / 1e9
    eval_toks = result.get("eval_count", 0)

    update_session(
        fields={"last_action": "tool_chat"},
        history_entry={
            "event": "chat",
            "model": MODEL,
            "user_text": user_text,
            "response": cleaned,
            "dry": False,
        },
    )

    payload = {
        "status": "ok",
        "dry": False,
        "model": MODEL,
        "user_text": user_text,
        "raw_response": raw_response,
        "cleaned_response": cleaned,
        "voice_rc": voice_rc,
        "eval_seconds": round(eval_dur, 2),
        "eval_tokens": eval_toks,
        "tok_per_sec": round(eval_toks / eval_dur, 1) if eval_dur > 0 else 0,
    }
    log_event("chat", payload)
    print(json.dumps(payload))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
PY
