#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

python - "$@" <<'PY'
"""Tool wrapper: photograph the scene then describe it using Claude vision."""
from __future__ import annotations

import json
import os
import shutil
import signal
import subprocess
import time
import urllib.request
import urllib.error
from pathlib import Path

from pxh.logging import log_event
from pxh.state import update_session

PROJECT_ROOT      = Path(os.environ["PROJECT_ROOT"])
TOOL_PHOTOGRAPH   = PROJECT_ROOT / "bin" / "tool-photograph"
TOOL_VOICE        = PROJECT_ROOT / "bin" / "tool-voice"
LOG_DIR           = Path(os.environ.get("LOG_DIR", PROJECT_ROOT / "logs"))

# Frigate API — set PX_FRIGATE_HOST to override (e.g. http://pi5-hailo:5000)
FRIGATE_HOST      = os.environ.get("PX_FRIGATE_HOST", "http://pi5-hailo:5000")
FRIGATE_CAMERA    = os.environ.get("PX_FRIGATE_CAMERA", "picar_x")
FRIGATE_TIMEOUT   = 4  # seconds


def _frigate_latest_jpg(dest: Path) -> bool:
    """Download latest Frigate frame for the camera. Returns True on success."""
    url = f"{FRIGATE_HOST}/api/{FRIGATE_CAMERA}/latest.jpg"
    try:
        with urllib.request.urlopen(url, timeout=FRIGATE_TIMEOUT) as resp:
            if resp.status != 200:
                return False
            dest.parent.mkdir(parents=True, exist_ok=True)
            dest.write_bytes(resp.read())
        return dest.stat().st_size > 0
    except Exception:
        return False


def _stream_pid() -> int | None:
    """Return the running px-frigate-stream PID, or None if not running."""
    pid_file = LOG_DIR / "px-frigate-stream.pid"
    if not pid_file.exists():
        return None
    try:
        pid = int(pid_file.read_text().strip())
        if Path(f"/proc/{pid}").is_dir():
            return pid
    except Exception:
        pass
    return None


def _pause_stream() -> bool:
    """SIGTERM the stream and wait up to 8 s for it to stop. Returns True if stopped."""
    pid = _stream_pid()
    if pid is None:
        return True  # already stopped
    try:
        os.kill(pid, signal.SIGTERM)
    except ProcessLookupError:
        return True
    pid_file = LOG_DIR / "px-frigate-stream.pid"
    for _ in range(16):  # 8 s in 0.5 s steps
        time.sleep(0.5)
        if not pid_file.exists() or _stream_pid() is None:
            return True
    return False  # timed out


def _resume_stream() -> None:
    """Restart px-frigate-stream via systemd (non-blocking)."""
    bypass = os.environ.get("PX_BYPASS_SUDO", "0") == "1"
    cmd = (["bin/px-frigate-stream"] if bypass
           else ["sudo", "-n", "/bin/systemctl", "start", "px-frigate-stream"])
    subprocess.Popen(
        cmd,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        cwd=str(PROJECT_ROOT),
    )

FALLBACK_DESCRIPTION = "I couldn't see anything right now."
CLAUDE_TIMEOUT = 45

# claude CLI may not be on PATH when launched from systemd — find it explicitly
CLAUDE_BIN = (shutil.which("claude")
              or "/home/pi/.local/bin/claude"
              or "claude")


def run_tool(path: Path, extra_env: dict) -> tuple[int, dict]:
    env = os.environ.copy()
    env.update(extra_env)
    result = subprocess.run(
        [str(path)],
        capture_output=True,
        text=True,
        check=False,
        env=env,
    )
    try:
        payload = json.loads(result.stdout.strip().splitlines()[-1])
    except (json.JSONDecodeError, IndexError):
        payload = {"status": "error", "stderr": result.stderr[-256:]}
    return result.returncode, payload


def call_claude_vision(image_path: Path) -> str:
    """Ask Claude to describe the image. Returns description string.

    Uses the Read tool so Claude can view the JPEG directly.
    """
    # Unset Claude Code env vars so the CLI runs as plain claude (not code mode)
    env = os.environ.copy()
    env.pop("CLAUDECODE", None)
    env.pop("CLAUDE_CODE_ENTRYPOINT", None)

    prompt = (
        f"Read the image at {image_path} and describe what you see "
        f"in 2 concise sentences. Focus on people, objects, and setting."
    )
    try:
        result = subprocess.run(
            [
                CLAUDE_BIN, "-p", prompt,
                "--allowedTools", "Read",
                "--output-format", "text",
            ],
            capture_output=True,
            text=True,
            check=False,
            env=env,
            timeout=CLAUDE_TIMEOUT,
        )
    except subprocess.TimeoutExpired:
        return FALLBACK_DESCRIPTION
    except Exception:
        return FALLBACK_DESCRIPTION

    if result.returncode != 0 or not result.stdout.strip():
        return FALLBACK_DESCRIPTION

    return result.stdout.strip()[:300]


def main() -> int:
    dry_mode = os.environ.get("PX_DRY", "0") != "0"

    if dry_mode:
        description = "A dry-run scene with a robot on a table."
        payload = {
            "status": "ok",
            "path": None,
            "description": description,
            "dry": True,
        }
        log_event("describe_scene", payload)
        update_session(
            fields={"last_action": "tool_describe_scene"},
            history_entry={"event": "describe_scene", "dry": True},
        )
        print(json.dumps(payload))
        return 0

    import datetime as dt
    timestamp = dt.datetime.now().strftime("%Y%m%dT%H%M%S")
    photo_path = PROJECT_ROOT / "photos" / f"{timestamp}.jpg"
    stream_was_running = _stream_pid() is not None
    stream_paused = False

    # Step 1: try Frigate latest frame first (no camera interruption)
    got_photo = _frigate_latest_jpg(photo_path)
    source = "frigate"

    if not got_photo:
        # Step 1b: pause stream and capture directly with rpicam
        if stream_was_running:
            log_event("describe_scene", {"status": "pausing_stream"})
            if not _pause_stream():
                payload = {"status": "error", "error": "stream did not stop in time"}
                log_event("describe_scene", payload)
                print(json.dumps(payload))
                return 1
            stream_paused = True

        rc_photo, photo_result = run_tool(TOOL_PHOTOGRAPH, {"PX_PHOTO_PATH": str(photo_path)})
        if photo_result.get("status") != "ok":
            if stream_paused:
                _resume_stream()
            payload = {
                "status": "error",
                "error": "photo capture failed",
                "photo": photo_result,
            }
            log_event("describe_scene", payload)
            print(json.dumps(payload))
            return 1
        source = "rpicam"

    if not photo_path.exists():
        if stream_paused:
            _resume_stream()
        payload = {"status": "error", "error": f"photo file missing: {photo_path}"}
        log_event("describe_scene", payload)
        print(json.dumps(payload))
        return 1

    # Resume stream before the slow Claude vision call
    if stream_paused:
        _resume_stream()
        stream_paused = False

    # Step 2: describe with Claude vision
    description = call_claude_vision(photo_path)

    # Step 3: speak the description
    env = os.environ.copy()
    env["PX_TEXT"] = description[:2000]
    subprocess.run([str(TOOL_VOICE)], capture_output=True, text=True, check=False, env=env)

    payload = {
        "status": "ok",
        "path": str(photo_path),
        "description": description,
        "source": source,
        "dry": False,
    }
    log_event("describe_scene", payload)
    update_session(
        fields={"last_action": "tool_describe_scene"},
        history_entry={"event": "describe_scene", "dry": False, "description": description[:80]},
    )
    print(json.dumps(payload))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
PY
