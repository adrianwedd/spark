#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

python - "$@" <<'PY'
"""Tool wrapper: play a bundled sound effect via aplay."""
from __future__ import annotations

import json
import os
import subprocess
from pathlib import Path

from pxh.logging import log_event
from pxh.state import update_session

PROJECT_ROOT = Path(os.environ["PROJECT_ROOT"])
SOUNDS_DIR   = Path(os.environ.get("PX_SOUNDS_DIR", PROJECT_ROOT / "sounds"))

# Built-in effects always allowed; recorded sounds are discovered from SOUNDS_DIR.
BUILTIN_SOUNDS = {"chime", "beep", "tada", "alert"}


def allowed_sounds() -> set[str]:
    found = set()
    if SOUNDS_DIR.exists():
        found = {p.stem.lower() for p in SOUNDS_DIR.glob("*.wav")}
    return BUILTIN_SOUNDS | found


def main() -> int:
    dry_mode = os.environ.get("PX_DRY", "0") != "0"

    name = os.environ.get("PX_SOUND", "").strip().lower()
    if not name:
        payload = {"status": "error", "error": "PX_SOUND is required"}
        log_event("play_sound", payload)
        print(json.dumps(payload))
        return 1

    if name not in allowed_sounds():
        payload = {
            "status": "error",
            "error": f"unknown sound '{name}'; allowed: {sorted(allowed_sounds())}",
        }
        log_event("play_sound", payload)
        print(json.dumps(payload))
        return 1

    sound_path = SOUNDS_DIR / f"{name}.wav"

    if dry_mode:
        payload = {"status": "ok", "sound": name, "dry": True}
        log_event("play_sound", payload)
        update_session(
            fields={"last_action": "tool_play_sound"},
            history_entry={"event": "play_sound", "sound": name, "dry": True},
        )
        print(json.dumps(payload))
        return 0

    if not sound_path.exists():
        payload = {"status": "error", "error": f"sound file missing: {sound_path}"}
        log_event("play_sound", payload)
        print(json.dumps(payload))
        return 1

    # Enable speaker amp before playback
    try:
        subprocess.run(
            ["sudo", "-n", "/usr/bin/python3", "-c",
             "from robot_hat import enable_speaker; enable_speaker()"],
            check=False,
            capture_output=True,
        )
    except Exception:
        pass  # Non-fatal — aplay may still work

    device = os.environ.get("PX_VOICE_DEVICE", "")
    play_cmd = ["aplay", "-q"]
    if device:
        play_cmd.extend(["-D", device])
    play_cmd.append(str(sound_path))

    try:
        result = subprocess.run(play_cmd, capture_output=True, text=True, check=False)
    except Exception as exc:
        payload = {"status": "error", "error": f"aplay failed: {exc}"}
        log_event("play_sound", payload)
        print(json.dumps(payload))
        return 1

    if result.returncode != 0:
        payload = {
            "status": "error",
            "error": "aplay exited with non-zero status",
            "rc": result.returncode,
            "stderr": result.stderr[-512:],
        }
        log_event("play_sound", payload)
        print(json.dumps(payload))
        return 1

    payload = {"status": "ok", "sound": name, "dry": False}
    log_event("play_sound", payload)
    update_session(
        fields={"last_action": "tool_play_sound"},
        history_entry={"event": "play_sound", "sound": name, "dry": False},
    )
    print(json.dumps(payload))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
PY
