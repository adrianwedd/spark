#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

python - "$@" <<'PY'
"""Tool wrapper: speak a Q&A answer aloud (delegates to tool-voice)."""
from __future__ import annotations

import json
import os
import subprocess
from pathlib import Path

from pxh.logging import log_event
from pxh.state import update_session

PROJECT_ROOT = Path(os.environ["PROJECT_ROOT"])
TOOL_VOICE   = PROJECT_ROOT / "bin" / "tool-voice"


def main() -> int:
    dry_mode = os.environ.get("PX_DRY", "0") != "0"

    text = os.environ.get("PX_TEXT", "").strip()
    if not text:
        payload = {"status": "error", "error": "PX_TEXT is required"}
        log_event("qa", payload)
        print(json.dumps(payload))
        return 1

    if len(text) > 2000:
        text = text[:2000]

    env = os.environ.copy()
    env["PX_TEXT"] = text

    try:
        result = subprocess.run(
            [str(TOOL_VOICE)],
            capture_output=True,
            text=True,
            check=False,
            env=env,
        )
    except Exception as exc:
        payload = {"status": "error", "error": f"tool-voice failed: {exc}"}
        log_event("qa", payload)
        print(json.dumps(payload))
        return 1

    try:
        inner = json.loads(result.stdout.strip().splitlines()[-1]) if result.stdout.strip() else {}
    except (json.JSONDecodeError, IndexError):
        inner = {}

    spoken = inner.get("spoken", text)
    payload = {
        "status": "ok" if result.returncode == 0 else "error",
        "spoken": spoken,
        "dry": dry_mode,
        "returncode": result.returncode,
    }
    if result.returncode != 0:
        payload["stderr"] = result.stderr[-512:]

    log_event("qa", payload)
    update_session(
        fields={"last_action": "tool_qa"},
        history_entry={"event": "qa", "spoken": spoken[:80], "dry": dry_mode},
    )
    print(json.dumps(payload))
    return 0 if result.returncode == 0 else 1


if __name__ == "__main__":
    raise SystemExit(main())
PY
