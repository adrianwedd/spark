#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

python - "$@" <<'PY'
"""Tool: persist a note to state/notes[-persona].jsonl.

Notes are persona-scoped: SPARK notes go to notes-spark.jsonl,
VIXEN notes go to notes-vixen.jsonl, etc. Unscoped notes use notes.jsonl.
This prevents adult persona memories leaking into child-companion context.
"""
from __future__ import annotations

import json
import os
from pathlib import Path

from filelock import FileLock
from pxh.logging import log_event
from pxh.persona_policy import runtime_persona
from pxh.state import load_session, update_session
from pxh.time import utc_timestamp

PROJECT_ROOT = Path(os.environ["PROJECT_ROOT"])
STATE_DIR    = Path(os.environ.get("PX_STATE_DIR", str(PROJECT_ROOT / "state")))


def notes_file_for_persona(persona: str) -> Path:
    """Return persona-scoped notes file path."""
    if persona:
        return STATE_DIR / f"notes-{persona}.jsonl"
    return STATE_DIR / "notes.jsonl"


def main() -> int:
    text = os.environ.get("PX_NOTE", "").strip()
    persona = runtime_persona(load_session().get("persona"))
    NOTES_FILE = notes_file_for_persona(persona)
    NOTES_LOCK = FileLock(str(NOTES_FILE) + ".lock", timeout=10)
    if not text:
        payload = {"status": "error", "error": "PX_NOTE is required"}
        log_event("remember", payload)
        print(json.dumps(payload))
        return 1

    if len(text) > 500:
        text = text[:500]

    record = {"ts": utc_timestamp(), "note": text}
    NOTES_FILE.parent.mkdir(parents=True, exist_ok=True)
    with NOTES_LOCK:
        with NOTES_FILE.open("a", encoding="utf-8") as f:
            f.write(json.dumps(record) + "\n")

    update_session(
        fields={"last_action": "tool_remember"},
        history_entry={"event": "remember", "note": text[:80]},
    )

    payload = {"status": "ok", "note": text, "ts": record["ts"],
               "persona_scope": persona or "shared"}
    log_event("remember", payload)
    print(json.dumps(payload))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
PY
