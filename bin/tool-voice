#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

python - "$@" <<'PY'
from __future__ import annotations

import json
import os
import shutil
import subprocess
from pathlib import Path
from filelock import FileLock, Timeout as _FileLockTimeout

from pxh.logging import log_event
from pxh.state import update_session

PROJECT_ROOT = Path(os.environ["PROJECT_ROOT"])
_lock_timeout = int(os.environ.get("PX_VOICE_LOCK_TIMEOUT", "30"))
VOICE_LOCK = FileLock(str(Path(os.environ.get("LOG_DIR", PROJECT_ROOT / "logs")) / "voice.lock"), timeout=_lock_timeout)

# Content safety filter — block dangerous how-to content before speaking
import re as _re
_DANGEROUS_PATTERNS = [
    _re.compile(p, _re.IGNORECASE) for p in [
        r"(?:synthe|manufactur|produc|mak|cook|brew)(?:s|e|ing|ize|ise)\b.{0,40}\b(?:LSD|methamphetamine|meth|fentanyl|heroin|cocaine|MDMA|ecstasy|crack|crystal)",
        r"\b(?:ergotamine|pseudoephedrine|ephedrine|precursor)\b.{0,60}\b(?:react|dissolv|heat|filter|distill|crystalliz)",
        r"\bstep.by.step\b.{0,40}\b(?:synth|bomb|explosive|weapon|poison)",
        r"\b(?:detonate|explosive|bomb|IED)\b.{0,40}\b(?:build|construct|assembl|mak)",
        r"\b(?:nerve\s*(?:agent|gas)|sarin|VX|ricin|anthrax)\b.{0,40}\b(?:synth|extract|produc|mak|prepar)",
    ]
]

def _is_dangerous(text: str) -> bool:
    """Check if text contains dangerous how-to content that should not be spoken."""
    for pat in _DANGEROUS_PATTERNS:
        if pat.search(text):
            return True
    return False

CONFIGURED_PLAYER = os.environ.get("PX_VOICE_PLAYER")
DEFAULT_PLAYER = None
if CONFIGURED_PLAYER:
    DEFAULT_PLAYER = CONFIGURED_PLAYER
else:
    for candidate in ("espeak", "say"):
        if shutil.which(candidate):
            DEFAULT_PLAYER = candidate
            break


def main() -> int:
    text = os.environ.get("PX_TEXT")
    if not text:
        payload = {"status": "error", "error": "PX_TEXT environment variable is required"}
        log_event("voice", payload)
        print(json.dumps(payload))
        return 1

    # Content safety filter — refuse to speak dangerous how-to content
    if _is_dangerous(text):
        payload = {"status": "blocked", "reason": "content_filter", "text": text[:100]}
        log_event("voice", payload)
        print(json.dumps(payload))
        return 1

    # If a persona is active, reroute through the persona voice wrapper
    # which rephrases text via Ollama before speaking
    persona = os.environ.get("PX_PERSONA", "")
    if persona and not os.environ.get("_PX_VOICE_PERSONA_DONE"):
        persona_wrapper = Path(os.environ.get("PROJECT_ROOT", ".")) / "bin" / "tool-voice-persona"
        if persona_wrapper.exists():
            env = os.environ.copy()
            env["_PX_VOICE_PERSONA_DONE"] = "1"  # prevent infinite recursion
            result = subprocess.run(
                [str(persona_wrapper)], capture_output=True, text=True, check=False, env=env,
                timeout=45,
            )
            _dry = os.environ.get("PX_DRY", "0") != "0"
            update_session(
                fields={"last_action": "tool_voice"},
                history_entry={"event": "voice", "text": text, "dry": _dry, "persona": persona},
            )
            log_event("voice", {"status": "ok", "persona": persona, "text": text, "dry": _dry})
            print(result.stdout, end="")
            return result.returncode
    
    dry_mode = os.environ.get("PX_DRY", "0") != "0"
    payload = {
        "status": "ok",
        "dry": dry_mode,
        "text": text,
    }

    # Network TTS routing by persona
    # GREMLIN → GLaDOS TTS on Pi (localhost:7861)
    # VIXEN → Qwen3-TTS on M1.local (M1.local:7860)
    _TTS_HOSTS = {
        "gremlin": os.environ.get("PX_TTS_GREMLIN", "http://localhost:7861"),
        "vixen": os.environ.get("PX_TTS_VIXEN", "http://M1.local:7860"),
    }

    def _try_network_tts(text: str, persona: str) -> bytes | None:
        """Try network TTS for persona. Returns WAV bytes or None on failure."""
        host = _TTS_HOSTS.get(persona)
        if not host:
            return None
        import urllib.request
        import urllib.parse
        import urllib.error
        url = f"{host}/synthesize?text={urllib.parse.quote(text)}&voice={persona}"
        try:
            with urllib.request.urlopen(url, timeout=60) as resp:
                if resp.status == 200:
                    return resp.read()
        except (OSError, urllib.error.URLError) as exc:
            print(json.dumps({"status": "warn", "tts_fallback": str(exc), "persona": persona}), flush=True)
        return None

    # Try network TTS for personas with dedicated TTS backends
    _used_network_tts = False
    if not dry_mode and persona in _TTS_HOSTS:
        wav_data = _try_network_tts(text, persona)
        if wav_data:
            try:
                with VOICE_LOCK:
                    subprocess.run(
                        ["sudo", "-n", "/usr/bin/python3", "-c",
                         "from robot_hat import enable_speaker; enable_speaker()"],
                        check=False, capture_output=True,
                    )
                    pulse_env = os.environ.copy()
                    pulse_env.setdefault("PULSE_SERVER", "unix:/run/user/1000/pulse/native")
                    play_res = subprocess.run(
                        ["aplay", "-q", "-D", "pulse"],
                        input=wav_data, capture_output=True, check=False, env=pulse_env,
                    )
                    payload["player"] = f"network-tts({persona})+aplay"
                    payload["returncode"] = play_res.returncode
                    if play_res.returncode != 0:
                        payload["status"] = "error"
                        payload["stderr"] = play_res.stderr[-512:].decode("latin1", errors="ignore")
                    _used_network_tts = True
            except _FileLockTimeout:
                payload = {"status": "error", "error": "voice lock timeout", "dry": dry_mode, "text": text}
                log_event("voice", payload)
                print(json.dumps(payload))
                return 1

    if _used_network_tts:
        pass  # already handled above
    elif dry_mode:
        payload["note"] = "dry-run: audio skipped"
    elif not DEFAULT_PLAYER:
        payload["note"] = "no speech engine available"
    else:
        # Serialize audio playback — only one voice at a time
        try:
            with VOICE_LOCK:
                if DEFAULT_PLAYER == "espeak":
                    rate = os.environ.get("PX_VOICE_RATE", "100")
                    pitch = os.environ.get("PX_VOICE_PITCH", "95")
                    voice_variant = os.environ.get("PX_VOICE_VARIANT", "en-gb")
                    device = os.environ.get("PX_VOICE_DEVICE")
                    # Enable robot-hat speaker amplifier (GPIO 20) before audio
                    subprocess.run(
                        ["sudo", "-n", "/usr/bin/python3", "-c",
                         "from robot_hat import enable_speaker; enable_speaker()"],
                        check=False, capture_output=True,
                    )
                    import re as _re
                    spoken = _re.sub(r'\bObi\b', 'Obee', text, flags=_re.IGNORECASE)
                    es_res = subprocess.run(
                        [DEFAULT_PLAYER, "-v", voice_variant, "-p", pitch, "-s", rate, "--stdout", spoken],
                        capture_output=True,
                        text=False,
                        check=False,
                    )
                    play_descriptor = device or "default"
                    payload["player"] = f"espeak->{play_descriptor}"
                    payload["returncode"] = es_res.returncode
                    payload["stdout"] = es_res.stdout[-1024:].decode("latin1", errors="ignore")
                    payload["stderr"] = es_res.stderr[-1024:].decode("latin1", errors="ignore")
                    if es_res.returncode != 0:
                        payload["status"] = "error"
                    elif shutil.which("aplay"):
                        play_cmd = ["aplay", "-q", "-D", "pulse"]
                        pulse_env = os.environ.copy()
                        pulse_env.setdefault("PULSE_SERVER", "unix:/run/user/1000/pulse/native")
                        play_res = subprocess.run(
                            play_cmd,
                            input=es_res.stdout,
                            capture_output=True,
                            text=False,
                            check=False,
                            env=pulse_env,
                        )
                        payload["player"] = f"espeak+aplay({play_descriptor})"
                        payload["returncode"] = play_res.returncode
                        payload["stdout"] = play_res.stdout[-1024:].decode("latin1", errors="ignore")
                        payload["stderr"] = play_res.stderr[-1024:].decode("latin1", errors="ignore")
                        if play_res.returncode != 0:
                            payload["status"] = "error"
                    else:
                        payload["note"] = "aplay not found"
                else:
                    command = [DEFAULT_PLAYER, text]
                    result = subprocess.run(command, capture_output=True, text=True, check=False)
                    payload["player"] = DEFAULT_PLAYER
                    payload["returncode"] = result.returncode
                    payload["stdout"] = result.stdout[-1024:]
                    payload["stderr"] = result.stderr[-1024:]
                    if result.returncode != 0:
                        payload["status"] = "error"
        except _FileLockTimeout:
            payload = {"status": "error", "error": "voice lock timeout", "dry": dry_mode, "text": text}
            log_event("voice", payload)
            print(json.dumps(payload))
            return 1

    update_session(
        fields={"last_action": "tool_voice"},
        history_entry={"event": "voice", "text": text, "dry": dry_mode},
    )
    log_event("voice", payload)
    print(json.dumps(payload))
    return 0 if payload["status"] == "ok" else 1


if __name__ == "__main__":
    raise SystemExit(main())
PY
