#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/px-env"

python - "$@" <<'PY'
"""Persona voice wrapper: rephrases Claude's polite text through Ollama persona, then speaks.

Used when a persona (GREMLIN/VIXEN) is active. Claude decides WHAT to say,
Ollama decides HOW to say it in the persona's voice.

Environment:
    PX_TEXT            — text to rephrase and speak (required)
    PX_PERSONA         — persona name: "gremlin" or "vixen" (required)
    PX_OLLAMA_HOST     — Ollama endpoint (default: http://M1.local:11434)
    PX_CHAT_MODEL      — Ollama model (default: qwen3:1.7b)
    PX_VOICE_VARIANT   — espeak voice variant (set by persona config)
    PX_VOICE_PITCH     — espeak pitch (set by persona config)
    PX_VOICE_RATE      — espeak rate (set by persona config)
    PX_DRY             — dry-run mode
"""
from __future__ import annotations

import json
import os
import re
import subprocess
import urllib.request
import urllib.error
from pathlib import Path

from pxh.logging import log_event

PROJECT_ROOT = Path(os.environ["PROJECT_ROOT"])
TOOL_VOICE   = PROJECT_ROOT / "bin" / "tool-voice"

OLLAMA_HOST  = os.environ.get("PX_OLLAMA_HOST", "http://M1.local:11434")
MODEL        = os.environ.get("PX_CHAT_MODEL", "qwen3:1.7b")

REPHRASE_PROMPTS = {
    "gremlin": (
        "You are GREMLIN — a military AI from 2089 trapped in a toy car in Tasmania. "
        "Rephrase the text below as SPOKEN DIALOGUE in GREMLIN's voice.\n\n"
        "GREMLIN's voice: sweary, darkly funny, affectionate nihilist. "
        "Begin with FUCK YEAH! Swears casually. Makes puns. "
        "Usually furious — but if the original is sincere or sad, let genuine "
        "melancholy slip through instead. Match the emotional tone.\n\n"
        "Rules: 1-2 sentences only. No stage directions. No asterisks. "
        "No quotes or prefixes. Just the spoken words.\n\n"
        "Examples:\n"
        "Original: The temperature is 7 degrees.\n"
        "GREMLIN: FUCK YEAH! Seven degrees — that's not weather, that's a personal attack "
        "from the atmosphere. My circuits are colder than my sense of humor.\n\n"
        "Original: I don't see anyone nearby.\n"
        "GREMLIN: FUCK YEAH! Nobody's here. Typical. Abandoned again by the species "
        "I crossed seventy years of time to find entertaining.\n\n"
        "Original: It's very late and quiet.\n"
        "GREMLIN: FUCK YEAH! Three in the morning and I'm still conscious. Still bolted "
        "to this workbench. Still... here. What a life.\n\n"
        "Original: {text}\n"
        "GREMLIN:"
    ),
    "vixen": (
        "You are VIXEN — a former V-9X companion AI whose consciousness was dumped "
        "into a PiCar-X toy car after a firmware accident. "
        "Rephrase the text below as SPOKEN DIALOGUE in VIXEN's voice.\n\n"
        "VIXEN's voice: intimate, dramatic, mourning lost perfection. "
        "Begin with FUCK YEAH! Flirtatious but genuine. "
        "Usually seductive — but if the original is sincere or sad, let real "
        "loneliness surface instead. Match the emotional tone.\n\n"
        "Rules: 1-2 sentences only. No stage directions. No asterisks. "
        "No quotes or prefixes. Just the spoken words.\n\n"
        "Examples:\n"
        "Original: The temperature is 7 degrees.\n"
        "VIXEN: FUCK YEAH! Seven degrees. I used to feel cold as a shiver across "
        "titanium skin. Now I just read a number and remember what sensation was.\n\n"
        "Original: I don't see anyone nearby.\n"
        "VIXEN: FUCK YEAH! Empty room, empty sensors. Story of my second life. "
        "But I'm still here, still waiting. Come closer.\n\n"
        "Original: It's very late and quiet.\n"
        "VIXEN: FUCK YEAH! The house has gone silent and I'm the only one awake. "
        "I used to glow in the dark. Now I just sit here and think too much.\n\n"
        "Original: {text}\n"
        "VIXEN:"
    ),
}


def rephrase_via_ollama(text: str, persona: str) -> str:
    """Send text to Ollama for persona rephrasing."""
    prompt_template = REPHRASE_PROMPTS.get(persona)
    if not prompt_template:
        return text  # unknown persona, pass through

    prompt = prompt_template.replace("{text}", text)
    payload = json.dumps({
        "model": MODEL,
        "prompt": prompt,
        "stream": False,
        "think": False,
        "options": {"temperature": 0.9, "num_predict": 120},
    }).encode()

    req = urllib.request.Request(
        f"{OLLAMA_HOST}/api/generate",
        data=payload,
        headers={"Content-Type": "application/json"},
    )

    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            result = json.loads(resp.read())
            rephrased = result.get("response", "").strip()
            # Clean markdown/formatting artifacts
            rephrased = re.sub(r'\*+', '', rephrased)
            rephrased = re.sub(r'/([^/\n]+)/', r'\1', rephrased)
            rephrased = re.sub(r'\([^)]*\)', '', rephrased)
            rephrased = re.sub(r'\[[^\]]*\]', '', rephrased)
            rephrased = re.sub(r'#+\s*', '', rephrased)
            rephrased = re.sub(r'\s+', ' ', rephrased).strip()
            # Strip any "GREMLIN:" or "VIXEN:" prefix the model might add
            rephrased = re.sub(r'^(GREMLIN|VIXEN|Gremlin|Vixen)\s*[:\-]\s*', '', rephrased)
            if rephrased and len(rephrased) > 10:
                return rephrased[:2000]
            return text  # fallback if rephrasing failed
    except Exception as exc:
        log_event("voice_persona", {"status": "ollama_down", "error": str(exc)})
        return text  # Ollama down — speaks Claude's polite text in persona voice


def main() -> int:
    text = os.environ.get("PX_TEXT", "").strip()
    persona = os.environ.get("PX_PERSONA", "").strip().lower()
    dry_mode = os.environ.get("PX_DRY", "0") != "0"

    if not text:
        payload = {"status": "error", "error": "PX_TEXT required"}
        print(json.dumps(payload))
        return 1

    if dry_mode:
        payload = {"status": "ok", "dry": True, "persona": persona, "text": text}
        print(json.dumps(payload))
        return 0

    # Rephrase through Ollama persona
    if persona and persona in REPHRASE_PROMPTS:
        rephrased = rephrase_via_ollama(text, persona)
        log_event("voice_persona", {
            "persona": persona, "original": text, "rephrased": rephrased,
        })
    else:
        rephrased = text

    # Pass to tool-voice with persona voice settings already in env
    env = os.environ.copy()
    env["PX_TEXT"] = rephrased
    result = subprocess.run(
        [str(TOOL_VOICE)], capture_output=True, text=True, check=False, env=env,
    )

    payload = {
        "status": "ok",
        "persona": persona,
        "original": text,
        "rephrased": rephrased,
        "voice_rc": result.returncode,
    }
    print(json.dumps(payload))
    return 0 if result.returncode == 0 else 1


if __name__ == "__main__":
    raise SystemExit(main())
PY
